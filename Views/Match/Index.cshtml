@{
    ViewData["Title"] = "REVORA Match";
}

<div class="min-h-screen bg-gray-50 flex items-center justify-center p-4">
    <div class="relative w-full max-w-md h-[650px] bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100 flex flex-col">
        
        <!-- Header -->
        <div class="p-4 flex justify-between items-center border-b border-gray-100 bg-white/80 backdrop-blur-md z-10">
            <a href="/" class="text-gray-400 hover:text-gray-600 transition">
                <i data-lucide="arrow-left" class="w-6 h-6"></i>
            </a>
            <div class="flex items-center gap-2">
                <i data-lucide="flame" class="w-6 h-6 text-orange-500 fill-orange-500"></i>
                <h1 class="font-bold text-xl text-gray-800 tracking-wide">MATCH</h1>
            </div>
            <button class="text-gray-400 hover:text-gray-600 transition relative">
                <i data-lucide="message-circle" class="w-6 h-6"></i>
                <span class="absolute -top-1 -right-1 w-3 h-3 bg-red-500 rounded-full border-2 border-white"></span>
            </button>
        </div>

        <!-- Tinder-like Card Stack Area -->
        <div class="flex-1 relative p-4 bg-gray-50">
            <!-- Mock Card -->
            <div class="absolute inset-4 bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-200 transform transition-transform cursor-grab active:cursor-grabbing hover:scale-[1.02]">
                <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600" class="w-full h-full object-cover" />
                
                <!-- Gradient Info Box -->
                <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-6 pt-20 text-white">
                    <div class="flex items-end justify-between">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <h2 class="text-2xl font-bold text-white shadow-sm">Đồng hồ Apple Watch</h2>
                                <span class="bg-blue-500 text-white text-[10px] px-1.5 py-0.5 rounded-full font-bold">New</span>
                            </div>
                            <p class="text-white/80 text-sm mb-2"><i data-lucide="map-pin" class="w-3 h-3 inline"></i> Hà Nội</p>
                            <div class="text-[#4ADE80] font-bold text-2xl">5.500.000đ</div>
                        </div>
                        <button class="w-10 h-10 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center hover:bg-white/30 transition">
                            <i data-lucide="info" class="w-5 h-5 text-white"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="p-6 pb-8 bg-white flex justify-center items-center gap-6 z-10">
            <!-- Reject -->
            <button class="w-16 h-16 bg-white border-2 border-red-100 rounded-full flex items-center justify-center text-red-500 hover:bg-red-50 hover:scale-110 transition-all shadow-sm">
                <i data-lucide="x" class="w-8 h-8"></i>
            </button>

            <!-- Super Like -->
            <button class="w-12 h-12 bg-white border-2 border-blue-100 rounded-full flex items-center justify-center text-blue-500 hover:bg-blue-50 hover:scale-110 transition-all shadow-sm">
                <i data-lucide="star" class="w-6 h-6 fill-blue-500/20"></i>
            </button>

            <!-- Like -->
            <button class="w-16 h-16 bg-white border-2 border-green-100 rounded-full flex items-center justify-center text-green-500 hover:bg-green-50 hover:scale-110 transition-all shadow-sm">
                <i data-lucide="heart" class="w-8 h-8 fill-green-500/20"></i>
            </button>
        </div>
    </div>
</div>
