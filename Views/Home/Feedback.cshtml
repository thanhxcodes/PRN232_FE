@{
    ViewData["Title"] = "Đóng Góp Ý Kiến";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-gray-50 flex flex-col items-center justify-center p-4">
    <div class="max-w-xl w-full bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
        <div class="h-2 bg-gradient-to-r from-[#2D5A3D] via-green-600 to-green-500"></div>
        <div class="p-8 sm:p-10">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-gray-900 mb-3">Đóng Góp Ý Kiến</h1>
                <p class="text-gray-500 text-sm">
                    Ý kiến của bạn giúp chúng tôi cải thiện REVORA ngày một tốt hơn. Cảm ơn bạn đã đồng hành cùng chúng tôi!
                </p>
            </div>

            <form class="space-y-6">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Email của bạn
                    </label>
                    <div class="relative">
                        <i data-lucide="mail" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
                        <input type="email" placeholder="ví dụ: user@gmail.com" class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/25 focus:border-[#2D5A3D]/40 bg-gray-50 focus:bg-white transition-all" required />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Nội dung góp ý
                    </label>
                    <div class="relative">
                        <i data-lucide="message-square" class="absolute left-4 top-4 w-5 h-5 text-gray-400"></i>
                        <textarea placeholder="Hãy chia sẻ suy nghĩ, trải nghiệm hoặc đề xuất của bạn về REVORA..." class="w-full pl-11 pr-4 py-3.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/25 focus:border-[#2D5A3D]/40 bg-gray-50 focus:bg-white transition-all min-h-[160px] resize-y" required></textarea>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white py-4 rounded-xl hover:shadow-lg hover:shadow-[#2D5A3D]/25 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2 font-bold text-lg">
                    <i data-lucide="send" class="w-5 h-5"></i> Gửi Ý Kiến
                </button>
            </form>
        </div>
    </div>
</div>
