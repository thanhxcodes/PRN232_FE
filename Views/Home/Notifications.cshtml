@{
    ViewData["Title"] = "Thông Báo";
    Layout = "_Layout";
}

<div class="max-w-4xl mx-auto py-8 px-4">
    <div class="flex items-center gap-4 mb-6">
        <button onclick="history.back()" class="w-10 h-10 rounded-full hover:bg-gray-100 flex items-center justify-center transition-colors">
            <i data-lucide="arrow-left" class="w-5 h-5 text-gray-600"></i>
        </button>
        <div>
            <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                <i data-lucide="bell" class="w-6 h-6 text-[#2D5A3D]"></i>
                Tất Cả Thông Báo
            </h1>
            <p class="text-sm text-gray-500 mt-1" id="notifications-subtitle">Đang tải...</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="border-b border-gray-200 mb-6 sticky top-20 bg-[#F4F4F4] z-10 pt-2 pb-0">
        <!-- Overflow scroll container for filters -->
        <div class="flex overflow-x-auto hide-scrollbar pb-2" id="notif-filters">
            <!-- JS will render filters here -->
        </div>
    </div>

    <!-- Notifications List -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-2 sm:p-4 min-h-[400px]">
        <div id="notif-page-list" class="space-y-2">
            <div class="py-8 text-center text-gray-500">
                <i data-lucide="loader" class="w-8 h-8 animate-spin mx-auto mb-2 text-gray-300"></i>
                <p>Đang tải thông báo...</p>
            </div>
        </div>
        
        <div id="notif-empty" class="hidden py-16 text-center">
            <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
                <i data-lucide="bell-off" class="w-10 h-10 text-gray-300"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-1">Không có thông báo</h3>
            <p class="text-gray-500 text-sm">Bạn chưa có thông báo nào trong mục này.</p>
        </div>
    </div>
</div>
