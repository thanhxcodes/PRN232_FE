@{
    ViewData["Title"] = "Trang Chủ";
    
    // Fallback images for dynamic categories if CategoryDto doesn't have an Image property
    var categoryImages = new Dictionary<string, string> {
        { "Quần Áo", "https://images.unsplash.com/photo-1495121605193-b116b5b9c5fe?w=400" },
        { "Giày Dép", "https://images.unsplash.com/photo-1560769629-975ec94e6a86?w=400" },
        { "Túi Xách", "https://images.unsplash.com/photo-1705909237050-7a7625b47fac?w=400" },
        { "Phụ Kiện", "https://images.unsplash.com/photo-1606760227091-3dd870d97f1d?w=400" },
        { "Đồng Hồ", "https://images.unsplash.com/photo-1524592094714-0f0654e20314?w=400" },
        { "Kính Mắt", "https://images.unsplash.com/photo-1577803645773-f96470509666?w=400" }
    };

    var defaultImage = "https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?w=400";
    var categories = ViewBag.Categories as List<REVORA_MVC_FE.Models.CategoryDto> ?? new List<REVORA_MVC_FE.Models.CategoryDto>();
}

<div class="min-h-screen bg-[#fafaf7]">
    
    <!-- Banner Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 mb-8">
        @await Html.PartialAsync("_BannerCarousel", (List<REVORA_MVC_FE.Models.ProductResponseDto>)ViewBag.FeaturedProducts)
    </section>

    <!-- Categories Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12">
        <div class="bg-white rounded-3xl shadow-lg p-8">
            <div class="grid grid-cols-3 md:grid-cols-6 gap-6">
                @if (categories.Any())
                {
                    @foreach (var cat in categories.Take(6))
                    {
                        var imageUrl = categoryImages.ContainsKey(cat.Name) ? categoryImages[cat.Name] : defaultImage;
                        <a href="/Products?categoryId=@cat.CategoryId" class="flex flex-col items-center space-y-3 group">
                            <div class="w-20 h-20 rounded-2xl overflow-hidden shadow-md group-hover:shadow-xl transition-all group-hover:scale-105 bg-gray-100 flex items-center justify-center">
                                <img src="@imageUrl" alt="@cat.Name" class="w-full h-full object-cover" />
                            </div>
                            <span class="text-sm text-gray-700 font-medium group-hover:text-[#2D5A3D] transition-colors text-center line-clamp-1">@cat.Name</span>
                        </a>
                    }
                }
                else
                {
                    <div class="col-span-full text-center text-gray-500 py-4">Chưa có danh mục nào</div>
                }
            </div>
        </div>
    </section>

    <!-- Featured Products Section -->
    @await Html.PartialAsync("_ProductSection", new { 
        Title = "Sản Phẩm Nổi Bật", 
        Subtitle = "Các sản phẩm được ưu tiên hiển thị", 
        Icon = "sparkles", 
        IconGradient = "from-[#2D5A3D] to-[#3D7054]", 
        BtnClass = "bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white", 
        SortQuery = "featured", 
        Products = ViewBag.FeaturedProducts 
    })

    <!-- Best Sellers Section -->
    @await Html.PartialAsync("_ProductSection", new { 
        Title = "Được Yêu Thích Nhất", 
        Subtitle = "Top sản phẩm được quan tâm nhiều nhất", 
        Icon = "trending-up", 
        IconGradient = "from-orange-500 to-red-500", 
        BtnClass = "bg-white text-orange-600 border-2 border-orange-500", 
        SortQuery = "loved", 
        Products = ViewBag.LovedProducts 
    })
    
    <!-- Most Viewed Products Section -->
    @await Html.PartialAsync("_ProductSection", new { 
        Title = "Được Xem Nhiều Nhất", 
        Subtitle = "Sản phẩm có lượt xem cao nhất", 
        Icon = "eye", 
        IconGradient = "from-green-500 to-teal-500", 
        BtnClass = "bg-white text-green-600 border-2 border-green-500", 
        SortQuery = "most-viewed", 
        Products = ViewBag.MostViewedProducts 
    })

    <!-- Newest Products Section -->
    @await Html.PartialAsync("_ProductSection", new { 
        Title = "Mới Nhất", 
        Subtitle = "Sản phẩm vừa được đăng lên", 
        Icon = "clock", 
        IconGradient = "from-blue-500 to-purple-500", 
        BtnClass = "bg-white text-blue-600 border-2 border-blue-500", 
        SortQuery = "newest", 
        Products = ViewBag.NewestProducts 
    })

    <!-- Premium CTA Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
        <div class="bg-gradient-to-r from-[#2D5A3D] via-[#3D7054] to-[#2D5A3D] rounded-3xl p-12 text-center text-white relative overflow-hidden">
            <div class="absolute inset-0 bg-black/10"></div>
            <div class="relative z-10">
                <i data-lucide="sparkles" class="w-16 h-16 mx-auto mb-6 text-[#C4603A] animate-pulse"></i>
                <h2 class="text-4xl md:text-5xl mb-4 font-bold">Nâng Cấp Tài Khoản Premium</h2>
                <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
                    Tăng độ hiển thị, ưu tiên trong tìm kiếm và nhiều tính năng độc quyền dành riêng cho bạn
                </p>
                <a href="/plans" class="inline-block bg-white text-[#2D5A3D] px-10 py-4 rounded-full hover:shadow-2xl hover:scale-105 transition-all font-bold text-lg">
                    Xem Gói Dịch Vụ Ngay
                </a>
            </div>
        </div>
    </section>
</div>
