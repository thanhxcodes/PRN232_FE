@model REVORA_MVC_FE.Models.ViewModels.ProductCreateViewModel

@{
    ViewData["Title"] = "Đăng Sản Phẩm";
    Layout = "_Layout";
    bool isEditMode = ViewBag.EditId != null;
}

<div class="min-h-screen bg-gray-50 relative overflow-hidden">
    <!-- Premium Dark Hero Header -->
    <div class="relative z-10 overflow-hidden pt-12 pb-24" style="background-color: #2D5A3D; background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.08) 2px, transparent 0); background-size: 24px 24px;">
        <div class="absolute inset-0 pointer-events-none">
            <!-- Background Icons -->
            <i data-lucide="sparkles" class="absolute top-10 left-[20%] w-6 h-6 text-emerald-300/40 animate-pulse"></i>
            <i data-lucide="sparkles" class="absolute bottom-10 left-[30%] w-8 h-8 text-emerald-400/30 animate-pulse delay-700"></i>
            <i data-lucide="shirt" class="absolute top-20 left-[15%] w-32 h-32 text-white/5 -rotate-12"></i>
            <i data-lucide="shopping-bag" class="absolute top-16 right-[15%] w-32 h-32 text-amber-500/5 rotate-12"></i>
        </div>
        <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center relative">
                <h1 class="text-4xl md:text-[52px] font-black text-white mb-4 tracking-tight">
                    @(isEditMode ? "Chỉnh Sửa" : "Đăng Sản Phẩm") 
                    <span class="italic" style="background: linear-gradient(90deg, #4ade80, #86efac); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        Thời Trang
                    </span>
                </h1>
                <p class="text-gray-400 text-base max-w-xl mx-auto">
                    @(isEditMode ? "Chỉnh sửa thông tin sản phẩm của bạn" : "Điền thông tin và chọn tính năng nâng cao để tối đa hóa lượt tiếp cận")
                </p>
            </div>
        </div>
    </div>

    <div class="relative z-20 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 pb-20">
        <form asp-action="@(isEditMode ? "Edit" : "Create")" asp-route-id="@(isEditMode ? ViewBag.EditId : null)" method="post" enctype="multipart/form-data" id="createProductForm">
        <div id="existingFilesContainer"></div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-4">
                        <div asp-validation-summary="All" class="font-medium text-sm"></div>
                    </div>
                }

                <!-- Global Error Summary cho JS -->
                <div id="jsGlobalErrorSummary" class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-4 hidden">
                    <div class="font-semibold text-sm mb-1 flex items-center gap-2">
                        <i data-lucide="alert-circle" class="w-4 h-4"></i> Vui lòng sửa các lỗi sau trước khi đăng:
                    </div>
                    <ul id="jsErrorList" class="list-disc pl-5 text-sm font-medium space-y-1"></ul>
                </div>

                <partial name="Partials/_ProductBasicInfo" model="@Model" />
                <partial name="Partials/_ProductMediaUpload" model="@Model" />
                <partial name="Partials/_ProductPremiumFeatures" model="@Model" />
            </div>

            <!-- SIDEBAR TÍNH TOÁN CREDIT BÊN PHẢI -->
            <div class="lg:col-span-1 space-y-6">
                <partial name="Partials/_ProductSidebar" model="@Model" />
            </div>
        </div>
        </form>

        <partial name="Partials/_ProductRulesModal" />
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/product-create.js" asp-append-version="true"></script>
    <script>
        window.EDIT_PRODUCT_ID = @(ViewBag.EditId ?? "null");
        window.TOTAL_POSTING_CREDITS = @(ViewBag.PostingCredits ?? 0);
        window.TOTAL_FEATURED_CREDITS = @(ViewBag.FeaturedCredits ?? 0);
        
        document.addEventListener('DOMContentLoaded', function () {
            const formManager = new ProductCreateFormManager();
            formManager.init();
        });
    </script>
}
