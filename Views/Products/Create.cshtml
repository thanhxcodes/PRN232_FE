@model REVORA_MVC_FE.Models.ViewModels.ProductCreateViewModel

@{
    ViewData["Title"] = "Đăng Sản Phẩm";
    Layout = "_Layout";
    var categories = ViewBag.Categories as List<REVORA_MVC_FE.Models.CategoryDto> ?? new List<REVORA_MVC_FE.Models.CategoryDto>();
}

<div class="min-h-screen bg-gray-50 relative overflow-hidden">
    <!-- Premium Dark Hero Header -->
    <div class="relative z-10 overflow-hidden pt-12 pb-24" style="background-color: #2D5A3D; background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.08) 2px, transparent 0); background-size: 24px 24px;">
        <div class="absolute inset-0 pointer-events-none">
            <!-- Background Icons -->
            <i data-lucide="sparkles" class="absolute top-10 left-[20%] w-6 h-6 text-emerald-300/40 animate-pulse"></i>
            <i data-lucide="sparkles" class="absolute bottom-10 left-[30%] w-8 h-8 text-emerald-400/30 animate-pulse delay-700"></i>
            <i data-lucide="shirt" class="absolute top-20 left-[15%] w-32 h-32 text-white/5 -rotate-12"></i>
            <i data-lucide="shopping-bag" class="absolute top-16 right-[15%] w-32 h-32 text-amber-500/5 rotate-12"></i>
        </div>
        <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center relative">
                <h1 class="text-4xl md:text-[52px] font-black text-white mb-4 tracking-tight">
                    Đăng Sản Phẩm 
                    <span class="italic" style="background: linear-gradient(90deg, #4ade80, #86efac); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        Thời Trang
                    </span>
                </h1>
                <p class="text-gray-400 text-base max-w-xl mx-auto">
                    Điền thông tin và chọn tính năng nâng cao để tối đa hóa lượt tiếp cận
                </p>
            </div>
        </div>
    </div>

    <div class="relative z-20 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-16 pb-20">
        <form asp-action="Create" method="post" enctype="multipart/form-data" id="createProductForm">

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-xl mb-4">
                        <div asp-validation-summary="All" class="font-medium text-sm"></div>
                    </div>
                }

                <!-- THÔNG TIN SẢN PHẨM -->
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8 relative">
                    <h2 class="text-xl text-gray-900 mb-6 font-semibold">Thông Tin Sản Phẩm</h2>
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm mb-2 text-gray-700 font-medium">Tên Sản Phẩm *</label>
                            <input asp-for="Title" placeholder="Ví dụ: Áo Khoác Da Vintage" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-colors" />
                            <span asp-validation-for="Title" class="text-red-500 text-sm mt-1 block"></span>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm mb-2 text-gray-700 font-medium">Danh Mục *</label>
                                <select asp-for="CategoryId" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-colors bg-white">
                                    <option value="0">Chọn danh mục</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.CategoryId">@cat.Name</option>
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-red-500 text-sm mt-1 block"></span>
                            </div>
                            <div>
                                <label class="block text-sm mb-2 text-gray-700 font-medium">Tình Trạng *</label>
                                <select asp-for="Condition" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-colors bg-white">
                                    <option value="">Chọn tình trạng</option>
                                    <option value="100%">100%</option>
                                    <option value="80%">80%</option>
                                    <option value="60%">60%</option>
                                    <option value="40%">40%</option>
                                    <option value="20%">20%</option>
                                </select>
                                <span asp-validation-for="Condition" class="text-red-500 text-sm mt-1 block"></span>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm mb-2 text-gray-700 font-medium">Giá (VNĐ) *</label>
                                <input type="hidden" asp-for="Price" id="realPrice" />
                                <input type="text" id="displayPrice" placeholder="0" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-colors font-semibold text-gray-900" />
                                <p id="priceText" class="text-sm text-[#C4603A] mt-2 font-medium italic hidden"></p>
                                <span asp-validation-for="Price" class="text-red-500 text-sm mt-1 block"></span>
                            </div>
                            <div>
                                <label class="block text-sm mb-2 text-gray-700 font-medium">Thương Hiệu</label>
                                <input asp-for="Brand" placeholder="Ví dụ: Gucci, Chanel" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-colors" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm mb-2 text-gray-700 font-medium">Mô Tả *</label>
                            <textarea asp-for="Description" rows="5" placeholder="Mô tả chi tiết sản phẩm của bạn..." class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-colors resize-none"></textarea>
                            <span asp-validation-for="Description" class="text-red-500 text-sm mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <!-- HÌNH ẢNH SẢN PHẨM -->
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-xl text-gray-900 font-semibold">Hình Ảnh Sản Phẩm *</h2>
                        <span id="imageCounter" class="text-sm font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-full">0/5 ảnh</span>
                    </div>

                    <div id="imageUploadArea" class="border-2 border-dashed border-gray-200 rounded-2xl p-10 text-center hover:border-[#2D5A3D] hover:bg-[#2D5A3D]/5 transition-all cursor-pointer relative group mb-6">
                        <input type="file" id="Images" name="Images" multiple accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                        <i data-lucide="image" class="w-12 h-12 text-gray-400 group-hover:text-[#2D5A3D] mx-auto mb-3 transition-colors"></i>
                        <p class="text-gray-700 mb-1 font-medium">Nhấp hoặc kéo thả để tải ảnh lên</p>
                        <p class="text-xs text-gray-400">Bạn có thể chọn tối đa 5 ảnh cùng lúc</p>
                    </div>

                    <div id="imagePreviewContainer" class="grid grid-cols-3 sm:grid-cols-5 gap-4 hidden">
                        <!-- Image Previews will be injected here by JS -->
                    </div>
                </div>

                <!-- VIDEO SHORTS PREMIUM -->
                <div id="videoContainer" class="bg-white rounded-3xl shadow-sm p-8 border-2 transition-all border-gray-100">
                    <div class="flex items-start justify-between mb-6">
                        <div class="flex items-center gap-4">
                            <div id="videoIconWrapper" class="w-12 h-12 rounded-xl flex items-center justify-center transition-colors bg-gray-100 text-gray-400">
                                <i data-lucide="video" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-semibold text-gray-900">Tính năng Video Shorts</h2>
                                <p class="text-sm text-gray-500">Người dùng sẽ xem review ngay trên bảng feed</p>
                            </div>
                        </div>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900">Dùng 1 Nổi Bật</span>
                            <input asp-for="EnableVideoUpload" id="enableVideoUpload" class="w-5 h-5 accent-[#2D5A3D] rounded border-gray-300 cursor-pointer" />
                        </label>
                    </div>

                    <div id="videoUploadSection" class="hidden">
                        <div id="videoUploadArea" class="border-2 border-dashed border-[#2D5A3D]/30 rounded-2xl p-8 text-center relative bg-white hover:border-[#2D5A3D] transition-colors">
                            <input type="file" asp-for="VideoFile" id="VideoFile" accept="video/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                            <i data-lucide="upload" class="w-8 h-8 text-[#2D5A3D] mx-auto mb-3"></i>
                            <p class="text-gray-700 font-medium mb-1">Click tải lên Video (Tối đa 1 phút, 30MB)</p>
                            <p class="text-sm text-gray-400">MP4, MOV, AVI</p>
                        </div>
                        <div id="videoPreviewArea" class="hidden relative group rounded-xl overflow-hidden border border-[#2D5A3D]/20 shadow-sm aspect-video bg-black flex items-center justify-center">
                            <video id="videoPreview" controls class="w-full h-full object-contain"></video>
                            <button type="button" id="removeVideoBtn" class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-red-500 p-2 rounded-full hover:bg-red-50 hover:text-red-600 transition-all shadow-md">
                                <i data-lucide="x" class="w-5 h-5"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- BANNER BOOST PREMIUM -->
                <div id="bannerContainer" class="bg-white rounded-3xl shadow-sm p-8 border-2 transition-all border-gray-100">
                    <div class="flex items-start justify-between mb-6">
                        <div class="flex items-center gap-4">
                            <div id="bannerIconWrapper" class="w-12 h-12 rounded-xl flex items-center justify-center transition-colors bg-gray-100 text-gray-400">
                                <i data-lucide="crown" class="w-6 h-6"></i>
                            </div>
                            <div>
                                <h2 class="text-lg font-semibold text-gray-900">Tính năng Banner VIP</h2>
                                <p class="text-sm text-gray-500">Chiếm trọn sự chú ý trong 24 giờ đầu</p>
                            </div>
                        </div>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900">Dùng 1 Nổi Bật</span>
                            <input asp-for="EnableBannerBoost" id="enableBannerBoost" class="w-5 h-5 accent-orange-500 rounded border-gray-300 cursor-pointer" />
                        </label>
                    </div>

                    <div id="bannerUploadSection" class="space-y-4 hidden">
                        <div id="bannerUploadArea" class="border-2 border-dashed border-orange-200 rounded-2xl p-8 text-center relative bg-white hover:border-orange-400 transition-colors">
                            <input type="file" asp-for="BannerFile" id="BannerFile" accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                            <i data-lucide="upload" class="w-8 h-8 text-orange-500 mx-auto mb-3"></i>
                            <p class="text-gray-700 font-medium mb-1">Tải ảnh Banner nằm ngang (Tỷ lệ 3:1)</p>
                            <p class="text-sm text-gray-400">Được dùng làm ảnh bìa cỡ lớn trên App</p>
                        </div>
                        <div id="bannerPreviewArea" class="hidden relative group rounded-xl overflow-hidden border border-orange-100 shadow-sm">
                            <img id="bannerPreview" alt="Banner" class="w-full aspect-[3/1] object-cover" />
                            <button type="button" id="removeBannerBtn" class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm text-red-500 p-2 rounded-full hover:bg-red-50 transition-all shadow-sm">
                                <i data-lucide="x" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </div>
                </div>

            </div>

            <!-- SIDEBAR TÍNH TOÁN CREDIT BÊN PHẢI -->
            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-24">
                    <h3 class="text-lg font-bold text-gray-900 mb-6">Credits Của Bạn</h3>

                    <div class="space-y-4 mb-8">
                        <!-- Posting Credits -->
                        <div class="relative">
                            <div class="flex items-center justify-between bg-blue-50 border-blue-200 border-2 rounded-xl px-4 py-3 relative group">
                                <div class="flex items-center gap-3">
                                    <i data-lucide="image" class="w-6 h-6 text-blue-600"></i>
                                    <div>
                                        <div class="text-sm text-gray-600">Đăng Tin</div>
                                        <div id="txtPostingCredits" class="text-2xl font-bold text-blue-600">@(ViewBag.PostingCredits ?? 0)</div>
                                    </div>
                                </div>
                                <div class="relative">
                                    <i data-lucide="info" class="w-5 h-5 text-blue-600 cursor-help"></i>
                                    
                                    <!-- Tooltip -->
                                    <div class="absolute right-0 top-8 w-64 bg-white rounded-xl shadow-xl border-2 border-gray-200 p-4 z-50 hidden group-hover:block transition-all">
                                        <div class="text-sm font-medium text-gray-900 mb-3">Chi Tiết Credits</div>
                                        <div class="space-y-2 max-h-60 overflow-y-auto">
                                            @if (ViewBag.PostingBatches != null)
                                            {
                                                foreach (var batch in ViewBag.PostingBatches)
                                                {
                                                    <div class="flex justify-between items-start text-xs border-b border-gray-100 pb-2 last:border-0">
                                                        <div>
                                                            <div class="font-bold text-blue-600">@batch.RemainingCredits credits</div>
                                                            @if(!string.IsNullOrEmpty(batch.PackageName)) { <div class="text-gray-500">@batch.PackageName</div> }
                                                        </div>
                                                        <div class="text-right">
                                                            <div class="text-gray-600">HSD: @(string.IsNullOrEmpty(batch.ExpiresAt) ? "Vĩnh viễn" : DateTime.Parse(batch.ExpiresAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Featured Credits -->
                        <div class="relative">
                            <div class="flex items-center justify-between bg-orange-50 border-orange-200 border-2 rounded-xl px-4 py-3 relative group">
                                <div class="flex items-center gap-3">
                                    <i data-lucide="sparkles" class="w-6 h-6 text-orange-600"></i>
                                    <div>
                                        <div class="text-sm text-gray-600">Nổi Bật</div>
                                        <div id="txtFeaturedCredits" class="text-2xl font-bold text-orange-600">@(ViewBag.FeaturedCredits ?? 0)</div>
                                    </div>
                                </div>
                                <div class="relative">
                                    <i data-lucide="info" class="w-5 h-5 text-orange-600 cursor-help"></i>
                                    
                                    <!-- Tooltip -->
                                    <div class="absolute right-0 top-8 w-64 bg-white rounded-xl shadow-xl border-2 border-gray-200 p-4 z-50 hidden group-hover:block transition-all">
                                        <div class="text-sm font-medium text-gray-900 mb-3">Chi Tiết Credits</div>
                                        <div class="space-y-2 max-h-60 overflow-y-auto">
                                            @if (ViewBag.FeaturedBatches != null)
                                            {
                                                foreach (var batch in ViewBag.FeaturedBatches)
                                                {
                                                    <div class="flex justify-between items-start text-xs border-b border-gray-100 pb-2 last:border-0">
                                                        <div>
                                                            <div class="font-bold text-orange-600">@batch.RemainingCredits credits</div>
                                                            @if(!string.IsNullOrEmpty(batch.PackageName)) { <div class="text-gray-500">@batch.PackageName</div> }
                                                        </div>
                                                        <div class="text-right">
                                                            <div class="text-gray-600">HSD: @(string.IsNullOrEmpty(batch.ExpiresAt) ? "Vĩnh viễn" : DateTime.Parse(batch.ExpiresAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="border-t border-gray-100 pt-6">
                        <h4 class="text-sm font-semibold text-gray-900 mb-4">Chi Phí Dự Kiến:</h4>
                        <div class="space-y-3">
                            <div class="flex justify-between items-center text-sm">
                                <span class="text-gray-600">Phí lên sàn</span>
                                <span class="font-bold text-blue-600">-1</span>
                            </div>
                            <div id="costVideo" class="flex justify-between items-center text-sm hidden">
                                <span class="text-gray-600">Tích hợp Video Shorts</span>
                                <span class="font-bold text-orange-600">-1</span>
                            </div>
                            <div id="costBanner" class="flex justify-between items-center text-sm hidden">
                                <span class="text-gray-600">Banner VIP</span>
                                <span class="font-bold text-orange-600">-1</span>
                            </div>

                            <div class="border-t border-dashed border-gray-200 pt-3 mt-4">
                                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Số dư khả dụng sau khi đăng:</div>
                                <div class="flex justify-between text-sm mb-2">
                                    <span class="text-gray-600">Đăng tin:</span>
                                    <span id="remainPosting" class="font-bold text-blue-600">@(ViewBag.PostingCredits ?? 0)</span>
                                </div>
                                <div class="flex justify-between text-sm mb-4">
                                    <span class="text-gray-600">Nổi bật:</span>
                                    <span id="remainFeatured" class="font-bold text-orange-600">@(ViewBag.FeaturedCredits ?? 0)</span>
                                </div>
                                <div class="flex justify-between text-sm bg-green-50 p-2.5 rounded-xl border border-green-100">
                                    <span class="text-green-700 font-medium">Tin tồn tại đến:</span>
                                    <span id="txtExpireDate" class="font-bold text-green-700"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-6 flex items-start gap-3">
                        <input type="checkbox" id="acceptRules" class="mt-1 w-5 h-5 accent-[#2D5A3D] rounded border-gray-300 cursor-pointer" />
                        <label for="acceptRules" class="text-sm text-gray-600 cursor-pointer select-none">
                            Tôi đã đọc và đồng ý với <span id="openRulesModal" class="text-[#2D5A3D] font-semibold hover:underline">Quy định đăng tin</span>
                        </label>
                    </div>

                    <button type="submit" id="submitBtn" disabled class="w-full mt-5 bg-[#2D5A3D] text-white py-4 rounded-2xl font-semibold text-sm hover:bg-[#234830] hover:shadow-lg hover:-translate-y-0.5 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:transform-none disabled:hover:shadow-none flex items-center justify-center gap-2">
                        Đăng Sản Phẩm
                    </button>
                </div>
            </div>
        </div>
    </form>

    <!-- Rules Modal -->
    <div id="rulesModal" class="fixed inset-0 z-50 flex items-center justify-center px-4 bg-black/50 backdrop-blur-sm hidden">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
            <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-[#2D5A3D]/10 flex items-center justify-center text-[#2D5A3D]">
                        <i data-lucide="file-text" class="w-5 h-5"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900">Quy định đăng tin</h3>
                </div>
                <button type="button" id="closeRulesModal" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-gray-500 hover:bg-gray-200 hover:text-gray-900 transition-colors">
                    <i data-lucide="x" class="w-4 h-4"></i>
                </button>
            </div>
            <div class="p-6 overflow-y-auto">
                <div class="space-y-5 text-sm text-gray-600">
                    <div class="flex gap-3">
                        <div class="mt-0.5 w-1.5 h-1.5 rounded-full bg-[#2D5A3D] shrink-0"></div>
                        <p><strong class="text-gray-900">Thời gian chỉnh sửa:</strong> 30 phút sau khi đăng tin, bạn được phép sửa tất cả thông tin. Sau 30 phút, bạn sẽ không thể thay đổi <strong class="text-gray-900">Tên sản phẩm</strong> và <strong class="text-gray-900">Danh mục</strong>.</p>
                    </div>
                    <div class="flex gap-3">
                        <div class="mt-0.5 w-1.5 h-1.5 rounded-full bg-[#2D5A3D] shrink-0"></div>
                        <p><strong class="text-gray-900">Sản phẩm Cơ bản (1 Credit Đăng tin):</strong> Mặc định hiển thị liên tục trên hệ thống trong vòng 30 ngày.</p>
                    </div>
                    <div class="flex gap-3">
                        <div class="mt-0.5 w-1.5 h-1.5 rounded-full bg-[#2D5A3D] shrink-0"></div>
                        <p><strong class="text-gray-900">Sản phẩm Nổi bật (Sử dụng Credit Nổi bật):</strong> Sản phẩm của bạn sẽ được ưu tiên hiển thị trong 60 ngày, có viền nổi bật bắt mắt, và cơ hội xuất hiện trên Bảng Xếp Hạng (BXH) Tuần.</p>
                    </div>
                    <p class="pt-2 text-xs italic text-gray-500 text-center border-t border-gray-100">Việc tuân thủ quy định giúp tạo ra môi trường giao dịch minh bạch và an toàn cho mọi người.</p>
                </div>
            </div>
            <div class="p-6 pt-4 bg-gray-50 border-t border-gray-100">
                <button type="button" id="acceptRulesBtn" class="w-full bg-[#2D5A3D] text-white py-3 rounded-xl font-semibold hover:bg-[#234830] transition-colors">
                    Đã hiểu & Đồng ý
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (window.jQuery && window.jQuery.validator) {
                window.jQuery.validator.setDefaults({ ignore: "" });
            }
            // --- BỘ CÔNG CỤ ĐỌC SỐ TIỀN TIẾNG VIỆT ---
            const DOCSO = {
                chuSo: ["không", "một", "hai", "ba", "bốn", "năm", "sáu", "bảy", "tám", "chín"],
                tien: ["", "nghìn", "triệu", "tỷ", "nghìn tỷ", "triệu tỷ"],
                doc3so: function (so) {
                    let tram = Math.floor(so / 100);
                    let chuc = Math.floor((so % 100) / 10);
                    let donVi = so % 10;
                    let ketQua = "";

                    if (tram === 0 && chuc === 0 && donVi === 0) return "";
                    if (tram !== 0) {
                        ketQua += this.chuSo[tram] + " trăm ";
                        if (chuc === 0 && donVi !== 0) ketQua += "linh ";
                    }
                    if (chuc !== 0 && chuc !== 1) {
                        ketQua += this.chuSo[chuc] + " mươi ";
                        if (chuc === 0 && donVi !== 0) ketQua += "linh ";
                    }
                    if (chuc === 1) ketQua += "mười ";
                    switch (donVi) {
                        case 1:
                            if (chuc > 1) ketQua += "mốt ";
                            else ketQua += this.chuSo[donVi] + " ";
                            break;
                        case 5:
                            if (chuc === 0) ketQua += this.chuSo[donVi] + " ";
                            else ketQua += "lăm ";
                            break;
                        default:
                            if (donVi !== 0) ketQua += this.chuSo[donVi] + " ";
                            break;
                    }
                    return ketQua;
                },
                doc: function (so) {
                    if (so === 0) return "Không đồng";
                    if (so < 0) return "Số âm";
                    let lan = 0;
                    let i = 0;
                    let ketQua = "";
                    let viTri = [];

                    while (so > 0) {
                        viTri[lan] = so % 1000;
                        so = Math.floor(so / 1000);
                        lan++;
                    }
                    for (i = lan - 1; i >= 0; i--) {
                        if (viTri[i] !== 0) {
                            ketQua += this.doc3so(viTri[i]) + this.tien[i] + " ";
                        }
                    }
                    return ketQua.replace(/\s+/g, ' ').trim();
                }
            };

            // 1. FORMAT PRICE
            const realPrice = document.getElementById('realPrice');
            const displayPrice = document.getElementById('displayPrice');
            const priceText = document.getElementById('priceText');

            // Initialize if there is existing value
            if (realPrice.value && realPrice.value !== '0') {
                const val = parseInt(realPrice.value);
                displayPrice.value = new Intl.NumberFormat('en-US').format(val);
                updatePriceText(val);
            }

            displayPrice.addEventListener('input', function (e) {
                let value = e.target.value.replace(/[^0-9]/g, '');
                if (value.length > 15) value = value.substring(0, 15);

                if (!value) {
                    displayPrice.value = '';
                    realPrice.value = '0';
                    priceText.textContent = '';
                    priceText.classList.add('hidden');
                    return;
                }

                const numericValue = parseInt(value, 10);
                displayPrice.value = new Intl.NumberFormat('en-US').format(numericValue);
                realPrice.value = numericValue;
                updatePriceText(numericValue);
                if (window.jQuery && window.jQuery(realPrice).valid) {
                    window.jQuery(realPrice).valid();
                }
            });

            function updatePriceText(numericValue) {
                if (!isNaN(numericValue) && numericValue > 0) {
                    let text = DOCSO.doc(numericValue);
                    if (text) {
                        text = text.charAt(0).toUpperCase() + text.slice(1);
                        priceText.textContent = text + ' đồng';
                        priceText.classList.remove('hidden');
                    }
                } else {
                    priceText.classList.add('hidden');
                }
            }

            // 2. IMAGE UPLOAD PREVIEW USING DATATRANSFER
            const imagesInput = document.getElementById('Images');
            const imagePreviewContainer = document.getElementById('imagePreviewContainer');
            const imageCounter = document.getElementById('imageCounter');
            const imageUploadArea = document.getElementById('imageUploadArea');
            let dataTransfer = new DataTransfer();

            imagesInput.addEventListener('change', function (e) {
                const files = e.target.files;
                if (!files || files.length === 0) return;

                if (dataTransfer.items.length + files.length > 5) {
                    Swal.fire({ icon: 'warning', title: 'Giới hạn ảnh', text: `Tối đa 5 ảnh. Đang có sẵn ${dataTransfer.items.length} ảnh.` });
                    imagesInput.value = '';
                    return;
                }

                for (let i = 0; i < files.length; i++) {
                    dataTransfer.items.add(files[i]);
                }
                
                imagesInput.files = dataTransfer.files;
                renderImagePreviews();
            });

            function renderImagePreviews() {
                imagePreviewContainer.innerHTML = '';
                const files = dataTransfer.files;

                if (files.length > 0) {
                    imagePreviewContainer.classList.remove('hidden');
                    imageCounter.textContent = `${files.length}/5 ảnh`;
                } else {
                    imagePreviewContainer.classList.add('hidden');
                    imageCounter.textContent = `0/5 ảnh`;
                }

                if (files.length >= 5) {
                    imageUploadArea.classList.add('hidden');
                } else {
                    imageUploadArea.classList.remove('hidden');
                }

                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    const objectUrl = URL.createObjectURL(file);

                    const div = document.createElement('div');
                    div.className = 'relative group rounded-xl overflow-hidden shadow-sm border border-gray-100 aspect-square';
                    
                    const img = document.createElement('img');
                    img.src = objectUrl;
                    img.className = 'w-full h-full object-cover';
                    
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = 'absolute top-1.5 right-1.5 bg-white/90 backdrop-blur-sm text-red-500 p-1.5 rounded-full opacity-0 group-hover:opacity-100 hover:bg-red-50 hover:text-red-600 transition-all shadow-sm';
                    btn.innerHTML = '<i data-lucide="x" class="w-3.5 h-3.5"></i>';
                    
                    btn.onclick = function() {
                        const newDataTransfer = new DataTransfer();
                        for (let j = 0; j < dataTransfer.files.length; j++) {
                            if (j !== i) {
                                newDataTransfer.items.add(dataTransfer.files[j]);
                            }
                        }
                        dataTransfer = newDataTransfer;
                        imagesInput.files = dataTransfer.files;
                        renderImagePreviews();
                    };

                    div.appendChild(img);
                    div.appendChild(btn);
                    imagePreviewContainer.appendChild(div);
                }
                lucide.createIcons();
            }

            // 3. VIDEO TOGGLE & PREVIEW
            const enableVideoUpload = document.getElementById('enableVideoUpload');
            const videoContainer = document.getElementById('videoContainer');
            const videoIconWrapper = document.getElementById('videoIconWrapper');
            const videoUploadSection = document.getElementById('videoUploadSection');
            const videoInput = document.getElementById('VideoFile');
            const videoPreviewArea = document.getElementById('videoPreviewArea');
            const videoUploadArea = document.getElementById('videoUploadArea');
            const videoPreview = document.getElementById('videoPreview');
            const removeVideoBtn = document.getElementById('removeVideoBtn');

            enableVideoUpload.addEventListener('change', function() {
                updateCredits();
                if (this.checked) {
                    videoContainer.classList.add('border-[#2D5A3D]', 'bg-[#2D5A3D]/[0.02]');
                    videoContainer.classList.remove('border-gray-100');
                    videoIconWrapper.classList.add('bg-[#2D5A3D]', 'text-white');
                    videoIconWrapper.classList.remove('bg-gray-100', 'text-gray-400');
                    videoUploadSection.classList.remove('hidden');
                } else {
                    videoContainer.classList.remove('border-[#2D5A3D]', 'bg-[#2D5A3D]/[0.02]');
                    videoContainer.classList.add('border-gray-100');
                    videoIconWrapper.classList.remove('bg-[#2D5A3D]', 'text-white');
                    videoIconWrapper.classList.add('bg-gray-100', 'text-gray-400');
                    videoUploadSection.classList.add('hidden');
                    // Reset
                    videoInput.value = '';
                    videoPreview.src = '';
                    videoPreviewArea.classList.add('hidden');
                    videoUploadArea.classList.remove('hidden');
                }
            });

            videoInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (!file) return;

                if (file.size > 30 * 1024 * 1024) {
                    Swal.fire({ icon: 'warning', title: 'File quá lớn', text: 'Dung lượng video không được vượt quá 30MB.' });
                    videoInput.value = '';
                    return;
                }

                const videoElement = document.createElement('video');
                videoElement.preload = 'metadata';
                videoElement.onloadedmetadata = function() {
                    window.URL.revokeObjectURL(videoElement.src);
                    if (videoElement.duration > 61) {
                        Swal.fire({ icon: 'warning', title: 'Video quá dài', text: 'Video của bạn không được dài quá 1 phút (60 giây).' });
                        videoInput.value = '';
                        return;
                    }
                    
                    videoPreview.src = URL.createObjectURL(file);
                    videoUploadArea.classList.add('hidden');
                    videoPreviewArea.classList.remove('hidden');
                };
                videoElement.src = URL.createObjectURL(file);
            });

            removeVideoBtn.addEventListener('click', function() {
                videoInput.value = '';
                videoPreview.src = '';
                videoPreviewArea.classList.add('hidden');
                videoUploadArea.classList.remove('hidden');
            });

            // 4. BANNER TOGGLE & PREVIEW
            const enableBannerBoost = document.getElementById('enableBannerBoost');
            const bannerContainer = document.getElementById('bannerContainer');
            const bannerIconWrapper = document.getElementById('bannerIconWrapper');
            const bannerUploadSection = document.getElementById('bannerUploadSection');
            const bannerInput = document.getElementById('BannerFile');
            const bannerPreviewArea = document.getElementById('bannerPreviewArea');
            const bannerUploadArea = document.getElementById('bannerUploadArea');
            const bannerPreview = document.getElementById('bannerPreview');
            const removeBannerBtn = document.getElementById('removeBannerBtn');

            enableBannerBoost.addEventListener('change', function() {
                updateCredits();
                if (this.checked) {
                    bannerContainer.classList.add('border-orange-500', 'bg-orange-50/30');
                    bannerContainer.classList.remove('border-gray-100');
                    bannerIconWrapper.classList.add('bg-gradient-to-br', 'from-orange-400', 'to-orange-600', 'text-white');
                    bannerIconWrapper.classList.remove('bg-gray-100', 'text-gray-400');
                    bannerUploadSection.classList.remove('hidden');
                } else {
                    bannerContainer.classList.remove('border-orange-500', 'bg-orange-50/30');
                    bannerContainer.classList.add('border-gray-100');
                    bannerIconWrapper.classList.remove('bg-gradient-to-br', 'from-orange-400', 'to-orange-600', 'text-white');
                    bannerIconWrapper.classList.add('bg-gray-100', 'text-gray-400');
                    bannerUploadSection.classList.add('hidden');
                    // Reset
                    bannerInput.value = '';
                    bannerPreview.src = '';
                    bannerPreviewArea.classList.add('hidden');
                    bannerUploadArea.classList.remove('hidden');
                }
            });

            bannerInput.addEventListener('change', function(e) {
                const file = e.target.files[0];
                if (!file) return;

                bannerPreview.src = URL.createObjectURL(file);
                bannerUploadArea.classList.add('hidden');
                bannerPreviewArea.classList.remove('hidden');
            });

            removeBannerBtn.addEventListener('click', function() {
                bannerInput.value = '';
                bannerPreview.src = '';
                bannerPreviewArea.classList.add('hidden');
                bannerUploadArea.classList.remove('hidden');
            });

            // 5. CREDITS CALCULATION
            const totalPostingCredits = @(ViewBag.PostingCredits ?? 0);
            const totalFeaturedCredits = @(ViewBag.FeaturedCredits ?? 0);

            function updateCredits() {
                let usedFeatured = 0;
                if (enableVideoUpload.checked) {
                    document.getElementById('costVideo').classList.remove('hidden');
                    usedFeatured += 1;
                } else {
                    document.getElementById('costVideo').classList.add('hidden');
                }

                if (enableBannerBoost.checked) {
                    document.getElementById('costBanner').classList.remove('hidden');
                    usedFeatured += 1;
                } else {
                    document.getElementById('costBanner').classList.add('hidden');
                }

                document.getElementById('remainPosting').textContent = totalPostingCredits - 1;
                document.getElementById('remainFeatured').textContent = totalFeaturedCredits - usedFeatured;

                const expireDays = usedFeatured > 0 ? 60 : 30;
                const date = new Date();
                date.setDate(date.getDate() + expireDays);
                document.getElementById('txtExpireDate').textContent = date.toLocaleDateString('vi-VN');

                // Disable checkboxes if not enough credits
                if (totalFeaturedCredits - usedFeatured <= 0) {
                    if (!enableVideoUpload.checked) enableVideoUpload.disabled = true;
                    if (!enableBannerBoost.checked) enableBannerBoost.disabled = true;
                } else {
                    enableVideoUpload.disabled = false;
                    enableBannerBoost.disabled = false;
                }
            }
            updateCredits(); // initial call

            // 6. RULES MODAL
            const rulesModal = document.getElementById('rulesModal');
            const openRulesModal = document.getElementById('openRulesModal');
            const closeRulesModal = document.getElementById('closeRulesModal');
            const acceptRulesBtn = document.getElementById('acceptRulesBtn');
            const acceptRulesCheckbox = document.getElementById('acceptRules');
            const submitBtn = document.getElementById('submitBtn');

            openRulesModal.addEventListener('click', function(e) {
                e.preventDefault();
                rulesModal.classList.remove('hidden');
            });

            closeRulesModal.addEventListener('click', function() {
                rulesModal.classList.add('hidden');
            });

            acceptRulesBtn.addEventListener('click', function() {
                acceptRulesCheckbox.checked = true;
                rulesModal.classList.add('hidden');
                checkSubmitStatus();
            });

            acceptRulesCheckbox.addEventListener('change', checkSubmitStatus);

            function checkSubmitStatus() {
                if (acceptRulesCheckbox.checked) {
                    submitBtn.disabled = false;
                } else {
                    submitBtn.disabled = true;
                }
            }
            checkSubmitStatus(); // initial
            
            // 7. FORM SUBMIT VALIDATION FOR IMAGES
            document.getElementById('createProductForm').addEventListener('submit', function(e) {
                if (dataTransfer.items.length === 0) {
                    e.preventDefault();
                    Swal.fire({ icon: 'warning', title: 'Thiếu hình ảnh', text: "Vui lòng tải lên ít nhất 1 hình ảnh." });
                }
            });
        });
    </script>
}
