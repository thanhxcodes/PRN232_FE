@model dynamic

@{
    var sortBy = Model.SortBy;
}

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4 mb-6 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <button type="button" onclick="productListManager.toggleFilters()" class="flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-lg hover:bg-gray-50 hover:border-gray-300 transition-colors text-sm font-medium text-gray-700">
            <i data-lucide="filter" class="w-4 h-4 text-[#2D5A3D]"></i> <span id="filterBtnText">Hiện Bộ Lọc</span>
        </button>
        
        <div class="hidden sm:flex items-center gap-2 border-l border-gray-200 pl-4">
            <button type="button" onclick="productListManager.setViewMode('grid')" id="btnGridMode" class="p-2 rounded-lg transition-colors bg-[#2D5A3D]/10 text-[#2D5A3D]">
                <i data-lucide="grid-3x3" class="w-5 h-5"></i>
            </button>
            <button type="button" onclick="productListManager.setViewMode('list')" id="btnListMode" class="p-2 rounded-lg transition-colors text-gray-400 hover:text-gray-600 hover:bg-gray-50">
                <i data-lucide="list" class="w-5 h-5"></i>
            </button>
        </div>
    </div>

    <div class="flex items-center gap-3">
        <label class="text-sm font-medium text-gray-600 hidden sm:block">Sắp xếp:</label>
        <select name="sortBy" onchange="productListManager.resetPageAndSubmit()" class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] text-sm font-medium text-gray-700 cursor-pointer">
            <!option value="newest" @(sortBy == "newest" ? "selected" : "")>Mới nhất</!option>
            <!option value="featured" @(sortBy == "featured" ? "selected" : "")>Sản phẩm nổi bật</!option>
            <!option value="loved" @(sortBy == "loved" ? "selected" : "")>Được yêu thích nhất</!option>
            <!option value="priceAsc" @(sortBy == "priceAsc" ? "selected" : "")>Giá: Thấp đến Cao</!option>
            <!option value="priceDesc" @(sortBy == "priceDesc" ? "selected" : "")>Giá: Cao đến Thấp</!option>
        </select>
    </div>
</div>
