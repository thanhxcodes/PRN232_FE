@model REVORA_MVC_FE.Models.ViewModels.ProductCreateViewModel

<div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-6 sticky top-24">
    <h3 class="text-lg font-bold text-gray-900 mb-6">Credits Của Bạn</h3>

    <div class="space-y-4 mb-8">
        <!-- Posting Credits -->
        <div class="relative">
            <div class="flex items-center justify-between bg-blue-50 border-blue-200 border-2 rounded-xl px-4 py-3 relative group">
                <div class="flex items-center gap-3">
                    <i data-lucide="image" class="w-6 h-6 text-blue-600"></i>
                    <div>
                        <div class="text-sm text-gray-600">Đăng Tin</div>
                        <div id="txtPostingCredits" class="text-2xl font-bold text-blue-600">@(ViewBag.PostingCredits ?? 0)</div>
                    </div>
                </div>
                <div class="relative">
                    <i data-lucide="info" class="w-5 h-5 text-blue-600 cursor-help"></i>
                    
                    <!-- Tooltip -->
                    <div class="absolute right-0 top-8 w-64 bg-white rounded-xl shadow-xl border-2 border-gray-200 p-4 z-50 hidden group-hover:block transition-all">
                        <div class="text-sm font-medium text-gray-900 mb-3">Chi Tiết Credits</div>
                        <div class="space-y-2 max-h-60 overflow-y-auto">
                            @if (ViewBag.PostingBatches != null)
                            {
                                foreach (var batch in ViewBag.PostingBatches)
                                {
                                    <div class="flex justify-between items-start text-xs border-b border-gray-100 pb-2 last:border-0">
                                        <div>
                                            <div class="font-bold text-blue-600">@batch.RemainingCredits credits</div>
                                            @if(!string.IsNullOrEmpty(batch.PackageName)) { <div class="text-gray-500">@batch.PackageName</div> }
                                        </div>
                                        <div class="text-right">
                                            <div class="text-gray-600">HSD: @(string.IsNullOrEmpty(batch.ExpiresAt) ? "Vĩnh viễn" : DateTime.Parse(batch.ExpiresAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Featured Credits -->
        <div class="relative">
            <div class="flex items-center justify-between bg-orange-50 border-orange-200 border-2 rounded-xl px-4 py-3 relative group">
                <div class="flex items-center gap-3">
                    <i data-lucide="sparkles" class="w-6 h-6 text-orange-600"></i>
                    <div>
                        <div class="text-sm text-gray-600">Nổi Bật</div>
                        <div id="txtFeaturedCredits" class="text-2xl font-bold text-orange-600">@(ViewBag.FeaturedCredits ?? 0)</div>
                    </div>
                </div>
                <div class="relative">
                    <i data-lucide="info" class="w-5 h-5 text-orange-600 cursor-help"></i>
                    
                    <!-- Tooltip -->
                    <div class="absolute right-0 top-8 w-64 bg-white rounded-xl shadow-xl border-2 border-gray-200 p-4 z-50 hidden group-hover:block transition-all">
                        <div class="text-sm font-medium text-gray-900 mb-3">Chi Tiết Credits</div>
                        <div class="space-y-2 max-h-60 overflow-y-auto">
                            @if (ViewBag.FeaturedBatches != null)
                            {
                                foreach (var batch in ViewBag.FeaturedBatches)
                                {
                                    <div class="flex justify-between items-start text-xs border-b border-gray-100 pb-2 last:border-0">
                                        <div>
                                            <div class="font-bold text-orange-600">@batch.RemainingCredits credits</div>
                                            @if(!string.IsNullOrEmpty(batch.PackageName)) { <div class="text-gray-500">@batch.PackageName</div> }
                                        </div>
                                        <div class="text-right">
                                            <div class="text-gray-600">HSD: @(string.IsNullOrEmpty(batch.ExpiresAt) ? "Vĩnh viễn" : DateTime.Parse(batch.ExpiresAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="border-t border-gray-100 pt-6">
        <h4 class="text-sm font-semibold text-gray-900 mb-4">Chi Phí Dự Kiến:</h4>
        <div class="space-y-3">
            <div class="flex justify-between items-center text-sm">
                <span class="text-gray-600">Phí lên sàn</span>
                <span class="font-bold text-blue-600">-1</span>
            </div>
            <div id="costVideo" class="flex justify-between items-center text-sm hidden">
                <span class="text-gray-600">Tích hợp Video Shorts</span>
                <span class="font-bold text-orange-600">-1</span>
            </div>
            <div id="costBanner" class="flex justify-between items-center text-sm hidden">
                <span class="text-gray-600">Banner VIP</span>
                <span class="font-bold text-orange-600">-1</span>
            </div>

            <div class="border-t border-dashed border-gray-200 pt-3 mt-4">
                <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Số dư khả dụng sau khi đăng:</div>
                <div class="flex justify-between text-sm mb-2">
                    <span class="text-gray-600">Đăng tin:</span>
                    <span id="remainPosting" class="font-bold text-blue-600">@(ViewBag.PostingCredits ?? 0)</span>
                </div>
                <div class="flex justify-between text-sm mb-4">
                    <span class="text-gray-600">Nổi bật:</span>
                    <span id="remainFeatured" class="font-bold text-orange-600">@(ViewBag.FeaturedCredits ?? 0)</span>
                </div>
                <div class="flex justify-between text-sm bg-green-50 p-2.5 rounded-xl border border-green-100">
                    <span class="text-green-700 font-medium">Tin tồn tại đến:</span>
                    <span id="txtExpireDate" class="font-bold text-green-700"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-6 flex items-start gap-3">
        <input type="checkbox" id="acceptRules" class="mt-1 w-5 h-5 accent-[#2D5A3D] rounded border-gray-300 cursor-pointer" />
        <label for="acceptRules" class="text-sm text-gray-600 cursor-pointer select-none">
            Tôi đã đọc và đồng ý với <span id="openRulesModal" class="text-[#2D5A3D] font-semibold hover:underline">Quy định đăng tin</span>
        </label>
    </div>

    <div id="formErrorSummary" class="mt-4 p-3 bg-red-50 border border-red-200 rounded-xl hidden">
        <p id="formErrorMessage" class="text-sm font-medium text-red-800"></p>
    </div>

    <div id="noCreditWarning" class="mt-4 p-3 bg-red-50 border border-red-200 rounded-xl flex items-start gap-3 hidden">
        <i data-lucide="alert-triangle" class="w-5 h-5 text-red-500 shrink-0 mt-0.5"></i>
        <div>
            <p class="text-sm font-medium text-red-800">Bạn đã hết Credit đăng tin</p>
            <a href="/Plans" class="text-sm text-red-600 hover:text-red-700 underline font-semibold mt-1 inline-block">Mua thêm gói ngay để tiếp tục</a>
        </div>
    </div>

    <button type="submit" id="submitBtn" disabled class="w-full mt-4 bg-[#2D5A3D] text-white py-4 rounded-2xl font-semibold text-sm hover:bg-[#234830] hover:shadow-lg hover:-translate-y-0.5 transition-all disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:transform-none disabled:hover:shadow-none flex items-center justify-center gap-2">
        Đăng Sản Phẩm
    </button>
</div>
