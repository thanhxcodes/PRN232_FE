@model REVORA_MVC_FE.Models.ViewModels.ProductCreateViewModel

<!-- HÌNH ẢNH SẢN PHẨM -->
<div class="bg-white rounded-3xl shadow-sm border border-gray-100 p-8">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-xl text-gray-900 font-semibold">Hình Ảnh Sản Phẩm *</h2>
        <span id="imageCounter" class="text-sm font-medium text-gray-500 bg-gray-100 px-3 py-1 rounded-full">0/5 ảnh</span>
    </div>

    <div id="imageUploadArea" class="border-2 border-dashed border-gray-200 rounded-2xl p-10 text-center hover:border-[#2D5A3D] hover:bg-[#2D5A3D]/5 transition-all cursor-pointer relative group mb-6">
        <input type="file" id="Images" name="Images" multiple accept="image/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
        <i data-lucide="image" class="w-12 h-12 text-gray-400 group-hover:text-[#2D5A3D] mx-auto mb-3 transition-colors"></i>
        <p class="text-gray-700 mb-1 font-medium">Nhấp hoặc kéo thả để tải ảnh lên</p>
        <p class="text-xs text-gray-400">Bạn có thể chọn tối đa 5 ảnh cùng lúc</p>
    </div>

    <div id="imagePreviewContainer" class="grid grid-cols-3 sm:grid-cols-5 gap-4 hidden">
        <!-- Image Previews will be injected here by JS -->
    </div>
    <span id="imgUploadError" class="text-red-500 text-sm mt-2 hidden block font-medium">Vui lòng tải lên ít nhất 1 hình ảnh sản phẩm.</span>
</div>
