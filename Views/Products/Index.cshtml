@{
    ViewData["Title"] = "Tất Cả Sản Phẩm";
    var searchKeyword = ViewBag.Search as string;
    var totalCount = ViewBag.TotalCount ?? 0;
    
    // Model creation for Partials
    var sidebarModel = new {
        Categories = ViewBag.Categories as List<REVORA_MVC_FE.Models.CategoryDto> ?? new List<REVORA_MVC_FE.Models.CategoryDto>(),
        SelectedCategory = ViewBag.CategoryId,
        Locations = new[] { "Hà Nội", "Hồ Chí Minh", "Đà Nẵng" },
        SelectedLocation = ViewBag.City as string ?? "Tất Cả",
        Brands = new[] { "Gucci", "Chanel", "Apple", "Samsung", "5TheWay", "First News", "Logitech", "No Brand" },
        SelectedBrand = ViewBag.Brand as string ?? "Tất Cả",
        Conditions = new[] { "Mới 100%", "Như Mới", "Tuyệt Vời", "Tốt", "Khá" },
        SelectedCondition = ViewBag.Condition as string ?? "Tất Cả",
        MinPrice = ViewBag.MinPrice ?? 0m,
        MaxPrice = ViewBag.MaxPrice ?? 1000000000m
    };
    
    var toolbarModel = new {
        SortBy = ViewBag.SortBy as string ?? "newest"
    };
    
    var gridModel = new {
        Products = ViewBag.Products as List<REVORA_MVC_FE.Models.ProductResponseDto> ?? new List<REVORA_MVC_FE.Models.ProductResponseDto>()
    };
    
    var paginationModel = new {
        TotalPages = ViewBag.TotalPages ?? 1,
        CurrentPage = ViewBag.CurrentPage ?? 1,
        ProductsCount = gridModel.Products.Count
    };
}

<div class="min-h-screen bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl text-gray-900 mb-2 font-bold">
                @(string.IsNullOrEmpty(searchKeyword) ? "Tất Cả Sản Phẩm" : $"Kết quả tìm kiếm cho: \"{searchKeyword}\"")
            </h1>
            <p class="text-gray-600">Tìm thấy <span class="font-semibold text-[#2D5A3D]">@totalCount</span> sản phẩm phù hợp</p>
        </div>

        <form method="get" action="/Products" id="filterForm">
            @if(!string.IsNullOrEmpty(searchKeyword)) {
                <input type="hidden" name="search" value="@searchKeyword" />
            }
            <input type="hidden" name="pageNumber" id="pageNumber" value="@paginationModel.CurrentPage" />
            <input type="hidden" name="minPrice" id="minPrice" value="@sidebarModel.MinPrice" />
            <input type="hidden" name="maxPrice" id="maxPrice" value="@sidebarModel.MaxPrice" />
            <input type="hidden" id="viewMode" value="grid" />

            <div class="flex flex-col md:flex-row gap-8 relative items-start">
                
                <!-- Main Content (TRÁI) -->
                <div class="flex-1 w-full order-2 md:order-1">
                    @await Html.PartialAsync("Partials/_ProductListToolbar", toolbarModel)
                    
                    @await Html.PartialAsync("Partials/_ProductGrid", gridModel)
                    
                    @await Html.PartialAsync("Partials/_ProductPagination", paginationModel)
                </div>

                <!-- Filters Sidebar (PHẢI) -->
                @await Html.PartialAsync("Partials/_ProductFilterSidebar", sidebarModel)
            </div>
        </form>
    </div>
</div>

<style>
    /* Toggle list and grid mode elements */
    #productContainer.view-grid .product-card-list { display: none; }
    #productContainer.view-grid .product-card-grid { display: flex; }

    #productContainer.view-list .product-card-grid { display: none; }
    #productContainer.view-list .product-card-list { display: block; }
</style>

@section Scripts {
    <script src="~/js/pages/product-list.js" asp-append-version="true"></script>
}
