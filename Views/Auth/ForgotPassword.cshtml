@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<div class="w-full">
    <div class="mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-2 tracking-tight">Quên mật khẩu</h2>
        <p class="text-gray-500 font-medium">Nhập email của bạn để nhận mã xác thực OTP</p>
    </div>

    <form class="space-y-5">
        <div class="space-y-1">
            <label class="block text-sm font-semibold text-gray-700 mb-1.5 ml-1">Email đăng ký</label>
            <div class="relative group">
                <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                    <i data-lucide="mail" class="h-5 w-5 text-gray-400 group-focus-within:text-[#2D5A3D] transition-colors"></i>
                </div>
                <input type="email" placeholder="your@email.com" class="block w-full pl-11 pr-4 py-3.5 bg-gray-50/50 border-2 border-gray-100 rounded-2xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#2D5A3D] focus:bg-white transition-all text-[15px] font-medium" required />
            </div>
            <p class="text-xs text-gray-500 mt-2 ml-1">
                Vui lòng nhập email bạn đã đăng ký để nhận mã xác thực OTP.
            </p>
        </div>

        <button type="button" onclick="alert('Tính năng đang được phát triển')" class="w-full flex justify-center py-4 px-4 rounded-2xl shadow-sm text-[15px] font-bold text-white bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] hover:shadow-lg hover:-translate-y-0.5 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#2D5A3D]">
            Tiếp Tục
        </button>
    </form>

    <div class="mt-8 text-center">
        <a href="/Auth/Login" class="flex items-center justify-center gap-2 text-sm text-gray-600 hover:text-[#2D5A3D] transition-colors font-medium">
            <i data-lucide="arrow-left" class="w-4 h-4"></i>
            <span>Quay lại Đăng nhập</span>
        </a>
    </div>
</div>
