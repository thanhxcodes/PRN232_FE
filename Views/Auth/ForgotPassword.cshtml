@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "_AuthLayout";
}

<div class="w-full" id="forgot-password-container">
    <div class="mb-8 flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-[#108A4D] flex items-center justify-center text-white">
            <i data-lucide="key" class="w-5 h-5"></i>
        </div>
        <div>
            <h2 class="text-2xl font-bold text-gray-900 tracking-tight" id="step-title">Quên Mật Khẩu</h2>
            <p class="text-sm text-gray-500 font-medium" id="step-subtitle">Nhập email để nhận mã xác thực</p>
        </div>
    </div>

    <!-- Error/Message Alert -->
    <div id="forgot-alert" class="hidden bg-red-50/80 backdrop-blur-sm border border-red-200 text-red-700 rounded-2xl px-5 py-3.5 flex items-center gap-2.5 shadow-sm mb-6 text-sm font-medium"></div>

    <form id="forgot-form" class="space-y-5" onsubmit="return false;">
        
        <!-- STEP 1: Enter Email -->
        <div id="step-1-container" class="space-y-5">
            <div class="space-y-1">
                <label class="block text-sm font-semibold text-gray-700 mb-1.5 ml-1">Email đăng ký</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i data-lucide="mail" class="h-5 w-5 text-gray-400 group-focus-within:text-[#2D5A3D] transition-colors"></i>
                    </div>
                    <input id="step1-email" type="email" placeholder="your@email.com" required class="block w-full pl-11 pr-4 py-3.5 bg-gray-50/50 border-2 border-gray-100 rounded-2xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#2D5A3D] focus:bg-white transition-all text-[15px] font-medium" />
                </div>
                <p class="text-xs text-gray-500 ml-1 mt-2">Vui lòng nhập email bạn đã đăng ký để nhận mã xác thực OTP.</p>
            </div>

            <div class="pt-2">
                <button type="button" id="btn-send-otp" class="w-full flex justify-center items-center py-3.5 px-4 rounded-xl shadow-sm text-[15px] font-bold text-white bg-[#9ca3af] hover:bg-[#108A4D] transition-all focus:outline-none">
                    <span id="btn-send-otp-text">Tiếp Tục</span>
                </button>
            </div>
        </div>

        <!-- STEP 2: Enter OTP -->
        <div id="step-2-container" class="hidden space-y-5">
            <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4">
                <p class="text-sm text-amber-800 flex items-start gap-2">
                    <i data-lucide="info" class="w-5 h-5 shrink-0 mt-0.5"></i>
                    <span>Lưu ý: Nếu không thấy email trong Hộp thư đến, vui lòng kiểm tra cả mục <strong>Thư rác (Spam)</strong> hoặc đợi vài phút.</span>
                </p>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-semibold text-gray-700 mb-1.5 ml-1 text-center">Mã OTP (6 chữ số)</label>
                <div class="flex justify-center gap-2" id="otp-inputs">
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-[#108A4D] focus:bg-white transition-all focus:outline-none" />
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-[#108A4D] focus:bg-white transition-all focus:outline-none" />
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-[#108A4D] focus:bg-white transition-all focus:outline-none" />
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-[#108A4D] focus:bg-white transition-all focus:outline-none" />
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-[#108A4D] focus:bg-white transition-all focus:outline-none" />
                    <input type="text" maxlength="1" class="w-12 h-14 text-center text-xl font-bold bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-[#108A4D] focus:bg-white transition-all focus:outline-none" />
                </div>
            </div>

            <div class="pt-2">
                <button type="button" id="btn-verify-otp" class="w-full flex justify-center items-center py-3.5 px-4 rounded-xl shadow-sm text-[15px] font-bold text-white bg-[#9ca3af] hover:bg-[#108A4D] transition-all focus:outline-none">
                    <span id="btn-verify-otp-text">Xác Thực</span>
                </button>
            </div>
            
            <div class="text-center mt-4">
                <button type="button" id="btn-resend-otp" class="text-sm font-semibold text-gray-500 hover:text-[#108A4D] transition-colors">
                    Gửi lại mã OTP
                </button>
            </div>
        </div>

        <!-- STEP 3: Reset Password -->
        <div id="step-3-container" class="hidden space-y-5">
            <div class="space-y-1">
                <label class="block text-sm font-semibold text-gray-700 mb-1.5 ml-1">Mật khẩu mới</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i data-lucide="lock" class="h-5 w-5 text-gray-400 group-focus-within:text-[#2D5A3D] transition-colors"></i>
                    </div>
                    <input id="step3-password" type="password" placeholder="Nhập mật khẩu mới" required class="block w-full pl-11 pr-12 py-3.5 bg-gray-50/50 border-2 border-gray-100 rounded-2xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#2D5A3D] focus:bg-white transition-all text-[15px] font-medium" />
                    <button type="button" onclick="togglePassword('step3-password', this)" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 transition-colors">
                        <i data-lucide="eye" class="h-5 w-5"></i>
                    </button>
                </div>
            </div>

            <div class="space-y-1">
                <label class="block text-sm font-semibold text-gray-700 mb-1.5 ml-1">Xác nhận mật khẩu</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i data-lucide="lock" class="h-5 w-5 text-gray-400 group-focus-within:text-[#2D5A3D] transition-colors"></i>
                    </div>
                    <input id="step3-confirm-password" type="password" placeholder="Nhập lại mật khẩu mới" required class="block w-full pl-11 pr-12 py-3.5 bg-gray-50/50 border-2 border-gray-100 rounded-2xl text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#2D5A3D] focus:bg-white transition-all text-[15px] font-medium" />
                    <button type="button" onclick="togglePassword('step3-confirm-password', this)" class="absolute inset-y-0 right-0 pr-4 flex items-center text-gray-400 hover:text-gray-600 transition-colors">
                        <i data-lucide="eye" class="h-5 w-5"></i>
                    </button>
                </div>
            </div>

            <div class="pt-2">
                <button type="button" id="btn-reset-password" class="w-full flex justify-center py-3.5 px-4 rounded-xl shadow-sm text-[15px] font-bold text-white bg-[#108A4D] hover:bg-[#0e7a44] transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#108A4D]">
                    <span id="btn-reset-password-text">Cập Nhật Mật Khẩu</span>
                </button>
            </div>
        </div>

        <div class="relative mt-8 mb-4">
            <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-gray-200"></div>
            </div>
        </div>

        <div class="text-center">
            <a href="/Auth/Login" class="text-sm font-semibold text-gray-600 hover:text-[#108A4D] transition-colors flex items-center justify-center gap-1">
                <i data-lucide="arrow-left" class="w-4 h-4"></i> Quay lại Đăng nhập
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                btn.innerHTML = '<i data-lucide="eye-off" class="h-5 w-5"></i>';
            } else {
                input.type = 'password';
                btn.innerHTML = '<i data-lucide="eye" class="h-5 w-5"></i>';
            }
            lucide.createIcons();
        }
    </script>
    <script src="~/js/forgot-password-flow.js" asp-append-version="true"></script>
}
