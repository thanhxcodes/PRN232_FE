@{
    ViewData["Title"] = "Gửi Thông Báo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h2 class="text-3xl text-gray-900 mb-2">Gửi Thông Báo</h2>
    <p class="text-gray-600">Gửi thông báo quan trọng đến tất cả hoặc nhóm người dùng cụ thể</p>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-8">
    <!-- Compose Panel -->
    <div class="xl:col-span-2 space-y-6">
        <!-- Type Templates -->
        <div class="bg-white rounded-2xl shadow-sm p-6">
            <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center space-x-2">
                <i data-lucide="bell" class="w-5 h-5 text-[#2D5A3D]"></i>
                <span>Loại thông báo</span>
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-2">
                <button type="button" class="flex flex-col items-center space-y-1.5 p-3 rounded-xl border-2 transition-all text-xs font-medium bg-blue-50 border-blue-600 text-blue-600">
                    <i data-lucide="megaphone" class="w-5 h-5 text-blue-600"></i>
                    <span>Thông báo</span>
                </button>
                <button type="button" class="flex flex-col items-center space-y-1.5 p-3 rounded-xl border-2 transition-all text-xs font-medium border-gray-200 text-gray-500 hover:bg-gray-50">
                    <i data-lucide="tag" class="w-5 h-5 text-gray-400"></i>
                    <span>Khuyến mãi</span>
                </button>
                <button type="button" class="flex flex-col items-center space-y-1.5 p-3 rounded-xl border-2 transition-all text-xs font-medium border-gray-200 text-gray-500 hover:bg-gray-50">
                    <i data-lucide="alert-triangle" class="w-5 h-5 text-gray-400"></i>
                    <span>Cảnh báo</span>
                </button>
                <button type="button" class="flex flex-col items-center space-y-1.5 p-3 rounded-xl border-2 transition-all text-xs font-medium border-gray-200 text-gray-500 hover:bg-gray-50">
                    <i data-lucide="calendar" class="w-5 h-5 text-gray-400"></i>
                    <span>Sự kiện</span>
                </button>
                <button type="button" class="flex flex-col items-center space-y-1.5 p-3 rounded-xl border-2 transition-all text-xs font-medium border-gray-200 text-gray-500 hover:bg-gray-50">
                    <i data-lucide="star" class="w-5 h-5 text-gray-400"></i>
                    <span>Tính năng mới</span>
                </button>
            </div>
        </div>

        <!-- Compose Form -->
        <div class="bg-white rounded-2xl shadow-sm p-6 space-y-5">
            <h3 class="text-base font-semibold text-gray-800 flex items-center space-x-2">
                <i data-lucide="megaphone" class="w-5 h-5 text-[#2D5A3D]"></i>
                <span>Soạn thông báo</span>
            </h3>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Tiêu đề thông báo *</label>
                <input type="text" placeholder="Nhập tiêu đề thông báo..." value="📢 Cập nhật chính sách đăng tin mới" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Nội dung *</label>
                <textarea rows="5" placeholder="Nhập nội dung thông báo đầy đủ..." class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm resize-none">REVORA vừa cập nhật chính sách đăng tin để đảm bảo trải nghiệm mua bán tốt hơn cho cộng đồng. Vui lòng đọc kỹ các điều khoản mới trước khi đăng sản phẩm.</textarea>
                <div class="text-right text-xs text-gray-400 mt-1">161/500 ký tự</div>
            </div>

            <!-- Schedule toggle -->
            <div class="flex items-center space-x-3">
                <button type="button" class="relative w-10 h-5 rounded-full transition-colors bg-gray-300">
                    <div class="absolute top-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform translate-x-0.5"></div>
                </button>
                <span class="text-sm text-gray-700">Hẹn giờ gửi</span>
            </div>
        </div>

        <!-- Preview -->
        <div class="bg-white rounded-2xl shadow-sm p-6">
            <h3 class="text-sm font-semibold text-gray-600 mb-3">Xem trước thông báo</h3>
            <div class="bg-blue-50 border border-current/20 rounded-2xl p-4">
                <div class="flex items-start space-x-3">
                    <div class="w-9 h-9 rounded-xl bg-blue-50 border border-current/10 flex items-center justify-center flex-shrink-0">
                        <i data-lucide="megaphone" class="w-5 h-5 text-blue-600"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="font-semibold text-gray-900 text-sm">📢 Cập nhật chính sách đăng tin mới</div>
                        <div class="text-xs text-gray-600 mt-1 leading-relaxed">REVORA vừa cập nhật chính sách đăng tin để đảm bảo trải nghiệm mua bán tốt hơn cho cộng đồng...</div>
                        <div class="text-xs text-gray-400 mt-1.5">Vừa xong · REVORA Admin</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="space-y-6">
        <!-- Target Selector -->
        <div class="bg-white rounded-2xl shadow-sm p-6">
            <h3 class="text-base font-semibold text-gray-800 mb-4 flex items-center space-x-2">
                <i data-lucide="users" class="w-5 h-5 text-[#2D5A3D]"></i>
                <span>Đối tượng nhận</span>
            </h3>
            <div class="space-y-2">
                <button type="button" class="w-full text-left p-3 rounded-xl border-2 transition-all border-[#2D5A3D] bg-[#2D5A3D]/5">
                    <div class="flex items-center justify-between">
                        <div>
                            <div class="text-sm font-medium text-gray-900">Tất cả người dùng</div>
                            <div class="text-xs text-gray-500 mt-0.5">Gửi đến toàn bộ tài khoản</div>
                        </div>
                        <div class="text-sm font-bold text-[#2D5A3D]">1,234</div>
                    </div>
                </button>
                <button type="button" class="w-full text-left p-3 rounded-xl border-2 transition-all border-gray-200 hover:border-gray-300">
                    <div class="flex items-center justify-between">
                        <div>
                            <div class="text-sm font-medium text-gray-900">Người dùng hoạt động</div>
                            <div class="text-xs text-gray-500 mt-0.5">Đăng nhập trong 30 ngày qua</div>
                        </div>
                        <div class="text-sm font-bold text-gray-400">892</div>
                    </div>
                </button>
            </div>
        </div>

        <!-- Summary + Send -->
        <div class="bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-2xl p-6 text-white">
            <h3 class="font-semibold mb-4">Tổng kết gửi</h3>
            <div class="space-y-2 text-sm mb-5">
                <div class="flex justify-between">
                    <span class="text-white/70">Loại:</span>
                    <span class="font-medium">Thông báo</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-white/70">Đối tượng:</span>
                    <span class="font-medium">Tất cả người dùng</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-white/70">Người nhận:</span>
                    <span class="font-bold text-lg">1,234</span>
                </div>
            </div>

            <button type="button" class="w-full flex items-center justify-center space-x-2 py-3 rounded-xl font-semibold text-sm transition-all bg-white text-[#2D5A3D] hover:bg-white/90">
                <i data-lucide="send" class="w-4 h-4"></i>
                <span>Gửi ngay</span>
            </button>
        </div>
    </div>
</div>

<!-- Sent History -->
<div class="mt-8 bg-white rounded-2xl shadow-sm">
    <button type="button" class="w-full flex items-center justify-between p-6 hover:bg-gray-50 rounded-2xl transition-colors">
        <div class="flex items-center space-x-2">
            <i data-lucide="clock" class="w-5 h-5 text-[#2D5A3D]"></i>
            <h3 class="text-base font-semibold text-gray-800">Lịch sử thông báo đã gửi</h3>
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">3</span>
        </div>
        <i data-lucide="chevron-up" class="w-5 h-5 text-gray-400"></i>
    </button>

    <div class="border-t border-gray-200">
        <div class="divide-y divide-gray-100">
            <!-- Mock Notif 1 -->
            <div class="p-5 hover:bg-gray-50 transition-colors">
                <div class="flex items-start justify-between">
                    <div class="flex-1 min-w-0 pr-4">
                        <div class="flex items-center space-x-2 mb-1">
                            <span class="text-xs font-medium text-[#C4603A]">Khuyến mãi</span>
                            <span class="text-gray-300">·</span>
                            <span class="text-xs text-gray-500">01/05/2026 09:00</span>
                        </div>
                        <div class="text-sm font-semibold text-gray-900 truncate">🎉 Chào mừng tháng 5 - Ưu đãi đặc biệt!</div>
                        <div class="text-xs text-gray-500 mt-0.5 line-clamp-1">Tháng 5 này REVORA tặng bạn 10 credits đăng tin miễn phí...</div>
                        <div class="flex items-center space-x-4 mt-2">
                            <div class="flex items-center space-x-1 text-xs text-gray-500">
                                <i data-lucide="users" class="w-3.5 h-3.5"></i>
                                <span>1,234 người nhận</span>
                            </div>
                            <div class="flex items-center space-x-1 text-xs text-gray-500">
                                <i data-lucide="check-circle" class="w-3.5 h-3.5 text-green-500"></i>
                                <span>Tỷ lệ đọc: 68%</span>
                            </div>
                        </div>
                    </div>
                    <button class="p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors flex-shrink-0">
                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
