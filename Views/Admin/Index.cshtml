@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="flex items-center justify-between mb-8">
            <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
                <i data-lucide="shield" class="w-8 h-8 text-[#2D5A3D]"></i>
                Admin Dashboard
            </h1>
            <div class="flex items-center gap-4">
                <div class="bg-white px-4 py-2 rounded-xl shadow-sm font-medium text-gray-600 flex items-center gap-2">
                    <i data-lucide="calendar" class="w-4 h-4 text-[#2D5A3D]"></i>
                    Tháng @DateTime.Now.Month/@DateTime.Now.Year
                </div>
            </div>
        </div>

        <!-- Stats Overview -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 border-l-4 border-l-[#2D5A3D]">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1">Tổng Doanh Thu</p>
                        <h3 class="text-2xl font-bold text-gray-900">125.4M đ</h3>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-green-50 flex items-center justify-center text-green-600">
                        <i data-lucide="dollar-sign" class="w-5 h-5"></i>
                    </div>
                </div>
                <div class="text-sm font-medium text-green-600 flex items-center gap-1">
                    <i data-lucide="trending-up" class="w-4 h-4"></i> +12.5% so với tháng trước
                </div>
            </div>

            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 border-l-4 border-l-blue-500">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1">Người Dùng Mới</p>
                        <h3 class="text-2xl font-bold text-gray-900">1,245</h3>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600">
                        <i data-lucide="users" class="w-5 h-5"></i>
                    </div>
                </div>
                <div class="text-sm font-medium text-green-600 flex items-center gap-1">
                    <i data-lucide="trending-up" class="w-4 h-4"></i> +8.2% so với tháng trước
                </div>
            </div>

            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 border-l-4 border-l-orange-500">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1">Đơn Hàng (Thành Công)</p>
                        <h3 class="text-2xl font-bold text-gray-900">842</h3>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-orange-50 flex items-center justify-center text-orange-600">
                        <i data-lucide="shopping-bag" class="w-5 h-5"></i>
                    </div>
                </div>
                <div class="text-sm font-medium text-green-600 flex items-center gap-1">
                    <i data-lucide="trending-up" class="w-4 h-4"></i> +24.1% so với tháng trước
                </div>
            </div>

            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 border-l-4 border-l-red-500">
                <div class="flex justify-between items-start mb-4">
                    <div>
                        <p class="text-sm font-medium text-gray-500 mb-1">Báo Cáo Vi Phạm</p>
                        <h3 class="text-2xl font-bold text-gray-900">12</h3>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center text-red-600">
                        <i data-lucide="alert-triangle" class="w-5 h-5"></i>
                    </div>
                </div>
                <div class="text-sm font-medium text-red-600 flex items-center gap-1">
                    <i data-lucide="trending-down" class="w-4 h-4"></i> Cần xử lý ngay
                </div>
            </div>
        </div>

        <!-- System Management Sections -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Recent Users -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                    <h2 class="text-lg font-bold text-gray-900">Người dùng mới đăng ký</h2>
                    <a href="#" class="text-sm font-semibold text-[#2D5A3D] hover:underline">Xem tất cả</a>
                </div>
                <div class="divide-y divide-gray-100">
                    @for(int i=0; i<5; i++) {
                        <div class="p-4 flex items-center justify-between hover:bg-gray-50 transition-colors">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-r from-gray-200 to-gray-300"></div>
                                <div>
                                    <div class="font-semibold text-gray-900">Nguyễn Văn User @i</div>
                                    <div class="text-xs text-gray-500">user@(i)@@gmail.com</div>
                                </div>
                            </div>
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">Hoạt động</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Pending Approvals / Reports -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                    <h2 class="text-lg font-bold text-gray-900">Yêu cầu cần duyệt</h2>
                </div>
                <div class="p-6 text-center text-gray-500 py-12">
                    <i data-lucide="check-circle" class="w-12 h-12 mx-auto text-green-400 mb-3"></i>
                    <p>Không có yêu cầu nào đang chờ duyệt.</p>
                </div>
            </div>
        </div>
    </div>
</div>
