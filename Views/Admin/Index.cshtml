@model REVORA_MVC_FE.Models.ViewModels.DashboardStatsViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<div class="mb-8">
    <h2 class="text-3xl text-gray-900 mb-2">Tổng Quan</h2>
    <p class="text-gray-600">Thống kê và quản lý hệ thống REVORA</p>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-2xl shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-green-500 to-green-600 flex items-center justify-center">
                <i data-lucide="dollar-sign" class="w-6 h-6 text-white"></i>
            </div>
            <span class="text-sm @(Model.RevenueGrowth >= 0 ? "text-green-500" : "text-red-500")">
                @(Model.RevenueGrowth > 0 ? "+" : "")@Model.RevenueGrowth%
            </span>
        </div>
        <div class="text-3xl text-gray-900 mb-1">@Model.CurrentMonthRevenue.ToString("N0")đ</div>
        <div class="text-sm text-gray-600">Doanh Thu Tháng Này</div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center">
                <i data-lucide="package" class="w-6 h-6 text-white"></i>
            </div>
            <span class="text-sm @(Model.PackagesSoldGrowth >= 0 ? "text-blue-500" : "text-red-500")">
                @(Model.PackagesSoldGrowth > 0 ? "+" : "")@Model.PackagesSoldGrowth%
            </span>
        </div>
        <div class="text-3xl text-gray-900 mb-1">@Model.PackagesSold.ToString("N0")</div>
        <div class="text-sm text-gray-600">Gói Đã Bán Tháng Này</div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500 to-purple-600 flex items-center justify-center">
                <i data-lucide="users" class="w-6 h-6 text-white"></i>
            </div>
            <span class="text-sm @(Model.TotalUsersGrowth >= 0 ? "text-purple-500" : "text-red-500")">
                @(Model.TotalUsersGrowth > 0 ? "+" : "")@Model.TotalUsersGrowth%
            </span>
        </div>
        <div class="text-3xl text-gray-900 mb-1">@Model.TotalUsers.ToString("N0")</div>
        <div class="text-sm text-gray-600">Người Dùng Hoạt Động</div>
    </div>

    <div class="bg-white rounded-2xl shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] flex items-center justify-center">
                <i data-lucide="trending-up" class="w-6 h-6 text-white"></i>
            </div>
            <span class="text-sm @(Model.ActiveProductsGrowth >= 0 ? "text-[#2D5A3D]" : "text-red-500")">
                @(Model.ActiveProductsGrowth > 0 ? "+" : "")@Model.ActiveProductsGrowth%
            </span>
        </div>
        <div class="text-3xl text-gray-900 mb-1">@Model.ActiveProducts.ToString("N0")</div>
        <div class="text-sm text-gray-600">Sản Phẩm Đang Bán</div>
    </div>
</div>

<!-- Charts -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Revenue Chart -->
    <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
        <h3 class="text-xl text-gray-900 mb-6">Doanh Thu 7 Ngày Qua</h3>
        <div style="height: 300px;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Package Distribution -->
    <div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
        <h3 class="text-xl text-gray-900 mb-6">Phân Bổ Gói Đã Bán Tháng Này</h3>
        @if (Model.PackageDistribution == null || !Model.PackageDistribution.Any())
        {
            <div class="flex justify-center items-center h-[300px] text-gray-400">
                Chưa có dữ liệu gói được bán
            </div>
        }
        else
        {
            <div style="height: 300px;">
                <canvas id="packagePieChart"></canvas>
            </div>
            <div class="grid grid-cols-2 gap-3 mt-6">
                @foreach (var pkg in Model.PackageDistribution)
                {
                    <div class="flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full" style="background-color: @pkg.Color"></div>
                        <span class="text-xs text-gray-600">@pkg.Name: @pkg.Value</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Recent Activity -->
<div class="bg-white rounded-2xl shadow-sm p-6 border border-gray-100">
    <h3 class="text-xl text-gray-900 mb-6">Hoạt Động Gần Đây</h3>
    <div class="space-y-4">
        @if (Model.RecentActivities == null || !Model.RecentActivities.Any())
        {
            <div class="text-center text-gray-400 py-4">Chưa có hoạt động giao dịch nào.</div>
        }
        else
        {
            foreach (var activity in Model.RecentActivities)
            {
                <div class="flex items-center justify-between py-3 border-b border-gray-100 last:border-0">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-full flex items-center justify-center text-white text-sm uppercase">
                            @(activity.User?.Length >= 2 ? activity.User.Substring(0, 2) : activity.User)
                        </div>
                        <div>
                            <div class="text-sm text-gray-900">
                                <span class="font-medium">@activity.User</span> @activity.Action
                            </div>
                            <div class="text-xs text-gray-500">@activity.Time</div>
                        </div>
                    </div>
                    <div class="text-sm font-bold text-green-600">+@activity.Amount.ToString("N0")đ</div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <!-- Load Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueChart7Days));
            if(chartData && chartData.length > 0) {
                const labels = chartData.map(d => d.Label);
                const postingData = chartData.map(d => d.Posting);
                const featuredData = chartData.map(d => d.Featured);

                const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
                new Chart(ctxRevenue, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Gói Posting',
                                data: postingData,
                                borderColor: '#3B82F6',
                                backgroundColor: 'rgba(59, 130, 246, 0.3)',
                                borderWidth: 2,
                                fill: true,
                                tension: 0.4
                            },
                            {
                                label: 'Gói Featured',
                                data: featuredData,
                                borderColor: '#2D5A3D',
                                backgroundColor: 'rgba(45, 90, 61, 0.3)',
                                borderWidth: 2,
                                fill: true,
                                tension: 0.4
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f0f0f0', drawBorder: false },
                                ticks: {
                                    callback: function(value) {
                                        return (value / 1000) + 'k';
                                    }
                                }
                            },
                            x: {
                                grid: { display: false, drawBorder: false }
                            }
                        }
                    }
                });
            }

            const pieData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PackageDistribution));
            if (pieData && pieData.length > 0 && document.getElementById('packagePieChart')) {
                const pieLabels = pieData.map(d => d.Name);
                const pieValues = pieData.map(d => d.Value);
                const pieColors = pieData.map(d => d.Color);

                const ctxPie = document.getElementById('packagePieChart').getContext('2d');
                new Chart(ctxPie, {
                    type: 'doughnut',
                    data: {
                        labels: pieLabels,
                        datasets: [{
                            data: pieValues,
                            backgroundColor: pieColors,
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '60%',
                        plugins: {
                            legend: { display: false }
                        }
                    }
                });
            }
        });
    </script>
}
