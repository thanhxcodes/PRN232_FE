@{
    ViewData["Title"] = "Ý Kiến Đóng Góp";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="p-6 max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Ý Kiến Đóng Góp</h1>
            <p class="text-sm text-gray-500 mt-1">Quản lý và xem xét các phản hồi từ người dùng</p>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50 border-b border-gray-100">
                        <th class="p-4 font-semibold text-gray-600 text-sm">Người Dùng</th>
                        <th class="p-4 font-semibold text-gray-600 text-sm">Nội Dung</th>
                        <th class="p-4 font-semibold text-gray-600 text-sm w-40">Thời Gian</th>
                        <th class="p-4 font-semibold text-gray-600 text-sm w-40 text-center">Trạng Thái</th>
                        <th class="p-4 font-semibold text-gray-600 text-sm w-32 text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    <!-- Mock Data Row 1 (Khách vãng lai) -->
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 align-top">
                            <div class="flex flex-col gap-1">
                                <span class="font-semibold text-gray-500 text-sm italic">Khách vãng lai</span>
                                <div class="flex items-center gap-1.5 text-xs text-gray-500 mt-1">
                                    <i data-lucide="mail" class="w-3.5 h-3.5"></i>
                                    guest@example.com
                                </div>
                            </div>
                        </td>
                        <td class="p-4 align-top">
                            <div class="flex items-start gap-2">
                                <i data-lucide="message-square" class="w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0"></i>
                                <p class="text-sm text-gray-700 whitespace-pre-wrap">App rất dễ sử dụng, tôi rất thích giao diện này.</p>
                            </div>
                        </td>
                        <td class="p-4 align-top text-sm text-gray-500">
                            <div class="flex items-center gap-1.5">
                                <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                                07/07/2026
                            </div>
                        </td>
                        <td class="p-4 align-top text-center">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border bg-amber-50 text-amber-700 border-amber-200">
                                <i data-lucide="clock" class="w-3.5 h-3.5"></i> Chờ xử lý
                            </span>
                        </td>
                        <td class="p-4 align-top text-center">
                            <button class="text-xs font-semibold text-[#2D5A3D] hover:text-[#1a3825] bg-[#2D5A3D]/10 hover:bg-[#2D5A3D]/20 px-3 py-1.5 rounded-lg transition-colors">
                                Đánh dấu đã xem
                            </button>
                        </td>
                    </tr>
                    <!-- Mock Data Row 2 (Registered User) -->
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 align-top">
                            <div class="flex flex-col gap-1">
                                <span class="font-semibold text-gray-900 text-sm">Trần Văn A</span>
                                <span class="text-xs text-gray-500">@@tranvana</span>
                                <div class="flex items-center gap-1.5 text-xs text-gray-500 mt-1">
                                    <i data-lucide="mail" class="w-3.5 h-3.5"></i>
                                    tranvana@example.com
                                </div>
                            </div>
                        </td>
                        <td class="p-4 align-top">
                            <div class="flex items-start gap-2">
                                <i data-lucide="message-square" class="w-4 h-4 text-gray-400 mt-0.5 flex-shrink-0"></i>
                                <p class="text-sm text-gray-700 whitespace-pre-wrap">Mình gặp lỗi khi thanh toán VNPAY, nhờ admin kiểm tra giúp.</p>
                            </div>
                        </td>
                        <td class="p-4 align-top text-sm text-gray-500">
                            <div class="flex items-center gap-1.5">
                                <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                                06/07/2026
                            </div>
                        </td>
                        <td class="p-4 align-top text-center">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border bg-green-50 text-green-700 border-green-200">
                                <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> Đã xem
                            </span>
                        </td>
                        <td class="p-4 align-top text-center">
                            <!-- No action needed when already reviewed -->
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Phân trang -->
        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-100">
            <span class="text-sm text-gray-500">
                Trang 1 / 1
            </span>
            <div class="flex gap-2">
                <button disabled class="p-1.5 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 disabled:opacity-50 transition-colors">
                    <i data-lucide="chevron-left" class="w-5 h-5"></i>
                </button>
                <button disabled class="p-1.5 rounded-lg border border-gray-200 text-gray-600 hover:bg-gray-50 disabled:opacity-50 transition-colors">
                    <i data-lucide="chevron-right" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
    </div>
</div>
