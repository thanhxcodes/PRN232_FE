@{
    ViewData["Title"] = "Quản Lý Sự Kiện";
    Layout = "_Layout";
}

<div class="mb-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-6">
        <div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2 tracking-tight">Quản Lý Sự Kiện</h2>
            <p class="text-gray-600">Thêm, sửa, xóa các thông báo sự kiện hiển thị trên trang chủ</p>
        </div>
        <button id="btn-add-new" class="px-6 py-2.5 bg-[#2D5A3D] hover:bg-[#1a3825] text-white rounded-xl flex items-center gap-2 font-semibold transition-all shadow-sm">
            <i data-lucide="plus" class="w-5 h-5"></i>
            <span>Thêm Mới</span>
        </button>
    </div>

    <!-- Search Input -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-2 mb-6 flex items-center max-w-md">
        <i data-lucide="search" class="w-5 h-5 text-gray-400 ml-3"></i>
        <input type="text" id="search-input" placeholder="Tìm kiếm theo tiêu đề..." class="w-full px-3 py-2 outline-none text-gray-700 bg-transparent">
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden relative">
        <div class="overflow-x-auto min-h-[400px]">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50 border-b border-gray-100 text-xs uppercase tracking-wider text-gray-500 font-semibold">
                        <th class="py-4 px-6 rounded-tl-2xl w-2/5">Thông Báo</th>
                        <th class="py-4 px-6 text-center">Ưu Tiên</th>
                        <th class="py-4 px-6 text-center">Thời Gian</th>
                        <th class="py-4 px-6 text-center">Trạng Thái</th>
                        <th class="py-4 px-6 text-right rounded-tr-2xl">Thao Tác</th>
                    </tr>
                </thead>
                <tbody id="announcements-table-body" class="divide-y divide-gray-100">
                    <!-- Data will be loaded here via JS -->
                </tbody>
            </table>
            
            <!-- Loading State -->
            <div id="loading-state" class="py-20 flex justify-center hidden">
                <i data-lucide="loader-2" class="w-8 h-8 text-[#2D5A3D] animate-spin"></i>
            </div>
            <!-- Empty State -->
            <div id="empty-state" class="py-20 text-center hidden">
                <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i data-lucide="search-x" class="w-8 h-8 text-gray-400"></i>
                </div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Không tìm thấy thông báo</h3>
                <p class="text-gray-500">Chưa có thông báo nào hoặc không khớp với tìm kiếm.</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal Add/Edit -->
<div id="announcement-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-white rounded-3xl max-w-5xl w-full max-h-[90vh] flex flex-col shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300" id="modal-content">
        <!-- Header -->
        <div class="px-8 py-5 border-b border-gray-100 flex justify-between items-center bg-white sticky top-0 z-10">
            <h3 id="modal-title" class="text-2xl font-bold text-gray-900">Thêm Thông Báo Mới</h3>
            <button id="btn-close-modal" class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-full transition-colors">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>
        <!-- Body -->
        <div class="p-8 overflow-y-auto flex-1 bg-gray-50/50">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                <!-- Form -->
                <div>
                    <form id="announcement-form" class="space-y-5">
                        <input type="hidden" id="form-id" value="">
                        
                        <!-- Image Upload -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Hình Ảnh *</label>
                            <div class="relative border-2 border-dashed border-gray-200 rounded-2xl p-6 hover:border-[#2D5A3D]/50 hover:bg-[#2D5A3D]/5 transition-all group text-center cursor-pointer overflow-hidden">
                                <input type="file" id="form-image-file" accept="image/jpeg, image/png, image/webp" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20">
                                
                                <div id="upload-placeholder" class="flex flex-col items-center gap-3">
                                    <div class="p-3 bg-white rounded-xl shadow-sm group-hover:scale-110 transition-transform">
                                        <i data-lucide="upload" class="w-6 h-6 text-[#2D5A3D]"></i>
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">Nhấp để chọn ảnh (JPG, PNG, WEBP)</p>
                                        <p class="text-xs text-gray-500 mt-1">Tối đa 5MB</p>
                                    </div>
                                </div>

                                <div id="upload-preview-container" class="absolute inset-0 hidden z-10 bg-white items-center justify-center">
                                    <img id="upload-preview-img" src="" class="h-full w-auto object-contain">
                                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                        <span class="text-white font-medium text-sm flex items-center gap-2"><i data-lucide="refresh-cw" class="w-4 h-4"></i> Đổi ảnh khác</span>
                                    </div>
                                </div>
                                
                                <div id="upload-loading" class="absolute inset-0 bg-white/90 z-30 hidden flex-col items-center justify-center">
                                    <i data-lucide="loader-2" class="w-8 h-8 text-[#2D5A3D] animate-spin mb-2"></i>
                                    <span class="text-sm font-medium text-[#2D5A3D]">Đang tải...</span>
                                </div>
                            </div>
                            <input type="hidden" id="form-image-url">
                        </div>

                        <!-- Title -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Tiêu đề *</label>
                            <input type="text" id="form-title" required class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-all" placeholder="VD: 🔥 REVORA MATCH">
                        </div>

                        <!-- Description -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Mô tả chi tiết *</label>
                            <textarea id="form-description" rows="3" required class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-all resize-none" placeholder="VD: Trao đổi quần áo..."></textarea>
                        </div>

                        <div class="grid grid-cols-2 gap-5">
                            <!-- Link -->
                            <div>
                                <label class="block text-xs font-bold text-gray-700 mb-2">Link Đích (Redirect) *</label>
                                <input type="text" id="form-link" list="route-suggestions" required class="w-full bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 block p-3 outline-none transition-all" placeholder="/">
                                <datalist id="route-suggestions">
                                    <option value="/" label="Trang Chủ (/)"></option>
                                    <option value="/match" label="Match (/match)"></option>
                                    <option value="/Products/Create" label="Đăng Tin (/Products/Create)"></option>
                                    <option value="/ranking" label="Bảng Xếp Hạng (/ranking)"></option>
                                    <option value="/Shorts" label="Short Video (/Shorts)"></option>
                                    <option value="/Plans" label="Gói Credit (/Plans)"></option>
                                    <option value="/Profile" label="Hồ Sơ (/Profile)"></option>
                                    <option value="/Chat" label="Nhắn Tin (/Chat)"></option>
                                </datalist>
                            </div>
                            <!-- Button Text -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Text Nút Bấm *</label>
                                <input type="text" id="form-button-text" required class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D]" placeholder="Khám phá ngay">
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-5">
                            <!-- Badge -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Badge Text</label>
                                <input type="text" id="form-badge" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D]" placeholder="HOT, MỚI...">
                            </div>
                            <!-- Priority -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Độ Ưu Tiên (0-999)</label>
                                <input type="number" id="form-priority" min="0" max="999" required class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D]" placeholder="0" value="0">
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-5">
                            <!-- Start Date -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Ngày Bắt Đầu *</label>
                                <input type="datetime-local" id="form-start" required class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D]">
                            </div>
                            <!-- End Date -->
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-2">Ngày Kết Thúc *</label>
                                <input type="datetime-local" id="form-end" required class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D]">
                            </div>
                        </div>

                        <!-- Is Active -->
                        <div class="flex items-center gap-3 pt-2">
                            <input type="checkbox" id="form-active" class="w-5 h-5 text-[#2D5A3D] rounded border-gray-300 focus:ring-[#2D5A3D]" checked>
                            <label class="text-sm font-medium text-gray-900 cursor-pointer select-none" for="form-active">Kích hoạt hiển thị (Is Active)</label>
                        </div>
                    </form>
                </div>
                
                <!-- Preview -->
                <div class="flex flex-col h-full">
                    <div class="flex items-center justify-between mb-4">
                        <label class="text-xs font-bold text-gray-500 uppercase tracking-wider flex items-center gap-2">
                            <i data-lucide="eye" class="w-4 h-4"></i> XEM TRƯỚC POPUP
                        </label>
                    </div>
                    
                    <div class="flex-1 bg-gray-200/50 rounded-2xl border border-gray-200 flex items-center justify-center p-8 relative overflow-hidden group">
                        <!-- Pseudo Backdrop -->
                        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm"></div>
                        
                        <!-- Preview Card -->
                        <div class="relative w-full max-w-sm aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl flex bg-[#1A1A1A]">
                            <div class="w-[45%] h-full bg-black flex items-center justify-center text-gray-600 relative overflow-hidden border-r border-white/5">
                                <div class="text-center z-10" id="preview-no-image">
                                    <i data-lucide="image" class="w-8 h-8 mx-auto mb-2 opacity-50"></i>
                                    <span class="text-[10px] font-medium uppercase tracking-widest opacity-50">Chưa có ảnh</span>
                                </div>
                                <img id="preview-img-tag" src="" class="absolute inset-0 w-full h-full object-cover hidden transition-all duration-300">
                            </div>
                            
                            <div class="w-[55%] p-5 flex flex-col justify-center relative">
                                <div id="preview-badge" class="absolute top-4 left-5 px-2 py-0.5 bg-yellow-500/20 text-yellow-500 text-[10px] font-bold rounded flex items-center gap-1 hidden">
                                    <i data-lucide="sparkles" class="w-3 h-3"></i> <span id="preview-badge-text"></span>
                                </div>
                                
                                <p class="text-[10px] font-bold tracking-widest text-white/50 mb-2 uppercase">Bản tin đặc biệt</p>
                                <h4 id="preview-title" class="text-white font-bold text-lg leading-tight mb-2">Tiêu đề thông báo</h4>
                                <p id="preview-description" class="text-white/60 text-xs leading-relaxed mb-6 line-clamp-4">Mô tả chi tiết sự kiện sẽ hiển thị ở đây...</p>
                                
                                <div class="flex items-center gap-2">
                                    <div class="flex-1 py-2 text-[10px] font-medium text-white/50 text-center rounded-lg border border-white/10">Để xem sau</div>
                                    <div id="preview-button" class="flex-1 py-2 bg-white text-black text-[10px] font-bold text-center rounded-lg shadow-sm">Khám phá ngay</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Footer -->
        <div class="px-8 py-5 border-t border-gray-100 bg-gray-50 flex justify-end gap-3 sticky bottom-0 z-10">
            <button id="btn-cancel" class="px-5 py-2.5 text-gray-600 bg-white border border-gray-200 hover:bg-gray-50 rounded-xl font-medium transition-colors">Hủy</button>
            <button id="btn-save" class="px-5 py-2.5 bg-[#2D5A3D] hover:bg-[#1a3825] text-white rounded-xl flex items-center justify-center gap-2 font-semibold transition-colors min-w-[160px]">
                <i data-lucide="save" class="w-5 h-5" id="save-icon"></i>
                <i data-lucide="loader-2" class="w-5 h-5 animate-spin hidden" id="save-spinner"></i>
                <span id="save-text">Lưu Thông Báo</span>
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/admin-announcements.js" asp-append-version="true"></script>
}
