@{
    ViewData["Title"] = "Quản Lý Sự Kiện";
    Layout = "~/Views/Shared/_Layout.cshtml"; // or maybe there is an _AdminLayout? Let's check later, for now just use Layout
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between">
    <div>
        <h2 class="text-3xl text-gray-900 mb-2 font-bold tracking-tight">Quản Lý Sự Kiện</h2>
        <p class="text-gray-600">Thêm, sửa, xóa các thông báo sự kiện hiển thị trên trang chủ</p>
    </div>
    <div class="mt-4 md:mt-0">
        <button onclick="document.getElementById('createModal').classList.remove('hidden')" class="bg-[#2D5A3D] text-white px-5 py-2.5 rounded-xl flex items-center space-x-2 font-semibold hover:bg-[#1a3825] transition-colors shadow-md shadow-[#2D5A3D]/20">
            <i data-lucide="plus" class="w-5 h-5"></i>
            <span>Thêm Mới</span>
        </button>
    </div>
</div>

<div class="bg-white rounded-2xl shadow-sm p-6 mb-8 border border-gray-100">
    <div class="relative w-full md:w-96 group">
        <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-[#2D5A3D] transition-colors"></i>
        <input type="text" placeholder="Tìm kiếm theo tiêu đề..." class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-all bg-gray-50 hover:bg-white font-medium text-sm" />
    </div>
</div>

<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100 bg-gray-50/80 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">
                    <th class="py-5 px-6">Thông Báo</th>
                    <th class="py-5 px-6">Ưu Tiên</th>
                    <th class="py-5 px-6">Thời Gian</th>
                    <th class="py-5 px-6">Trạng Thái</th>
                    <th class="py-5 px-6 text-right">Thao Tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <!-- Mock Data Row -->
                <tr class="hover:bg-gray-50/50 transition-colors">
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-4">
                            <img src="https://images.unsplash.com/photo-1495121605193-b116b5b9c5fe?w=400" alt="banner" class="w-16 h-16 object-cover rounded-xl shadow-sm" />
                            <div>
                                <div class="text-sm font-bold text-gray-900 flex items-center gap-2">
                                    Sự kiện mùa hè
                                    <span class="bg-amber-100 text-amber-700 text-[10px] px-2 py-0.5 rounded-full uppercase font-bold tracking-wider">HOT</span>
                                </div>
                                <div class="text-xs text-gray-500 max-w-xs truncate mt-0.5">Giảm giá lên đến 50% cho tất cả các sản phẩm...</div>
                                <div class="text-xs text-blue-500 mt-1 inline-block">/products</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <span class="text-sm font-bold text-gray-700 bg-gray-100 px-3 py-1 rounded-lg">10</span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="text-xs text-gray-500 flex flex-col gap-1">
                            <div><span class="font-semibold text-gray-700">Từ:</span> 01/06/2026</div>
                            <div><span class="font-semibold text-gray-700">Đến:</span> 30/06/2026</div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <button class="text-xs px-3 py-1.5 rounded-xl flex items-center space-x-1.5 w-fit font-bold shadow-sm transition-colors bg-green-50 border border-green-200 text-green-700 hover:bg-green-100">
                            <i data-lucide="check" class="w-3.5 h-3.5"></i>
                            <span>Đang bật</span>
                        </button>
                    </td>
                    <td class="py-4 px-6 text-right">
                        <div class="flex items-center justify-end space-x-2">
                            <button class="p-2 text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors" title="Sửa">
                                <i data-lucide="edit-2" class="w-4 h-4"></i>
                            </button>
                            <button class="p-2 text-red-600 bg-red-50 hover:bg-red-100 rounded-lg transition-colors" title="Xóa">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Thêm/Sửa (Hidden by default) -->
<div id="createModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-6xl overflow-hidden flex flex-col max-h-[95vh]">
        <div class="p-6 border-b border-gray-100 flex items-center justify-between">
            <h3 class="text-xl font-bold text-gray-900">Thêm Thông Báo Mới</h3>
            <button onclick="document.getElementById('createModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 p-2 rounded-full hover:bg-gray-100">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto p-6 bg-gray-50/50">
            <form class="space-y-5">
                 <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Hình Ảnh *</label>
                    <div class="border-2 border-dashed border-gray-200 rounded-2xl p-6 text-center relative hover:border-[#2D5A3D] transition-colors bg-gray-50/50">
                        <input type="file" accept="image/jpeg, image/png, image/webp" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
                        <i data-lucide="upload" class="w-8 h-8 text-gray-400 mx-auto mb-2"></i>
                        <p class="text-gray-700 font-medium text-sm">Nhấp để chọn ảnh (JPG, PNG, WEBP)</p>
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Tiêu đề *</label>
                    <input type="text" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] bg-gray-50 focus:bg-white text-sm" placeholder="VD: 🔥 REVORA MATCH" />
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" onclick="document.getElementById('createModal').classList.add('hidden')" class="px-5 py-2.5 text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-xl transition-colors font-semibold">Hủy</button>
                    <button type="submit" class="px-5 py-2.5 bg-[#2D5A3D] hover:bg-[#1a3825] text-white rounded-xl flex items-center space-x-2 font-semibold transition-colors">
                        <i data-lucide="check" class="w-4 h-4"></i>
                        <span>Lưu Thông Báo</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
