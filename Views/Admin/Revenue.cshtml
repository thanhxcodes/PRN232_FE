@model REVORA_MVC_FE.Models.ViewModels.RevenueStatsViewModel
@{
    ViewData["Title"] = "Quản Lý Doanh Thu";
    Layout = "_Layout";
    
    var filterType = ViewBag.FilterType as string ?? "month";
    var year = ViewBag.Year as int? ?? DateTime.Now.Year;
    var month = ViewBag.Month as int? ?? DateTime.Now.Month;
    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;

    var postingRevenue = Model.RevenueByPackages?.FirstOrDefault(p => p.PackageName == "Posting")?.Revenue ?? 0;
    var featuredRevenue = Model.RevenueByPackages?.FirstOrDefault(p => p.PackageName == "Featured")?.Revenue ?? 0;
}

<div class="mb-8">
    <div>
        <h2 class="text-[28px] font-bold text-gray-900 mb-1">Quản Lý Doanh Thu</h2>
        <p class="text-gray-500 text-[15px]">Theo dõi và phân tích nguồn thu chi tiết</p>
    </div>
</div>

<!-- Revenue Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-2xl shadow-lg p-6 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10">
            <i data-lucide="dollar-sign" class="w-32 h-32 transform translate-x-8 -translate-y-8"></i>
        </div>
        <div class="flex items-center justify-between mb-4 relative z-10">
            <div class="p-2 bg-white/20 rounded-xl">
                <i data-lucide="dollar-sign" class="w-6 h-6"></i>
            </div>
            <span class="text-sm bg-white/20 px-3 py-1.5 rounded-full font-medium shadow-sm backdrop-blur-sm @(Model.RevenueGrowth < 0 ? "text-red-100 bg-red-500/30" : "")">
                @(Model.RevenueGrowth > 0 ? "+" : "")@Model.RevenueGrowth% so với kỳ trước
            </span>
        </div>
        <div class="text-4xl font-bold mb-2 relative z-10 tracking-tight">@Model.TotalRevenue.ToString("N0")đ</div>
        <div class="text-sm text-green-100 font-medium relative z-10">Tổng Doanh Thu</div>
    </div>

    <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl shadow-lg p-6 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10">
            <i data-lucide="dollar-sign" class="w-32 h-32 transform translate-x-8 -translate-y-8"></i>
        </div>
        <div class="flex items-center justify-between mb-4 relative z-10">
            <div class="p-2 bg-white/20 rounded-xl">
                <i data-lucide="dollar-sign" class="w-6 h-6"></i>
            </div>
            <span class="text-sm bg-white/20 px-3 py-1.5 rounded-full font-medium shadow-sm backdrop-blur-sm">Posting</span>
        </div>
        <div class="text-4xl font-bold mb-2 relative z-10 tracking-tight">@postingRevenue.ToString("N0")đ</div>
        <div class="text-sm text-blue-100 font-medium relative z-10">Doanh Thu Gói Posting</div>
    </div>

    <div class="bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-2xl shadow-lg p-6 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10">
            <i data-lucide="dollar-sign" class="w-32 h-32 transform translate-x-8 -translate-y-8"></i>
        </div>
        <div class="flex items-center justify-between mb-4 relative z-10">
            <div class="p-2 bg-white/20 rounded-xl">
                <i data-lucide="dollar-sign" class="w-6 h-6"></i>
            </div>
            <span class="text-sm bg-white/20 px-3 py-1.5 rounded-full font-medium shadow-sm backdrop-blur-sm">Featured</span>
        </div>
        <div class="text-4xl font-bold mb-2 relative z-10 tracking-tight">@featuredRevenue.ToString("N0")đ</div>
        <div class="text-sm text-green-100/80 font-medium relative z-10">Doanh Thu Gói Featured</div>
    </div>
</div>

<!-- Revenue Chart -->
<div class="bg-white rounded-2xl shadow-sm p-6 mb-8 border border-gray-100">
    <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <i data-lucide="calendar" class="w-5 h-5 text-green-600"></i>
            Biểu Đồ Thống Kê
        </h3>
    </div>
    <div class="w-full overflow-x-auto">
        <div class="min-w-[600px] h-[380px]">
            <canvas id="revenueBarChart"></canvas>
        </div>
    </div>
</div>

<!-- Transactions Table -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div>
            <h3 class="text-[17px] font-bold text-gray-900">Chi Tiết Lịch Sử Giao Dịch</h3>
            <p class="text-[13px] text-gray-500 mt-0.5">@Model.Transactions.Count giao dịch</p>
        </div>
        
        <div class="flex flex-col sm:flex-row items-center gap-3">
            <div class="relative w-full sm:w-64">
                <i data-lucide="search" class="absolute left-3.5 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400"></i>
                <input type="text" placeholder="Tìm người dùng, mã GD..." class="w-full bg-transparent border border-gray-200 text-gray-900 py-2 pl-9 pr-4 rounded-full focus:outline-none focus:ring-1 focus:ring-gray-300 focus:border-gray-300 text-[13px] shadow-sm" />
            </div>
            
            <div class="relative w-full sm:w-auto min-w-[160px]">
                <select class="w-full bg-white border border-gray-700 text-gray-900 text-[13px] rounded-full focus:outline-none focus:ring-1 focus:ring-gray-700 focus:border-gray-700 block px-4 py-2 font-medium appearance-none pr-8 cursor-pointer shadow-sm">
                    <option value="newest" selected>Mới nhất</option>
                    <option value="highest">Chi tiêu nhiều nhất</option>
                </select>
                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-700">
                    <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
                </div>
            </div>
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full" id="txTable">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">MÃ GD</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">NGƯỜI DÙNG</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">GÓI CƯỚC</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">SỐ TIỀN</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">THỜI GIAN</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">TRẠNG THÁI</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Transactions == null || !Model.Transactions.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-10">
                            <div class="flex flex-col items-center justify-center text-gray-400">
                                <i data-lucide="dollar-sign" class="w-12 h-12 mb-2 opacity-20"></i>
                                <p class="font-medium">Không có giao dịch nào trong thời gian này</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var txn in Model.Transactions)
                    {
                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="py-4 px-6 text-sm font-semibold text-gray-900">@txn.Id</td>
                            <td class="py-4 px-6">
                                <div class="flex items-center space-x-3">
                                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] flex items-center justify-center text-white text-xs font-bold overflow-hidden shadow-sm ring-2 ring-white uppercase">
                                        @if (!string.IsNullOrEmpty(txn.AvatarUrl) && txn.AvatarUrl.StartsWith("http"))
                                        {
                                            <img src="@txn.AvatarUrl" alt="avatar" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            @((!string.IsNullOrEmpty(txn.FullName) ? txn.FullName : (!string.IsNullOrEmpty(txn.User) ? txn.User : "U")).Substring(0, 1))
                                        }
                                    </div>
                                    <div>
                                        <div class="text-sm font-bold text-gray-900">@(string.IsNullOrEmpty(txn.FullName) ? txn.User : txn.FullName)</div>
                                        <div class="text-xs text-gray-500 font-medium">@@@txn.User</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium @(txn.Package.Contains("Posting") ? "bg-blue-50 text-blue-700" : "bg-green-50 text-green-700")">
                                    @txn.Package
                                </span>
                            </td>
                            <td class="py-4 px-6 text-sm font-bold text-gray-900">@txn.Amount.ToString("N0")đ</td>
                            <td class="py-4 px-6 text-sm text-gray-500">@txn.Date</td>
                            <td class="py-4 px-6">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                    @txn.Status
                                </span>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

    <script>
        function toggleFilters() {
            var filterType = document.getElementById('filterType').value;
            document.getElementById('monthFilter').style.display = filterType === 'month' ? 'block' : 'none';
            document.getElementById('yearFilter').style.display = (filterType === 'year' || filterType === 'month') ? 'block' : 'none';
            document.getElementById('customFilter').style.display = filterType === 'custom' ? 'flex' : 'none';
        }

        function exportExcel() {
            var table = document.getElementById("txTable");
            if(table) {
                var wb = XLSX.utils.table_to_book(table, {sheet:"Giao Dịch"});
                XLSX.writeFile(wb, "BaoCaoDoanhThu.xlsx");
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const chartData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData));
            if(chartData && chartData.length > 0) {
                const labels = chartData.map(d => d.Label);
                const postingData = chartData.map(d => d.Posting);
                const featuredData = chartData.map(d => d.Featured);

                const ctx = document.getElementById('revenueBarChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [
                            {
                                label: 'Gói Posting',
                                data: postingData,
                                backgroundColor: '#3B82F6',
                                borderRadius: { topLeft: 4, topRight: 4 },
                                maxBarThickness: 40
                            },
                            {
                                label: 'Gói Featured',
                                data: featuredData,
                                backgroundColor: '#2D5A3D',
                                borderRadius: { topLeft: 4, topRight: 4 },
                                maxBarThickness: 40
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: '#f0f0f0', drawBorder: false },
                                ticks: {
                                    callback: function(value) {
                                        return (value / 1000000).toFixed(1) + 'M';
                                    }
                                }
                            },
                            x: {
                                grid: { display: false, drawBorder: false }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
