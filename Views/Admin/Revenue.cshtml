@{
    ViewData["Title"] = "Quản Lý Doanh Thu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <div class="flex flex-col xl:flex-row xl:items-center justify-between gap-6">
        <div>
            <h2 class="text-3xl text-gray-900 mb-2">Quản Lý Doanh Thu</h2>
            <p class="text-gray-600">Theo dõi và phân tích nguồn thu chi tiết</p>
        </div>
        <div class="flex flex-wrap items-center gap-3 bg-white p-2 rounded-xl shadow-sm border border-gray-100">

            <!-- Loại Bộ Lọc -->
            <div class="relative">
                <select class="appearance-none bg-gray-50 border border-gray-200 text-gray-700 py-2 pl-10 pr-8 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent text-sm font-medium">
                    <option value="year">Theo Năm</option>
                    <option value="month" selected>Theo Tháng</option>
                    <option value="custom">Tùy Chỉnh Khoảng Ngày</option>
                </select>
                <i data-lucide="filter" class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-500"></i>
            </div>

            <!-- Các Điều Kiện Lọc Tương Ứng -->
            <div class="flex items-center gap-3 border-l border-gray-200 pl-3">
                <select class="bg-gray-50 border border-gray-200 text-gray-700 py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent text-sm font-medium">
                    <option value="1">Tháng 1</option>
                    <option value="2">Tháng 2</option>
                    <option value="3">Tháng 3</option>
                    <option value="4">Tháng 4</option>
                    <option value="5">Tháng 5</option>
                    <option value="6" selected>Tháng 6</option>
                    <option value="7">Tháng 7</option>
                    <option value="8">Tháng 8</option>
                    <option value="9">Tháng 9</option>
                    <option value="10">Tháng 10</option>
                    <option value="11">Tháng 11</option>
                    <option value="12">Tháng 12</option>
                </select>
                <select class="bg-gray-50 border border-gray-200 text-gray-700 py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent text-sm font-medium">
                    <option value="2024">Năm 2024</option>
                    <option value="2025">Năm 2025</option>
                    <option value="2026" selected>Năm 2026</option>
                </select>
            </div>

            <div class="border-l border-gray-200 pl-3">
                <button class="flex items-center space-x-2 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white px-5 py-2 rounded-lg hover:shadow-md transition-all text-sm font-medium">
                    <i data-lucide="download" class="w-4 h-4"></i>
                    <span>Xuất Excel</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Revenue Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-2xl shadow-lg p-6 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10">
            <i data-lucide="dollar-sign" class="w-32 h-32 transform translate-x-8 -translate-y-8"></i>
        </div>
        <div class="flex items-center justify-between mb-4 relative z-10">
            <div class="p-2 bg-white/20 rounded-xl">
                <i data-lucide="dollar-sign" class="w-6 h-6"></i>
            </div>
            <span class="text-sm bg-white/20 px-3 py-1.5 rounded-full font-medium shadow-sm backdrop-blur-sm">
                +15% so với kỳ trước
            </span>
        </div>
        <div class="text-4xl font-bold mb-2 relative z-10 tracking-tight">120.500.000đ</div>
        <div class="text-sm text-green-100 font-medium relative z-10">Tổng Doanh Thu Tháng 6/2026</div>
    </div>

    <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl shadow-lg p-6 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10">
            <i data-lucide="dollar-sign" class="w-32 h-32 transform translate-x-8 -translate-y-8"></i>
        </div>
        <div class="flex items-center justify-between mb-4 relative z-10">
            <div class="p-2 bg-white/20 rounded-xl">
                <i data-lucide="dollar-sign" class="w-6 h-6"></i>
            </div>
            <span class="text-sm bg-white/20 px-3 py-1.5 rounded-full font-medium shadow-sm backdrop-blur-sm">Posting</span>
        </div>
        <div class="text-4xl font-bold mb-2 relative z-10 tracking-tight">70.000.000đ</div>
        <div class="text-sm text-blue-100 font-medium relative z-10">Doanh Thu Gói Posting</div>
    </div>

    <div class="bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-2xl shadow-lg p-6 text-white relative overflow-hidden">
        <div class="absolute right-0 top-0 opacity-10">
            <i data-lucide="dollar-sign" class="w-32 h-32 transform translate-x-8 -translate-y-8"></i>
        </div>
        <div class="flex items-center justify-between mb-4 relative z-10">
            <div class="p-2 bg-white/20 rounded-xl">
                <i data-lucide="dollar-sign" class="w-6 h-6"></i>
            </div>
            <span class="text-sm bg-white/20 px-3 py-1.5 rounded-full font-medium shadow-sm backdrop-blur-sm">Featured</span>
        </div>
        <div class="text-4xl font-bold mb-2 relative z-10 tracking-tight">50.500.000đ</div>
        <div class="text-sm text-green-100/80 font-medium relative z-10">Doanh Thu Gói Featured</div>
    </div>
</div>

<!-- Revenue Chart Area (Mock placeholder) -->
<div class="bg-white rounded-2xl shadow-sm p-6 mb-8 border border-gray-100">
    <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-bold text-gray-900 flex items-center gap-2">
            <i data-lucide="calendar" class="w-5 h-5 text-green-600"></i>
            Biểu Đồ Thống Kê Tháng 6/2026
        </h3>
    </div>
    <div class="w-full overflow-x-auto">
        <div class="min-w-[600px] h-[380px] bg-gray-50 rounded-xl border border-dashed border-gray-200 flex items-center justify-center text-gray-400">
            <span>(Biểu đồ Recharts sẽ được render bằng JS, ở đây hiển thị placeholder UI tĩnh)</span>
        </div>
    </div>
</div>

<!-- Transactions Table -->
<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-lg font-bold text-gray-900">Chi Tiết Lịch Sử Giao Dịch</h3>
        <span class="text-sm text-gray-500 font-medium">10 giao dịch</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="bg-gray-50/50">
                    <th class="text-left py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Mã GD</th>
                    <th class="text-left py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Người Dùng</th>
                    <th class="text-left py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Gói Cước</th>
                    <th class="text-left py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Số Tiền</th>
                    <th class="text-left py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Thời Gian</th>
                    <th class="text-left py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Trạng Thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50/80 transition-colors">
                    <td class="py-4 px-6 text-sm font-semibold text-gray-900">TXN-001</td>
                    <td class="py-4 px-6 text-sm text-gray-600">nguyenvana</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                            Posting
                        </span>
                    </td>
                    <td class="py-4 px-6 text-sm font-bold text-gray-900">50.000đ</td>
                    <td class="py-4 px-6 text-sm text-gray-500">05/06/2026 14:30</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            Thành công
                        </span>
                    </td>
                </tr>
                <tr class="hover:bg-gray-50/80 transition-colors">
                    <td class="py-4 px-6 text-sm font-semibold text-gray-900">TXN-002</td>
                    <td class="py-4 px-6 text-sm text-gray-600">tranvanb</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                            Featured
                        </span>
                    </td>
                    <td class="py-4 px-6 text-sm font-bold text-gray-900">200.000đ</td>
                    <td class="py-4 px-6 text-sm text-gray-500">06/06/2026 09:15</td>
                    <td class="py-4 px-6">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            Thành công
                        </span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
