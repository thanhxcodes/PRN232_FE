@model List<REVORA_MVC_FE.Models.ViewModels.CreditPackageViewModel>
@{
    ViewData["Title"] = "Quản Lý Gói Tín Dụng";
    Layout = "_Layout";
    
    var postingPackages = Model?.Where(p => (p.CreditTypeName ?? p.Name).Contains("Post", StringComparison.OrdinalIgnoreCase) || p.Name.Contains("Đăng")).ToList() ?? new List<REVORA_MVC_FE.Models.ViewModels.CreditPackageViewModel>();
    var featuredPackages = Model?.Where(p => (p.CreditTypeName ?? p.Name).Contains("Feature", StringComparison.OrdinalIgnoreCase) || p.Name.Contains("Nổi bật")).ToList() ?? new List<REVORA_MVC_FE.Models.ViewModels.CreditPackageViewModel>();
}

<div class="">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-900 flex items-center gap-3">
            <i data-lucide="sparkles" class="w-8 h-8 text-[#2D5A3D]"></i>
            Quản Lý Gói Tín Dụng
        </h1>
        <p class="text-gray-500 mt-2">Đồng bộ với giao diện hiển thị cho người dùng.</p>
    </div>

    <div class="space-y-16">
        <!-- GÓI ĐĂNG TIN -->
        <section>
            <div class="text-center mb-8">
                <h2 class="text-3xl font-bold text-gray-900 mb-2">Gói Đăng Tin</h2>
                <p class="text-gray-500">Giúp người bán tăng số lượng tin đăng tiêu chuẩn</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                @if (!postingPackages.Any())
                {
                    <div class="col-span-full text-center text-gray-400 py-10">Chưa có gói đăng tin nào.</div>
                }
                else
                {
                    foreach (var pkg in postingPackages)
                    {
                        <div class="relative bg-white rounded-3xl shadow-lg p-8 hover:shadow-2xl transition-all border border-gray-100 flex flex-col">
                            <div class="absolute top-6 right-6">
                                <span class="bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-xs font-bold">
                                    Đăng Tin
                                </span>
                            </div>

                            <h3 class="text-2xl font-bold text-gray-900 mb-2">@pkg.Name</h3>
                            <div class="flex items-baseline gap-2 mb-6">
                                @if (pkg.DiscountRate > 0)
                                {
                                    <span class="text-4xl font-black text-gray-900">@pkg.DiscountedPrice.ToString("N0")đ</span>
                                    <span class="text-lg text-gray-400 line-through">@pkg.OriginalPrice.ToString("N0")đ</span>
                                }
                                else
                                {
                                    <span class="text-4xl font-black text-gray-900">@pkg.OriginalPrice.ToString("N0")đ</span>
                                }
                            </div>

                            <div class="bg-blue-50/50 rounded-2xl p-4 mb-8">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-white rounded-xl shadow-sm flex items-center justify-center">
                                        <span class="font-bold text-blue-600">+@pkg.CreditAmount</span>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-gray-900">Credits @(pkg.CreditTypeName ?? "Đăng Tin")</p>
                                        <p class="text-sm text-gray-500">HSD: @(pkg.DurationDays.HasValue ? $"{pkg.DurationDays} ngày" : "Vĩnh viễn")</p>
                                    </div>
                                </div>
                            </div>

                            <ul class="space-y-4 mb-8 flex-1">
                                @if (pkg.Descriptions != null && pkg.Descriptions.Any())
                                {
                                    foreach (var desc in pkg.Descriptions)
                                    {
                                        <li class="flex items-start gap-3">
                                            <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                                <i data-lucide="check" class="w-4 h-4 text-emerald-600"></i>
                                            </div>
                                            <span class="text-gray-600 leading-relaxed">@desc</span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="flex items-start gap-3">
                                        <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                            <i data-lucide="check" class="w-4 h-4 text-emerald-600"></i>
                                        </div>
                                        <span class="text-gray-600 leading-relaxed">Nhận @pkg.CreditAmount credits</span>
                                    </li>
                                }
                            </ul>

                            <button onclick="editPackage(@pkg.PaidCreditPackageId)" class="w-full py-4 px-6 rounded-xl font-bold flex items-center justify-center space-x-2 bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors mt-auto">
                                <i data-lucide="edit-2" class="w-5 h-5"></i>
                                <span>Chỉnh Sửa Gói</span>
                            </button>
                        </div>
                    }
                }
            </div>
        </section>

        <!-- GÓI NỔI BẬT -->
        <section>
            <div class="text-center mb-8">
                <h2 class="text-3xl font-bold text-gray-900 mb-2">Gói Nổi Bật</h2>
                <p class="text-gray-500">Tiếp cận hàng ngàn khách hàng tiềm năng</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                @if (!featuredPackages.Any())
                {
                    <div class="col-span-full text-center text-gray-400 py-10">Chưa có gói nổi bật nào.</div>
                }
                else
                {
                    foreach (var pkg in featuredPackages)
                    {
                        <div class="relative bg-white rounded-3xl shadow-lg p-8 hover:shadow-2xl transition-all border border-gray-100 flex flex-col">
                            <div class="absolute top-6 right-6">
                                <span class="bg-orange-100 text-[#C4603A] px-4 py-1.5 rounded-full text-xs font-bold">
                                    Nổi Bật
                                </span>
                            </div>

                            <h3 class="text-2xl font-bold text-gray-900 mb-2">@pkg.Name</h3>
                            <div class="flex items-baseline gap-2 mb-6">
                                @if (pkg.DiscountRate > 0)
                                {
                                    <span class="text-4xl font-black text-gray-900">@pkg.DiscountedPrice.ToString("N0")đ</span>
                                    <span class="text-lg text-gray-400 line-through">@pkg.OriginalPrice.ToString("N0")đ</span>
                                }
                                else
                                {
                                    <span class="text-4xl font-black text-gray-900">@pkg.OriginalPrice.ToString("N0")đ</span>
                                }
                            </div>

                            <div class="bg-orange-50/50 rounded-2xl p-4 mb-8">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 bg-white rounded-xl shadow-sm flex items-center justify-center">
                                        <span class="font-bold text-[#C4603A]">+@pkg.CreditAmount</span>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-gray-900">Credits @(pkg.CreditTypeName ?? "Nổi Bật")</p>
                                        <p class="text-sm text-gray-500">HSD: @(pkg.DurationDays.HasValue ? $"{pkg.DurationDays} ngày" : "Vĩnh viễn")</p>
                                    </div>
                                </div>
                            </div>

                            <ul class="space-y-4 mb-8 flex-1">
                                @if (pkg.Descriptions != null && pkg.Descriptions.Any())
                                {
                                    foreach (var desc in pkg.Descriptions)
                                    {
                                        <li class="flex items-start gap-3">
                                            <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                                <i data-lucide="check" class="w-4 h-4 text-emerald-600"></i>
                                            </div>
                                            <span class="text-gray-600 leading-relaxed">@desc</span>
                                        </li>
                                    }
                                }
                                else
                                {
                                    <li class="flex items-start gap-3">
                                        <div class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                            <i data-lucide="check" class="w-4 h-4 text-emerald-600"></i>
                                        </div>
                                        <span class="text-gray-600 leading-relaxed">Nhận @pkg.CreditAmount credits</span>
                                    </li>
                                }
                            </ul>

                            <button onclick="editPackage(@pkg.PaidCreditPackageId)" class="w-full py-4 px-6 rounded-xl font-bold flex items-center justify-center space-x-2 bg-gray-100 text-gray-700 hover:bg-gray-200 transition-colors mt-auto">
                                <i data-lucide="edit-2" class="w-5 h-5"></i>
                                <span>Chỉnh Sửa Gói</span>
                            </button>
                        </div>
                    }
                }
            </div>
        </section>
    </div>
</div>

<!-- Modal Edit Package -->
<div id="editModal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-gray-900">Chỉnh Sửa Gói</h3>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600">
                <i data-lucide="x" class="w-6 h-6"></i>
            </button>
        </div>
        <form method="post" action="/Admin/UpdatePackage" id="editForm">
            <input type="hidden" name="id" id="pkgId" />
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tên gói</label>
                    <input type="text" name="name" id="pkgName" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 focus:ring-2 focus:ring-green-500" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Giá cũ (đ)</label>
                    <input type="number" name="originalPrice" id="pkgOriginalPrice" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 focus:ring-2 focus:ring-green-500" required />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Giá mới (đ)</label>
                    <input type="number" name="discountedPrice" id="pkgDiscountedPrice" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 focus:ring-2 focus:ring-green-500" required />
                </div>
            </div>
            <div class="mt-8 flex justify-end gap-3">
                <button type="button" onclick="closeModal()" class="px-5 py-2 rounded-lg font-medium text-gray-600 hover:bg-gray-100">Hủy</button>
                <button type="submit" class="px-5 py-2 rounded-lg font-medium bg-[#2D5A3D] text-white hover:shadow-lg">Cập Nhật</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Note: For a fully functioning modal, we would fetch the package details or read from data attributes.
        // This is a minimal JS logic to toggle visibility as requested.
        function editPackage(id) {
            document.getElementById('pkgId').value = id;
            document.getElementById('editModal').classList.remove('hidden');
            // Typically you'd populate the inputs here
        }
        function closeModal() {
            document.getElementById('editModal').classList.add('hidden');
        }
    </script>
}
