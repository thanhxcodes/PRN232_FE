@{
    ViewData["Title"] = "Quản Lý Người Dùng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between">
    <div>
        <h2 class="text-3xl text-gray-900 mb-2 font-bold tracking-tight">Quản Lý Người Dùng</h2>
        <p class="text-gray-600">Theo dõi, quản lý trạng thái và phân quyền tài khoản thành viên</p>
    </div>
    <div class="mt-4 md:mt-0 flex items-center bg-[#2D5A3D]/5 text-[#2D5A3D] px-4 py-2 rounded-xl border border-[#2D5A3D]/10 font-medium text-sm">
        <i data-lucide="shield" class="w-4 h-4 mr-2"></i>
        Quyền: Administrator
    </div>
</div>

<!-- Search & Filter -->
<div class="bg-white rounded-2xl shadow-sm p-6 mb-8 border border-gray-100 transition-all hover:shadow-md">
    <div class="flex flex-col md:flex-row items-center space-y-4 md:space-y-0 md:space-x-4">
        <div class="flex-1 relative w-full group">
            <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400 group-focus-within:text-[#2D5A3D] transition-colors"></i>
            <input type="text" placeholder="Tìm kiếm theo tên, email..." class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-all bg-gray-50 hover:bg-white text-gray-800 font-medium" />
        </div>
        <select class="w-full md:w-48 px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] transition-all bg-gray-50 hover:bg-white cursor-pointer text-gray-700 font-medium">
            <option value="all">Tất cả trạng thái</option>
            <option value="active">Đang hoạt động</option>
            <option value="suspended">Bị khóa</option>
        </select>
    </div>
</div>

<!-- Users Table -->
<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100 bg-gray-50/80 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">
                    <th class="py-5 px-6">Người Dùng</th>
                    <th class="py-5 px-6">Email</th>
                    <th class="py-5 px-6">Chức Vụ</th>
                    <th class="py-5 px-6">Ngày Tham Gia</th>
                    <th class="py-5 px-6">Lượt GD</th>
                    <th class="py-5 px-6">Trạng Thái</th>
                    <th class="py-5 px-6 text-right">Thao Tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                <!-- Mock Data Row 1 (Active) -->
                <tr class="hover:bg-green-50/30 transition-colors group">
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-2xl shadow-sm flex items-center justify-center text-white text-base font-bold uppercase overflow-hidden ring-4 ring-white group-hover:ring-green-50 transition-all">
                                NV
                            </div>
                            <div>
                                <div class="text-sm text-gray-900 font-bold">Nguyễn Văn A</div>
                                <div class="text-xs text-gray-500 font-medium mt-0.5">@@nguyenvana</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-600 font-medium">nguyenvana@gmail.com</td>
                    <td class="py-4 px-6">
                        <span class="text-xs px-3 py-1.5 rounded-lg font-bold flex items-center w-fit bg-gray-50 text-gray-700 border border-gray-200">
                            User
                        </span>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-500 font-medium">01/01/2026</td>
                    <td class="py-4 px-6 text-sm font-bold text-[#2D5A3D] bg-green-50/30">
                        15 <span class="text-xs font-normal text-gray-400">lượt</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-green-50 border border-green-200 text-green-700 text-xs px-3 py-1.5 rounded-xl flex items-center space-x-1.5 w-fit font-bold shadow-sm">
                            <i data-lucide="check" class="w-3.5 h-3.5"></i>
                            <span>Hoạt động</span>
                        </span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center justify-end space-x-2">
                            <button class="flex items-center space-x-1 text-gray-600 bg-gray-50 border border-gray-200 hover:bg-gray-100 hover:border-gray-300 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Xem chi tiết">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                                <span>Xem</span>
                            </button>
                            <button class="flex items-center space-x-1.5 text-red-600 bg-white border border-red-100 hover:bg-red-50 hover:border-red-200 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Khóa tài khoản này">
                                <i data-lucide="ban" class="w-4 h-4"></i>
                                <span>Khóa</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <!-- Mock Data Row 2 (Admin) -->
                <tr class="hover:bg-green-50/30 transition-colors group">
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-2xl shadow-sm flex items-center justify-center text-white text-base font-bold uppercase overflow-hidden ring-4 ring-white group-hover:ring-green-50 transition-all">
                                AD
                            </div>
                            <div>
                                <div class="text-sm text-gray-900 font-bold">Admin User</div>
                                <div class="text-xs text-gray-500 font-medium mt-0.5">@@admin</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-600 font-medium">admin@revora.com</td>
                    <td class="py-4 px-6">
                        <span class="text-xs px-3 py-1.5 rounded-lg font-bold flex items-center w-fit bg-purple-50 text-purple-700 border border-purple-100">
                            <i data-lucide="shield" class="w-3 h-3 mr-1"></i>
                            Admin
                        </span>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-500 font-medium">10/10/2025</td>
                    <td class="py-4 px-6 text-sm font-bold text-[#2D5A3D] bg-green-50/30">
                        0 <span class="text-xs font-normal text-gray-400">lượt</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-green-50 border border-green-200 text-green-700 text-xs px-3 py-1.5 rounded-xl flex items-center space-x-1.5 w-fit font-bold shadow-sm">
                            <i data-lucide="check" class="w-3.5 h-3.5"></i>
                            <span>Hoạt động</span>
                        </span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center justify-end space-x-2">
                            <button class="flex items-center space-x-1 text-gray-600 bg-gray-50 border border-gray-200 hover:bg-gray-100 hover:border-gray-300 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Xem chi tiết">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                                <span>Xem</span>
                            </button>
                        </div>
                    </td>
                </tr>

                 <!-- Mock Data Row 3 (Banned) -->
                <tr class="hover:bg-green-50/30 transition-colors group">
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-gradient-to-br from-red-600 to-red-500 rounded-2xl shadow-sm flex items-center justify-center text-white text-base font-bold uppercase overflow-hidden ring-4 ring-white group-hover:ring-red-50 transition-all">
                                TV
                            </div>
                            <div>
                                <div class="text-sm text-gray-900 font-bold">Trần Vi Phạm</div>
                                <div class="text-xs text-gray-500 font-medium mt-0.5">@@tranvipham</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-600 font-medium">tranvipham@gmail.com</td>
                    <td class="py-4 px-6">
                        <span class="text-xs px-3 py-1.5 rounded-lg font-bold flex items-center w-fit bg-gray-50 text-gray-700 border border-gray-200">
                            User
                        </span>
                    </td>
                    <td class="py-4 px-6 text-sm text-gray-500 font-medium">01/05/2026</td>
                    <td class="py-4 px-6 text-sm font-bold text-[#2D5A3D] bg-green-50/30">
                        2 <span class="text-xs font-normal text-gray-400">lượt</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="bg-red-50 border border-red-200 text-red-700 text-xs px-3 py-1.5 rounded-xl flex items-center space-x-1.5 w-fit font-bold shadow-sm">
                            <i data-lucide="ban" class="w-3.5 h-3.5"></i>
                            <span>Bị khóa</span>
                        </span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center justify-end space-x-2">
                            <button class="flex items-center space-x-1 text-gray-600 bg-gray-50 border border-gray-200 hover:bg-gray-100 hover:border-gray-300 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Xem chi tiết">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                                <span>Xem</span>
                            </button>
                            <button class="flex items-center space-x-1.5 text-[#2D5A3D] bg-white border border-green-100 hover:bg-green-50 hover:border-green-200 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Mở khóa tài khoản này">
                                <i data-lucide="shield" class="w-4 h-4"></i>
                                <span>Mở khóa</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="flex flex-col sm:flex-row items-center justify-between px-8 py-5 bg-gray-50/80 border-t border-gray-100">
        <div class="text-sm text-gray-500 font-medium mb-4 sm:mb-0 bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-100">
            Tổng cộng <span class="text-[#2D5A3D] font-bold text-base mx-1">3</span> người dùng
        </div>
        <div class="flex items-center space-x-2">
            <button disabled class="px-4 py-2 border border-gray-200 bg-white rounded-xl text-sm font-bold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-sm hover:shadow active:scale-95">
                Trước
            </button>
            <div class="flex items-center space-x-1">
                <button class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all shadow-sm active:scale-95 bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] text-white border-transparent shadow-md">
                    1
                </button>
            </div>
            <button disabled class="px-4 py-2 border border-gray-200 bg-white rounded-xl text-sm font-bold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-sm hover:shadow active:scale-95">
                Sau
            </button>
        </div>
    </div>
</div>
