@model REVORA_MVC_FE.Models.ViewModels.AdminUserPagedResult
@{
    ViewData["Title"] = "Quản Lý Người Dùng";
    Layout = "_Layout";
    var currentFilter = ViewBag.StatusFilter as string ?? "all";
    var search = ViewBag.Search as string ?? "";
}

<div class="mb-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-8">
        <div>
            <h2 class="text-[28px] font-bold text-gray-900 mb-1">Quản Lý Người Dùng</h2>
            <p class="text-gray-500 text-[15px]">Theo dõi, quản lý trạng thái và phân quyền tài khoản thành viên</p>
        </div>
        <div class="flex items-center gap-3">
            <div class="bg-gray-50 text-gray-700 px-4 py-2 rounded-full text-sm font-medium border border-gray-200 flex items-center gap-2">
                <i data-lucide="shield" class="w-4 h-4 text-green-600"></i>
                Quyền: Administrator
            </div>
        </div>
    </div>

    <!-- Filters & Search -->
    <form method="get" action="/Admin/Users" class="bg-white p-2 rounded-full shadow-sm border border-gray-100 flex items-center justify-between gap-4 mb-6">
        <!-- Search input -->
        <div class="flex-1 relative flex items-center pl-2">
            <i data-lucide="search" class="absolute left-4 w-4 h-4 text-gray-400"></i>
            <input type="text" name="search" value="@search" placeholder="Tìm kiếm theo tên, email..." class="w-full bg-transparent border-none text-gray-900 py-2.5 pl-10 pr-4 focus:outline-none focus:ring-0 text-[15px]" />
        </div>
        
        <!-- Status Dropdown -->
        <div class="flex items-center gap-2 pr-2">
            <select name="statusFilter" id="statusFilter" onchange="this.form.submit()" class="bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-full focus:ring-green-500 focus:border-green-500 block px-4 py-2 font-medium appearance-none pr-10 relative cursor-pointer outline-none">
                <option value="all" selected="@(currentFilter == "all")">Tất cả trạng thái</option>
                <option value="active" selected="@(currentFilter == "active")">Đang Hoạt Động</option>
                <option value="suspended" selected="@(currentFilter == "suspended")">Bị Khóa</option>
            </select>
        </div>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium flex items-center gap-2">
        <i data-lucide="check-circle" class="w-5 h-5"></i>
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm font-medium flex items-center gap-2">
        <i data-lucide="alert-triangle" class="w-5 h-5"></i>
        @TempData["ErrorMessage"]
    </div>
}

<div class="bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100">
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">NGƯỜI DÙNG</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">EMAIL</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">CHỨC VỤ</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">NGÀY THAM GIA</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">LƯỢT GD</th>
                    <th class="text-left py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">TRẠNG THÁI</th>
                    <th class="text-center py-5 px-6 text-xs font-bold text-gray-500 uppercase tracking-widest whitespace-nowrap">THAO TÁC</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @if (Model.Items == null || !Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-10">
                            <div class="flex flex-col items-center justify-center text-gray-400">
                                <i data-lucide="users" class="w-12 h-12 mb-2 opacity-20"></i>
                                <p class="font-medium">Không tìm thấy người dùng nào</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var user in Model.Items)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="py-4 px-6 whitespace-nowrap">
                                <div class="flex items-center space-x-3">
                                    <div class="w-10 h-10 rounded-full overflow-hidden bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] flex items-center justify-center text-white font-bold text-sm shadow-sm">
                                        @if (!string.IsNullOrEmpty(user.AvatarUrl) && user.AvatarUrl.StartsWith("http"))
                                        {
                                            <img src="@user.AvatarUrl" alt="avatar" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            @((!string.IsNullOrEmpty(user.FullName) ? user.FullName : user.Username).Substring(0, 1).ToUpper())
                                        }
                                    </div>
                                    <div>
                                        <div class="font-bold text-[14px] text-gray-900">@(string.IsNullOrEmpty(user.FullName) ? user.Username : user.FullName)</div>
                                        <div class="text-[13px] text-gray-500 font-medium mt-0.5">@@@user.Username</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-[14px] text-gray-700 font-medium whitespace-nowrap">
                                @user.Email
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold border @(user.RoleName.ToUpper() == "ADMIN" ? "bg-purple-50 text-purple-700 border-purple-200" : "bg-gray-50 text-gray-600 border-gray-200")">
                                    @user.RoleName
                                </span>
                            </td>
                            <td class="py-4 px-6 text-[14px] text-gray-700 font-medium whitespace-nowrap">
                                @user.CreatedAt.ToString("d/M/yyyy")
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap">
                                <div class="flex items-center gap-1.5 text-[14px] font-bold text-gray-900">
                                    @user.TradeSuccessCount <span class="text-gray-500 font-normal">lượt</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap">
                                @if (user.IsActive)
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[13px] font-bold bg-green-50 text-green-700 border border-green-200 shadow-sm">
                                        <i data-lucide="check" class="w-3.5 h-3.5"></i>
                                        Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[13px] font-bold bg-red-50 text-red-600 border border-red-200 shadow-sm">
                                        <i data-lucide="ban" class="w-3.5 h-3.5"></i>
                                        Bị Khóa
                                    </span>
                                }
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap text-center">
                                <div class="flex items-center justify-center space-x-2">
                                    <button onclick="openUserDetailModal(@user.UserId, '@(user.FullName ?? user.Username)', '@user.Username', '@user.Email', '@(user.AvatarUrl ?? "")', '@user.CreatedAt.ToString("d/M/yyyy")', @user.IsActive.ToString().ToLower(), '@user.RoleName')" class="px-3 py-1.5 text-gray-600 bg-white border border-gray-200 hover:bg-gray-50 hover:text-gray-900 rounded-lg transition-all text-sm font-bold shadow-sm flex items-center gap-1.5">
                                        <i data-lucide="eye" class="w-4 h-4"></i> Xem
                                    </button>
                                    @if (user.RoleName.ToUpper() != "ADMIN")
                                    {
                                        if (user.IsActive)
                                        {
                                            <button onclick="openStatusModal(@user.UserId, true, '@(user.Username)')" class="px-3 py-1.5 text-red-600 bg-white border border-red-100 hover:bg-red-50 hover:border-red-200 rounded-lg transition-all text-sm font-bold shadow-sm flex items-center gap-1.5">
                                                <i data-lucide="ban" class="w-4 h-4"></i> Khóa
                                            </button>
                                        }
                                        else
                                        {
                                            <button onclick="openStatusModal(@user.UserId, false, '@(user.Username)')" class="px-3 py-1.5 text-[#2D5A3D] bg-white border border-green-100 hover:bg-green-50 hover:border-green-200 rounded-lg transition-all text-sm font-bold shadow-sm flex items-center gap-1.5">
                                                <i data-lucide="shield" class="w-4 h-4"></i> Mở Khóa
                                            </button>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    
    @if (Model.TotalPages > 1)
    {
        <div class="flex flex-col sm:flex-row items-center justify-between px-8 py-5 bg-gray-50/80 border-t border-gray-100">
            <div class="text-sm text-gray-500 font-medium mb-4 sm:mb-0 bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-100">
                Tổng cộng <span class="text-[#2D5A3D] font-bold text-base mx-1">@Model.TotalCount</span> người dùng
            </div>
            <div class="flex items-center space-x-2">
                <a href="@(Model.CurrentPage > 1 ? $"/Admin/Users?page={Model.CurrentPage - 1}&search={Uri.EscapeDataString(search)}&statusFilter={currentFilter}" : "javascript:void(0)")" 
                   class="px-4 py-2 border border-gray-200 bg-white rounded-xl text-sm font-bold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all shadow-sm hover:shadow active:scale-95 @(Model.CurrentPage == 1 ? "opacity-50 cursor-not-allowed pointer-events-none" : "")">
                    Trước
                </a>
                
                <div class="flex items-center space-x-1">
                    @{
                        int startPage = Math.Max(1, Model.CurrentPage - 2);
                        int endPage = Math.Min(Model.TotalPages, startPage + 4);
                        if (endPage - startPage < 4) {
                            startPage = Math.Max(1, endPage - 4);
                        }
                    }
                    @for (int p = startPage; p <= endPage; p++)
                    {
                        <a href="/Admin/Users?page=@p&search=@Uri.EscapeDataString(search)&statusFilter=@currentFilter" 
                           class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all shadow-sm active:scale-95 @(p == Model.CurrentPage ? "bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] text-white border-transparent shadow-md" : "border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-[#2D5A3D]")">
                            @p
                        </a>
                    }
                </div>
                
                <a href="@(Model.CurrentPage < Model.TotalPages ? $"/Admin/Users?page={Model.CurrentPage + 1}&search={Uri.EscapeDataString(search)}&statusFilter={currentFilter}" : "javascript:void(0)")" 
                   class="px-4 py-2 border border-gray-200 bg-white rounded-xl text-sm font-bold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all shadow-sm hover:shadow active:scale-95 @(Model.CurrentPage == Model.TotalPages ? "opacity-50 cursor-not-allowed pointer-events-none" : "")">
                    Sau
                </a>
            </div>
        </div>
    }
</div>

<!-- Modal Toggle Status -->
<div id="statusModal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-3xl shadow-xl w-full max-w-md p-6">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-xl font-bold text-gray-900" id="statusModalTitle">Xác nhận thao tác</h3>
            <button type="button" onclick="closeStatusModal()" class="text-gray-400 hover:text-gray-600 bg-gray-50 hover:bg-gray-100 p-2 rounded-full transition-colors">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>
        <form method="post" action="/Admin/ToggleUserStatus" id="statusForm">
            <input type="hidden" name="userId" id="modalUserId" />
            <input type="hidden" name="isBanning" id="modalIsBanning" />
            
            <p class="text-gray-600 mb-6 text-[15px]" id="statusModalMessage"></p>
            
            <div class="space-y-4 mb-8" id="reasonGroup">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">Lý do khóa tài khoản <span class="text-red-500">*</span></label>
                    <textarea name="reason" id="modalReason" rows="3" placeholder="Nhập lý do chi tiết..." class="w-full bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] outline-none text-[15px] resize-none"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3">
                <button type="button" onclick="closeStatusModal()" class="px-6 py-2.5 rounded-full font-bold text-gray-600 bg-gray-100 hover:bg-gray-200 transition-colors">Hủy</button>
                <button type="submit" id="statusModalBtn" class="px-6 py-2.5 rounded-full font-bold text-white shadow-lg transition-transform hover:scale-105 active:scale-95">Xác nhận</button>
            </div>
        </form>
    </div>
</div>

<!-- User Detail Modal -->
<div id="userDetailModal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-gray-900/40 backdrop-blur-sm p-4 sm:p-6 transition-opacity">
    <div class="bg-white rounded-[24px] shadow-2xl w-full max-w-[800px] max-h-[90vh] flex flex-col overflow-hidden animate-in fade-in zoom-in-95 duration-200">
        <!-- Header -->
        <div class="relative pt-8 pb-6 px-8 border-b border-gray-100 bg-gradient-to-b from-slate-50 to-white">
            <button type="button" onclick="closeUserDetailModal()" class="absolute top-6 right-6 p-2 bg-white hover:bg-gray-100 rounded-full transition-colors text-gray-400 hover:text-gray-600 shadow-sm border border-gray-100">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
            <div class="flex items-start space-x-5">
                <div id="udm-avatar-container" class="w-16 h-16 bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-2xl flex items-center justify-center text-white text-xl font-bold uppercase overflow-hidden shadow-md ring-4 ring-green-50">
                    <span id="udm-avatar-text"></span>
                    <img id="udm-avatar-img" src="" alt="avatar" class="w-full h-full object-cover hidden" />
                </div>
                <div class="flex-1">
                    <div class="flex items-center space-x-3 mb-1">
                        <h3 id="udm-fullname" class="text-2xl font-black text-gray-900 tracking-tight"></h3>
                        <span id="udm-status-active" class="hidden bg-green-100 text-green-700 px-2 py-0.5 rounded text-xs font-bold uppercase tracking-wider">Hoạt động</span>
                        <span id="udm-status-banned" class="hidden bg-red-100 text-red-700 px-2 py-0.5 rounded text-xs font-bold uppercase tracking-wider">Bị khóa</span>
                    </div>
                    <div class="flex flex-wrap gap-x-4 gap-y-2 mt-2 text-sm text-gray-500 font-medium">
                        <div class="flex items-center"><i data-lucide="user" class="w-4 h-4 mr-1.5 opacity-70"></i> <span id="udm-username"></span></div>
                        <div class="flex items-center"><i data-lucide="mail" class="w-4 h-4 mr-1.5 opacity-70"></i> <span id="udm-email"></span></div>
                        <div class="flex items-center"><i data-lucide="calendar" class="w-4 h-4 mr-1.5 opacity-70"></i> Tham gia: <span id="udm-joined"></span></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs Navigation -->
        <div class="px-8 border-b border-gray-100 flex space-x-8">
            <button onclick="switchTab('overview')" id="tab-btn-overview" class="py-4 text-sm font-bold border-b-2 transition-colors border-[#2D5A3D] text-[#2D5A3D]">
                Tổng quan
            </button>
            <button onclick="switchTab('transactions')" id="tab-btn-transactions" class="py-4 text-sm font-bold border-b-2 transition-colors border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 flex items-center">
                Lịch sử giao dịch
                <span id="udm-total-tx-badge" class="hidden ml-2 px-2 py-0.5 rounded-full text-[10px] bg-gray-100 text-gray-600">0</span>
            </button>
        </div>

        <!-- Content Body -->
        <div id="udm-content-body" class="p-8 overflow-y-auto flex-1 bg-white">
            <!-- Loading -->
            <div id="udm-loading" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4 animate-pulse">
                <div class="h-32 bg-gray-100 rounded-2xl"></div>
                <div class="h-32 bg-gray-100 rounded-2xl"></div>
                <div class="md:col-span-2 h-40 bg-gray-100 rounded-2xl"></div>
            </div>
            
            <!-- Overview Tab -->
            <div id="udm-tab-overview" class="space-y-6">
                <!-- Injected via JS -->
            </div>

            <!-- Transactions Tab -->
            <div id="udm-tab-transactions" class="space-y-4 hidden">
                <div id="udm-tx-list" class="space-y-3">
                    <!-- Injected via JS -->
                </div>
                <div id="udm-tx-footer" class="mt-6 space-y-4 hidden">
                    <div class="bg-gray-50 border border-gray-100 rounded-2xl p-5 flex items-center justify-between">
                        <div class="space-y-1">
                            <p class="text-sm text-gray-500 font-semibold">Tổng chi tiêu:</p>
                            <p class="text-sm text-gray-500 font-semibold">Số giao dịch thành công:</p>
                        </div>
                        <div class="space-y-1 text-right">
                            <p id="udm-tx-total-spent" class="text-lg font-black text-[#2D5A3D]"></p>
                            <p id="udm-tx-success-count" class="text-sm font-bold text-gray-900"></p>
                        </div>
                    </div>
                    <div id="udm-tx-pagination" class="flex justify-between items-center bg-white px-5 py-3 rounded-xl border border-gray-100 shadow-sm">
                        <span id="udm-tx-page-info" class="text-sm text-gray-500 font-medium"></span>
                        <div class="flex space-x-2">
                            <button id="udm-btn-prev" onclick="changeTxPage(-1)" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm font-semibold hover:bg-gray-50 transition-colors">Trước</button>
                            <button id="udm-btn-next" onclick="changeTxPage(1)" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg text-sm font-semibold hover:bg-gray-50 transition-colors">Sau</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="p-6 border-t border-gray-100 bg-gray-50 flex justify-between items-center">
            <div class="flex space-x-3">
                <button id="udm-btn-ban" class="hidden flex items-center space-x-2 px-4 py-2.5 bg-white border border-red-200 text-red-600 hover:bg-red-50 rounded-xl transition-colors font-bold text-sm shadow-sm">
                    <i data-lucide="ban" class="w-4 h-4"></i>
                    <span>Khóa tài khoản</span>
                </button>
            </div>
            <button type="button" onclick="closeUserDetailModal()" class="px-6 py-2.5 bg-gray-900 text-white hover:bg-gray-800 rounded-xl transition-colors font-bold text-sm shadow-md">
                Đóng
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openStatusModal(userId, isBanning, username) {
            document.getElementById('modalUserId').value = userId;
            document.getElementById('modalIsBanning').value = isBanning;
            
            const title = document.getElementById('statusModalTitle');
            const message = document.getElementById('statusModalMessage');
            const btn = document.getElementById('statusModalBtn');
            const reasonGroup = document.getElementById('reasonGroup');
            
            if (isBanning) {
                title.textContent = 'Khóa Tài Khoản';
                message.textContent = `Bạn có chắc chắn muốn khóa tài khoản của người dùng @@${username}?`;
                btn.textContent = 'Khóa Tài Khoản';
                btn.className = 'px-6 py-2.5 rounded-full font-bold text-white shadow-lg bg-red-500 hover:bg-red-600 transition-all';
                reasonGroup.style.display = 'block';
                document.getElementById('modalReason').required = true;
                document.getElementById('modalReason').value = '';
            } else {
                title.textContent = 'Mở Khóa Tài Khoản';
                message.textContent = `Bạn có chắc chắn muốn mở khóa tài khoản cho người dùng @@${username}?`;
                btn.textContent = 'Mở Khóa Tài Khoản';
                btn.className = 'px-6 py-2.5 rounded-full font-bold text-white shadow-lg bg-emerald-500 hover:bg-emerald-600 transition-all';
                reasonGroup.style.display = 'none';
                document.getElementById('modalReason').required = false;
                document.getElementById('modalReason').value = 'Mở khóa tài khoản';
            }
            
            document.getElementById('statusModal').classList.remove('hidden');
        }
        
        function closeStatusModal() {
            document.getElementById('statusModal').classList.add('hidden');
            document.getElementById('modalReason').value = '';
        }

        // Modal User Detail Logic
        let currentDetailUserId = null;
        let currentTxPage = 1;
        let totalTxPages = 1;
        let currentTotalSpent = 0;
        let currentTotalTxCount = 0;

        function formatCurrency(amount) {
            return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
        }

        function getStatusBadge(status) {
            switch(status) {
                case 'Success': return `<span class="bg-green-50 text-green-700 px-3 py-1 rounded-lg text-xs font-bold flex items-center w-fit"><i data-lucide="check-circle-2" class="w-3.5 h-3.5 mr-1"></i> Thành công</span>`;
                case 'Pending': return `<span class="bg-yellow-50 text-yellow-700 px-3 py-1 rounded-lg text-xs font-bold flex items-center w-fit"><i data-lucide="clock" class="w-3.5 h-3.5 mr-1"></i> Chờ xử lý</span>`;
                case 'Failed': return `<span class="bg-red-50 text-red-700 px-3 py-1 rounded-lg text-xs font-bold flex items-center w-fit"><i data-lucide="x-circle" class="w-3.5 h-3.5 mr-1"></i> Thất bại</span>`;
                default: return `<span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-lg text-xs font-bold">${status}</span>`;
            }
        }

        function openUserDetailModal(userId, fullName, username, email, avatarUrl, createdAt, isActive, roleName) {
            currentDetailUserId = userId;
            currentTxPage = 1;

            document.getElementById('udm-fullname').textContent = fullName;
            document.getElementById('udm-username').textContent = '@@' + username;
            document.getElementById('udm-email').textContent = email;
            document.getElementById('udm-joined').textContent = createdAt;

            const avatarImg = document.getElementById('udm-avatar-img');
            const avatarText = document.getElementById('udm-avatar-text');
            if (avatarUrl && avatarUrl.startsWith('http')) {
                avatarImg.src = avatarUrl;
                avatarImg.classList.remove('hidden');
                avatarText.classList.add('hidden');
            } else {
                avatarImg.classList.add('hidden');
                avatarText.classList.remove('hidden');
                avatarText.textContent = fullName.substring(0, 1).toUpperCase();
            }

            const btnBan = document.getElementById('udm-btn-ban');
            if (isActive) {
                document.getElementById('udm-status-active').classList.remove('hidden');
                document.getElementById('udm-status-banned').classList.add('hidden');
                
                if (roleName && roleName.toUpperCase() !== 'ADMIN') {
                    btnBan.classList.remove('hidden');
                    btnBan.onclick = () => {
                        closeUserDetailModal();
                        openStatusModal(userId, true, username);
                    };
                } else {
                    btnBan.classList.add('hidden');
                }
            } else {
                document.getElementById('udm-status-active').classList.add('hidden');
                document.getElementById('udm-status-banned').classList.remove('hidden');
                btnBan.classList.add('hidden');
            }

            document.getElementById('userDetailModal').classList.remove('hidden');
            
            switchTab('overview');
        }

        function closeUserDetailModal() {
            document.getElementById('userDetailModal').classList.add('hidden');
            currentDetailUserId = null;
        }

        function switchTab(tab) {
            const tabOverview = document.getElementById('udm-tab-overview');
            const tabTransactions = document.getElementById('udm-tab-transactions');
            const btnOverview = document.getElementById('tab-btn-overview');
            const btnTransactions = document.getElementById('tab-btn-transactions');

            if (tab === 'overview') {
                tabOverview.classList.remove('hidden');
                tabTransactions.classList.add('hidden');
                
                btnOverview.classList.add('border-[#2D5A3D]', 'text-[#2D5A3D]');
                btnOverview.classList.remove('border-transparent', 'text-gray-500');
                
                btnTransactions.classList.remove('border-[#2D5A3D]', 'text-[#2D5A3D]', 'bg-[#2D5A3D]/10');
                btnTransactions.classList.add('border-transparent', 'text-gray-500');
                document.getElementById('udm-total-tx-badge').classList.remove('bg-[#2D5A3D]/10', 'text-[#2D5A3D]');
                document.getElementById('udm-total-tx-badge').classList.add('bg-gray-100', 'text-gray-600');

                fetchOverview();
            } else {
                tabOverview.classList.add('hidden');
                tabTransactions.classList.remove('hidden');
                
                btnTransactions.classList.add('border-[#2D5A3D]', 'text-[#2D5A3D]');
                btnTransactions.classList.remove('border-transparent', 'text-gray-500');
                document.getElementById('udm-total-tx-badge').classList.add('bg-[#2D5A3D]/10', 'text-[#2D5A3D]');
                document.getElementById('udm-total-tx-badge').classList.remove('bg-gray-100', 'text-gray-600');
                
                btnOverview.classList.remove('border-[#2D5A3D]', 'text-[#2D5A3D]');
                btnOverview.classList.add('border-transparent', 'text-gray-500');

                fetchTransactions();
            }
        }

        async function fetchOverview() {
            const loading = document.getElementById('udm-loading');
            const container = document.getElementById('udm-tab-overview');
            loading.classList.remove('hidden');
            container.innerHTML = '';

            try {
                const response = await fetch(`/Admin/GetUserOverview?userId=${currentDetailUserId}`);
                const result = await response.json();
                
                loading.classList.add('hidden');
                
                if (result.success && result.data) {
                    renderOverview(result.data);
                    
                    currentTotalTxCount = result.data.totalTransactions;
                    currentTotalSpent = result.data.totalSpent;
                    if (currentTotalTxCount > 0) {
                        const badge = document.getElementById('udm-total-tx-badge');
                        badge.textContent = currentTotalTxCount;
                        badge.classList.remove('hidden');
                    }
                } else {
                    container.innerHTML = `<div class="text-center py-10 text-gray-500">Không có dữ liệu tổng quan.</div>`;
                }
            } catch (err) {
                loading.classList.add('hidden');
                container.innerHTML = `<div class="text-center py-10 text-red-500">Lỗi khi tải dữ liệu</div>`;
            }
            
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }

        function renderOverview(data) {
            const container = document.getElementById('udm-tab-overview');
            
            let recentTxHtml = '';
            if (data.recentTransactions && data.recentTransactions.length > 0) {
                recentTxHtml = data.recentTransactions.map(tx => {
                    const isPosting = tx.type === 'Posting';
                    const iconClass = isPosting ? 'bg-[#2D5A3D]/10 text-[#2D5A3D]' : 'bg-amber-50 text-amber-600';
                    const date = new Date(tx.createdAt).toLocaleDateString('vi-VN');
                    return `
                        <div class="py-3 flex items-center justify-between">
                          <div class="flex items-center">
                            <div class="w-10 h-10 rounded-xl flex items-center justify-center mr-4 ${iconClass}">
                              <i data-lucide="credit-card" class="w-5 h-5"></i>
                            </div>
                            <div>
                              <p class="font-bold text-gray-900">${tx.packageName}</p>
                              <p class="text-xs text-gray-500">${date} • #${tx.orderCode}</p>
                            </div>
                          </div>
                          <div class="text-right">
                            <p class="font-bold text-[#2D5A3D]">+${tx.credits} cr</p>
                            <p class="text-xs font-semibold text-gray-900">${formatCurrency(tx.amount)}</p>
                          </div>
                        </div>
                    `;
                }).join('');
            } else {
                recentTxHtml = `<p class="text-gray-500 py-4 text-center">Chưa có giao dịch nào.</p>`;
            }

            container.innerHTML = `
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="bg-indigo-50/50 border border-indigo-100 rounded-2xl p-6 hover:-translate-y-1 transition-transform duration-300 shadow-sm hover:shadow-md">
                    <div class="flex items-center text-indigo-700 mb-3">
                      <i data-lucide="credit-card" class="w-5 h-5 mr-2"></i>
                      <span class="font-bold text-sm">Credit Đăng Tin</span>
                    </div>
                    <h3 class="text-4xl font-black text-indigo-700 mb-1">${data.postingCredits}</h3>
                    <p class="text-indigo-600/70 text-sm font-semibold">credits còn lại</p>
                  </div>
                  
                  <div class="bg-amber-50/50 border border-amber-100 rounded-2xl p-6 hover:-translate-y-1 transition-transform duration-300 shadow-sm hover:shadow-md">
                    <div class="flex items-center text-amber-700 mb-3">
                      <i data-lucide="trending-up" class="w-5 h-5 mr-2"></i>
                      <span class="font-bold text-sm">Credit Nổi Bật</span>
                    </div>
                    <h3 class="text-4xl font-black text-amber-700 mb-1">${data.featuredCredits}</h3>
                    <p class="text-amber-600/70 text-sm font-semibold">credits còn lại</p>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 hover:-translate-y-1 transition-transform">
                    <div class="flex items-center text-gray-500 mb-2">
                      <i data-lucide="shopping-bag" class="w-5 h-5 mr-2 text-indigo-500"></i>
                      <span class="font-semibold text-sm">Tổng chi tiêu</span>
                    </div>
                    <p class="text-2xl font-black text-gray-900">${formatCurrency(data.totalSpent)}</p>
                  </div>
                  
                  <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 hover:-translate-y-1 transition-transform">
                    <div class="flex items-center text-gray-500 mb-2">
                      <i data-lucide="layout-dashboard" class="w-5 h-5 mr-2 text-emerald-500"></i>
                      <span class="font-semibold text-sm">Sản phẩm đăng</span>
                    </div>
                    <p class="text-2xl font-black text-gray-900">${data.productsPosted}</p>
                  </div>

                  <div class="bg-gray-50 rounded-2xl p-5 border border-gray-100 hover:-translate-y-1 transition-transform">
                    <div class="flex items-center text-gray-500 mb-2">
                      <i data-lucide="arrow-right-left" class="w-5 h-5 mr-2 text-rose-500"></i>
                      <span class="font-semibold text-sm">Lượt giao dịch</span>
                    </div>
                    <p class="text-2xl font-black text-gray-900">${data.totalTransactions}</p>
                  </div>
                </div>

                <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm">
                  <div class="flex justify-between items-center mb-4">
                    <h4 class="text-lg font-bold text-gray-900 flex items-center">
                      <i data-lucide="clock" class="w-5 h-5 mr-2 text-gray-400"></i>
                      Giao dịch gần đây
                    </h4>
                    <button type="button" onclick="switchTab('transactions')" class="text-[#2D5A3D] text-sm font-semibold hover:underline">
                      Xem tất cả
                    </button>
                  </div>
                  
                  <div class="divide-y divide-gray-50">
                    ${recentTxHtml}
                  </div>
                </div>
            `;
        }

        async function fetchTransactions() {
            const loading = document.getElementById('udm-loading');
            const container = document.getElementById('udm-tx-list');
            const footer = document.getElementById('udm-tx-footer');
            
            loading.classList.remove('hidden');
            container.innerHTML = '';
            footer.classList.add('hidden');

            try {
                const response = await fetch(`/Admin/GetUserTransactions?userId=${currentDetailUserId}&page=${currentTxPage}`);
                const result = await response.json();
                
                loading.classList.add('hidden');
                
                if (result.success && result.data && result.data.items && result.data.items.length > 0) {
                    renderTransactions(result.data.items);
                    
                    totalTxPages = result.data.totalPages || 1;
                    
                    document.getElementById('udm-tx-total-spent').textContent = formatCurrency(currentTotalSpent);
                    const successCount = result.data.items.filter(t => t.status === 'Success').length;
                    document.getElementById('udm-tx-success-count').textContent = `${successCount}/${currentTotalTxCount}`;
                    
                    if (totalTxPages > 1) {
                        document.getElementById('udm-tx-pagination').classList.remove('hidden');
                        document.getElementById('udm-tx-page-info').textContent = `Trang ${currentTxPage} / ${totalTxPages}`;
                        document.getElementById('udm-btn-prev').disabled = currentTxPage === 1;
                        document.getElementById('udm-btn-next').disabled = currentTxPage === totalTxPages;
                        
                        if(currentTxPage === 1) document.getElementById('udm-btn-prev').classList.add('opacity-50', 'cursor-not-allowed');
                        else document.getElementById('udm-btn-prev').classList.remove('opacity-50', 'cursor-not-allowed');
                        
                        if(currentTxPage === totalTxPages) document.getElementById('udm-btn-next').classList.add('opacity-50', 'cursor-not-allowed');
                        else document.getElementById('udm-btn-next').classList.remove('opacity-50', 'cursor-not-allowed');
                    } else {
                        document.getElementById('udm-tx-pagination').classList.add('hidden');
                    }
                    
                    footer.classList.remove('hidden');
                } else {
                    container.innerHTML = `<div class="text-center py-12 text-gray-500 bg-white border border-gray-100 rounded-2xl shadow-sm">Chưa có giao dịch nào</div>`;
                }
            } catch (err) {
                loading.classList.add('hidden');
                container.innerHTML = `<div class="text-center py-10 text-red-500">Lỗi khi tải dữ liệu</div>`;
            }
            
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }

        function renderTransactions(items) {
            const container = document.getElementById('udm-tx-list');
            container.innerHTML = items.map(tx => {
                const isPosting = tx.type === 'Posting';
                const iconColorClass = isPosting ? 'bg-indigo-50 text-indigo-500' : 'bg-amber-50 text-amber-600';
                const textColorClass = isPosting ? 'text-indigo-600' : 'text-amber-600';
                const date = new Date(tx.createdAt).toLocaleDateString('vi-VN');
                const iconName = isPosting ? 'credit-card' : 'trending-up';
                
                return `
                    <div class="bg-white border border-gray-100 hover:border-gray-200 rounded-2xl p-4 flex items-center justify-between shadow-sm hover:shadow transition-all duration-200">
                      <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0 ${iconColorClass}">
                          <i data-lucide="${iconName}" class="w-5 h-5"></i>
                        </div>
                        <div>
                          <h4 class="text-sm font-bold text-gray-900">${tx.packageName}</h4>
                          <p class="text-xs text-gray-500 mt-0.5">
                            ${tx.orderCode} <span class="mx-1">•</span> ${date}
                          </p>
                        </div>
                      </div>
                      
                      <div class="text-right flex flex-col items-end space-y-1">
                        <span class="text-sm font-bold ${textColorClass}">
                          +${tx.credits} credits
                        </span>
                        <span class="text-sm font-black text-gray-900">
                          ${formatCurrency(tx.amount)}
                        </span>
                        <div class="mt-1">
                          ${getStatusBadge(tx.status)}
                        </div>
                      </div>
                    </div>
                `;
            }).join('');
        }

        function changeTxPage(delta) {
            const newPage = currentTxPage + delta;
            if (newPage >= 1 && newPage <= totalTxPages) {
                currentTxPage = newPage;
                fetchTransactions();
            }
        }
    </script>
}
