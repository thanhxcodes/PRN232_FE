@{
    ViewData["Title"] = "Quản Lý Bài Đăng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="mb-8">
    <h2 class="text-3xl text-gray-900 mb-2">Quản Lý Bài Đăng</h2>
    <p class="text-gray-600">Xem, duyệt và quản lý các bài đăng sản phẩm của người dùng</p>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-white rounded-2xl shadow-sm p-5">
        <div class="text-xs text-gray-500 mb-1">Tổng bài đăng</div>
        <div class="text-3xl font-bold text-gray-900">120</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm p-5">
        <div class="text-xs text-gray-500 mb-1">Đang hiển thị</div>
        <div class="text-3xl font-bold text-green-600">85</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm p-5">
        <div class="text-xs text-gray-500 mb-1">Chờ duyệt kháng cáo</div>
        <div class="text-3xl font-bold text-orange-600">5</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm p-5">
        <div class="text-xs text-gray-500 mb-1">Vi phạm</div>
        <div class="text-3xl font-bold text-red-600">10</div>
    </div>
    <div class="bg-white rounded-2xl shadow-sm p-5">
        <div class="text-xs text-gray-500 mb-1">Đã xóa</div>
        <div class="text-3xl font-bold text-gray-400">20</div>
    </div>
</div>

<!-- Filters -->
<div class="bg-white rounded-2xl shadow-sm p-5 mb-6">
    <div class="flex flex-wrap items-center gap-3">
        <div class="flex-1 min-w-48 relative">
            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
            <input type="text" placeholder="Tìm theo tên, người đăng..." class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm" />
        </div>
        <select class="px-4 py-2 bg-white border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 transition-all cursor-pointer hover:border-gray-300">
            <option value="all">Tất cả trạng thái</option>
            <option value="Public">Đang hiển thị</option>
            <option value="Private">Riêng tư</option>
            <option value="Expired">Hết hạn</option>
            <option value="Deleted">Đã xóa (User)</option>
            <option value="AdminDeleted">Đã xóa (Admin)</option>
            <option value="Violated">Vi phạm</option>
            <option value="AppealPending">Chờ duyệt kháng cáo</option>
        </select>
        <select class="px-4 py-2.5 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm">
            <option value="all">Tất cả danh mục</option>
            <option value="Áo">Áo</option>
            <option value="Quần">Quần</option>
        </select>
    </div>
</div>

<!-- Posts Table -->
<div class="bg-white rounded-2xl shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead>
                <tr class="border-b border-gray-100 bg-gray-50/80 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">
                    <th class="py-5 px-6">Sản phẩm</th>
                    <th class="py-5 px-6">Người đăng</th>
                    <th class="py-5 px-6">Giá</th>
                    <th class="py-5 px-6">Ngày đăng</th>
                    <th class="py-5 px-6">Lượt xem</th>
                    <th class="py-5 px-6">Trạng thái</th>
                    <th class="py-5 px-6 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <!-- Mock Row -->
                <tr class="border-b border-gray-50 hover:bg-green-50/30 transition-colors group cursor-pointer">
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-3">
                            <div class="w-12 h-12 rounded-xl overflow-hidden bg-gray-100 flex-shrink-0">
                                <img src="https://images.unsplash.com/photo-1560769629-975ec94e6a86?w=400" alt="Sản phẩm" class="w-full h-full object-cover" />
                            </div>
                            <div class="min-w-0">
                                <div class="text-sm font-medium text-gray-900 truncate max-w-48">Giày thể thao Nike Air Max</div>
                                <div class="flex items-center space-x-1 mt-0.5">
                                    <span class="text-xs text-gray-400">Giày Dép</span>
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center space-x-4">
                            <div class="w-10 h-10 bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] rounded-xl flex items-center justify-center text-white text-sm font-bold overflow-hidden shadow-sm ring-2 ring-white group-hover:ring-green-50 transition-all">
                                N
                            </div>
                            <div>
                                <div class="text-sm font-bold text-gray-900">Nguyễn Văn B</div>
                                <div class="text-xs text-gray-500 font-medium mt-0.5">@@nguyenvanb</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-4 px-6 text-sm font-bold text-[#C4603A]">1.200.000đ</td>
                    <td class="py-4 px-6 text-sm text-gray-500 font-medium">01/06/2026</td>
                    <td class="py-4 px-6 text-sm font-bold text-[#2D5A3D] bg-green-50/30">
                        150 <span class="text-xs font-normal text-gray-400">lượt</span>
                    </td>
                    <td class="py-4 px-6">
                        <span class="text-xs px-3 py-1.5 rounded-xl font-bold flex items-center w-fit shadow-sm border border-green-200 bg-green-100 text-green-700">
                            Đang hiển thị
                        </span>
                    </td>
                    <td class="py-4 px-6">
                        <div class="flex items-center justify-end space-x-2">
                            <button class="flex items-center space-x-1 text-gray-600 bg-gray-50 border border-gray-200 hover:bg-gray-100 hover:border-gray-300 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Xem chi tiết">
                                <i data-lucide="eye" class="w-4 h-4"></i>
                                <span>Xem</span>
                            </button>
                            <button class="flex items-center space-x-1.5 text-yellow-700 bg-yellow-50 border border-yellow-200 hover:bg-yellow-100 hover:border-yellow-300 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Báo vi phạm">
                                <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                                <span>Vi phạm</span>
                            </button>
                            <button class="flex items-center space-x-1.5 text-red-600 bg-white border border-red-100 hover:bg-red-50 hover:border-red-200 px-3 py-1.5 rounded-lg transition-all text-sm font-bold shadow-sm" title="Xóa bài viết">
                                <i data-lucide="trash-2" class="w-4 h-4"></i>
                                <span>Xóa</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="flex items-center justify-between px-5 py-4 border-t border-gray-200">
        <div class="flex items-center space-x-4">
            <div class="text-sm text-gray-500">Hiển thị 1-10 trong 120 bài đăng</div>
        </div>
        <div class="flex items-center space-x-2">
            <button class="p-2 border border-gray-300 rounded-lg text-gray-500 hover:bg-gray-50 transition-colors">
                <i data-lucide="chevron-left" class="w-4 h-4"></i>
            </button>
            <button class="w-8 h-8 rounded-lg text-sm font-medium transition-colors bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white">1</button>
            <button class="w-8 h-8 rounded-lg text-sm font-medium transition-colors border border-gray-300 text-gray-600 hover:bg-gray-50">2</button>
            <button class="p-2 border border-gray-300 rounded-lg text-gray-500 hover:bg-gray-50 transition-colors">
                <i data-lucide="chevron-right" class="w-4 h-4"></i>
            </button>
        </div>
    </div>
</div>
