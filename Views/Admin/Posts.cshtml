@using REVORA_MVC_FE.Models.ViewModels
@model AdminProductPagedResult
@{
    ViewData["Title"] = "Quản Lý Bài Đăng";
    Layout = "_Layout";
    var search = ViewBag.Search as string ?? "";
    var currentStatusFilter = ViewBag.StatusFilter as string ?? "all";
    var currentCategoryFilter = ViewBag.CategoryFilter as string ?? "all";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between">
    <div>
        <h2 class="text-3xl text-gray-900 mb-2 font-bold tracking-tight">Quản Lý Bài Đăng</h2>
        <p class="text-gray-600">Xem, duyệt và quản lý các bài đăng sản phẩm của người dùng</p>
    </div>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
    <div class="bg-white p-5 rounded-2xl shadow-[0_2px_10px_-3px_rgba(6,81,237,0.1)] flex flex-col justify-center border border-gray-100/50 relative overflow-hidden group hover:shadow-md transition-shadow">
        <div class="text-xs text-gray-500 mb-1">Chờ duyệt kháng cáo</div>
        <div class="text-3xl font-bold text-orange-600">@Model.Stats.PendingAds</div>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-green-100 shadow-sm relative overflow-hidden">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-green-50 rounded-full"></div>
        <p class="text-sm font-medium text-green-600 mb-1 relative z-10">Đang hiển thị</p>
        <h3 class="text-2xl font-bold text-green-700 relative z-10">@Model.Stats.ActivePosts</h3>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-orange-100 shadow-sm relative overflow-hidden">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-orange-50 rounded-full"></div>
        <p class="text-sm font-medium text-orange-600 mb-1 relative z-10">Chờ duyệt quảng cáo</p>
        <h3 class="text-2xl font-bold text-orange-700 relative z-10">@Model.Stats.PendingAds</h3>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-red-100 shadow-sm relative overflow-hidden">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-red-50 rounded-full"></div>
        <p class="text-sm font-medium text-red-600 mb-1 relative z-10">Vi phạm</p>
        <h3 class="text-2xl font-bold text-red-700 relative z-10">@Model.Stats.ViolatedPosts</h3>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm relative overflow-hidden">
        <div class="absolute -right-4 -bottom-4 w-16 h-16 bg-gray-50 rounded-full"></div>
        <p class="text-sm font-medium text-gray-600 mb-1 relative z-10">Đã xóa</p>
        <h3 class="text-2xl font-bold text-gray-700 relative z-10">@Model.Stats.DeletedPosts</h3>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-green-50 border border-green-100 text-green-700 flex items-center gap-3">
        <i data-lucide="check-circle" class="w-5 h-5"></i>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 text-red-700 flex items-center gap-3">
        <i data-lucide="alert-triangle" class="w-5 h-5"></i>
        @TempData["ErrorMessage"]
    </div>
}

<div class="bg-white rounded-2xl shadow-sm p-6 mb-8 border border-gray-100">
    <!-- Search & Filter -->
    <form method="get" action="/Admin/Posts" class="flex flex-col md:flex-row items-center space-y-4 md:space-y-0 md:space-x-4 mb-6">
        <div class="flex-1 relative w-full group">
            <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
            <input type="text" name="search" value="@search" placeholder="Tìm kiếm theo tên bài, người đăng..."
                   class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/20 focus:border-[#2D5A3D] bg-gray-50 hover:bg-white text-gray-800 font-medium" />
        </div>
        <select name="statusFilter" class="px-4 py-2.5 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm bg-white text-gray-700 min-w-40 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2216%22%20height%3D%2216%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[position:right_12px_center]" onchange="this.form.submit()">
            <option value="all" selected="@(currentStatusFilter == "all")">Tất cả trạng thái</option>
            <option value="Public" selected="@(currentStatusFilter == "Public")">Đang hiển thị</option>
            <option value="Private" selected="@(currentStatusFilter == "Private")">Riêng tư</option>
            <option value="Expired" selected="@(currentStatusFilter == "Expired")">Hết hạn</option>
            <option value="Deleted" selected="@(currentStatusFilter == "Deleted")">Đã xóa (User)</option>
            <option value="AdminDeleted" selected="@(currentStatusFilter == "AdminDeleted")">Đã xóa (Admin)</option>
            <option value="Violated" selected="@(currentStatusFilter == "Violated")">Vi phạm</option>
            <option value="AppealPending" selected="@(currentStatusFilter == "AppealPending")">Chờ duyệt kháng cáo</option>
        </select>

        <select name="categoryFilter" class="px-4 py-2.5 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm bg-white text-gray-700 min-w-40 appearance-none bg-[url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2216%22%20height%3D%2216%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[position:right_12px_center]" onchange="this.form.submit()">
            <option value="all" selected="@(currentCategoryFilter == "all")">Tất cả danh mục</option>
            @if(ViewBag.Categories != null) {
                foreach(string cat in ViewBag.Categories) {
                    <option value="@cat" selected="@(currentCategoryFilter == cat)">@cat</option>
                }
            }
        </select>
    </form>

    <div class="overflow-x-auto rounded-xl border border-gray-100">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50/80 border-b border-gray-100">
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Sản phẩm</th>
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Người đăng</th>
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Giá</th>
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Ngày đăng</th>
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider">Lượt xem</th>
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-center">Trạng thái</th>
                    <th class="py-4 px-6 text-xs font-bold text-gray-500 uppercase tracking-wider text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="7" class="py-12 text-center">
                            <div class="flex flex-col items-center justify-center text-gray-500">
                                <i data-lucide="inbox" class="w-12 h-12 mb-3 text-gray-300"></i>
                                <p class="text-lg font-medium text-gray-900">Không tìm thấy bài đăng nào</p>
                                <p class="text-sm mt-1">Hãy thử thay đổi điều kiện tìm kiếm</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var post in Model.Items)
                    {
                        var firstImage = (post.Images != null && post.Images.Count > 0) ? post.Images[0] : "";
                        var badgeClass = "";
                        var badgeText = "";
                        var badgeIcon = "info";

                        switch (post.Status)
                        {
                            case "Public":
                                badgeClass = "bg-green-50 text-green-700 border-green-200";
                                badgeText = "Đang hiển thị";
                                badgeIcon = "check-circle";
                                break;
                            case "Private":
                                badgeClass = "bg-gray-100 text-gray-600 border-gray-200";
                                badgeText = "Riêng tư";
                                badgeIcon = "lock";
                                break;
                            case "Expired":
                                badgeClass = "bg-gray-200 text-gray-700 border-gray-300";
                                badgeText = "Hết hạn";
                                badgeIcon = "clock";
                                break;
                            case "Deleted":
                                badgeClass = "bg-gray-100 text-gray-600 border-gray-200";
                                badgeText = "Đã xóa";
                                badgeIcon = "trash-2";
                                break;
                            case "Violated":
                                badgeClass = "bg-red-100 text-red-700 border-red-200";
                                badgeText = "Vi phạm";
                                badgeIcon = "alert-triangle";
                                break;
                            case "AdminDeleted":
                                badgeClass = "bg-red-200 text-red-800 border-red-300";
                                badgeText = "Xóa bởi Admin";
                                badgeIcon = "x-circle";
                                break;
                            case "AppealPending":
                                badgeClass = "bg-orange-100 text-orange-700 border-orange-200";
                                badgeText = "Chờ duyệt kháng cáo";
                                badgeIcon = "alert-circle";
                                break;
                            default:
                                badgeClass = "bg-gray-100 text-gray-600 border-gray-200";
                                badgeText = post.Status;
                                badgeIcon = "info";
                                break;
                        }

                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-xl bg-gray-100 flex-shrink-0 border border-gray-200 overflow-hidden">
                                        @if (!string.IsNullOrEmpty(firstImage))
                                        {
                                            <img src="@firstImage" alt="@post.Title" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <div class="w-full h-full flex items-center justify-center text-gray-400">
                                                <i data-lucide="image" class="w-5 h-5"></i>
                                            </div>
                                        }
                                    </div>
                                    <div>
                                        <div class="font-bold text-[14px] text-gray-900 max-w-[200px] truncate" title="@post.Title">@post.Title</div>
                                        <div class="flex items-center gap-1.5 mt-1">
                                            <span class="text-[12px] text-gray-500">@post.Category</span>
                                            @if (post.IsFeatured)
                                            {
                                                <span class="text-[10px] font-bold text-[#C4603A] bg-orange-50 border border-orange-100 px-1.5 py-0.5 rounded text-xs">Nổi bật</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-[#2D5A3D] text-white flex items-center justify-center font-bold text-xs flex-shrink-0 overflow-hidden">
                                        @if (!string.IsNullOrEmpty(post.Owner.Avatar))
                                        {
                                            <img src="@post.Owner.Avatar" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <span>@(string.IsNullOrEmpty(post.Owner.Username) ? "U" : post.Owner.Username.Substring(0, 1).ToUpper())</span>
                                        }
                                    </div>
                                    <div>
                                        <div class="font-bold text-[13px] text-gray-900">@post.Owner.Username</div>
                                        <div class="text-[12px] text-gray-500 font-medium">@@@post.Owner.Username</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-4 px-6 text-[14px] font-bold text-[#C4603A] whitespace-nowrap">
                                @post.Price.ToString("N0")đ
                            </td>
                            <td class="py-4 px-6 text-[13px] text-gray-700 font-medium whitespace-nowrap">
                                @post.CreatedAt
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap">
                                <div class="flex items-center gap-1.5 text-[14px] font-bold text-gray-900">
                                    @post.Views <span class="text-gray-500 font-normal text-xs">lượt</span>
                                </div>
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap text-center">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[12px] font-bold border shadow-sm @badgeClass">
                                    <i data-lucide="@badgeIcon" class="w-3.5 h-3.5"></i>
                                    @badgeText
                                </span>
                            </td>
                            <td class="py-4 px-6 whitespace-nowrap text-center">
                                <div class="flex items-center justify-center space-x-2">
                                    <button onclick='openPostDetailModal(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(post)))' class="px-3 py-1.5 text-gray-600 bg-white border border-gray-200 hover:bg-gray-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                        <i data-lucide="eye" class="w-3.5 h-3.5"></i> Xem
                                    </button>
                                    @if (post.Status == "Public")
                                    {
                                        <button onclick="openActionReasonModal('@post.Id', 'Violated')" class="px-3 py-1.5 text-yellow-700 bg-white border border-yellow-200 hover:bg-yellow-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                            <i data-lucide="alert-triangle" class="w-3.5 h-3.5"></i> Vi phạm
                                        </button>
                                        <button onclick="openActionReasonModal('@post.Id', 'AdminDeleted')" class="px-3 py-1.5 text-red-600 bg-white border border-red-200 hover:bg-red-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Xóa
                                        </button>
                                    }
                                    else if (post.Status == "Violated")
                                    {
                                        <button onclick="openActionReasonModal('@post.Id', 'AdminDeleted')" class="px-3 py-1.5 text-red-600 bg-white border border-red-200 hover:bg-red-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i> Xóa
                                        </button>
                                    }
                                    else if (post.Status == "AppealPending")
                                    {
                                        <button type="button" onclick="openConfirmApproveModal('@post.Id')" class="px-3 py-1.5 text-green-700 bg-white border border-green-200 hover:bg-green-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                            <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> Duyệt
                                        </button>
                                        <button onclick="openActionReasonModal('@post.Id', 'AdminDeleted')" class="px-3 py-1.5 text-red-600 bg-white border border-red-200 hover:bg-red-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                            <i data-lucide="x-circle" class="w-3.5 h-3.5"></i> Từ chối
                                        </button>
                                    }
                                    else if (post.Status == "AdminDeleted" || post.Status == "Deleted")
                                    {
                                        <button type="button" onclick="openConfirmRestoreModal('@post.Id')" class="px-3 py-1.5 text-green-700 bg-white border border-green-200 hover:bg-green-50 rounded-lg transition-all text-xs font-bold shadow-sm flex items-center gap-1.5">
                                            <i data-lucide="refresh-ccw" class="w-3.5 h-3.5"></i> Khôi phục
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="flex flex-col sm:flex-row items-center justify-between px-8 py-5 bg-gray-50/80 border-t border-gray-100 mt-4 rounded-b-xl">
            <div class="text-sm text-gray-500 font-medium mb-4 sm:mb-0 bg-white px-4 py-2 rounded-xl shadow-sm border border-gray-100">
                Tổng cộng <span class="text-[#2D5A3D] font-bold text-base mx-1">@Model.TotalCount</span> bài đăng
            </div>
            <div class="flex items-center space-x-2">
                <a href="@(Model.CurrentPage > 1 ? $"/Admin/Posts?page={Model.CurrentPage - 1}&search={Uri.EscapeDataString(search)}&statusFilter={currentStatusFilter}&categoryFilter={currentCategoryFilter}" : "javascript:void(0)")" 
                   class="px-4 py-2 border border-gray-200 bg-white rounded-xl text-sm font-bold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all shadow-sm active:scale-95 @(Model.CurrentPage == 1 ? "opacity-50 cursor-not-allowed pointer-events-none" : "")">
                    Trước
                </a>
                
                <div class="flex items-center space-x-1">
                    @{
                        int startPage = Math.Max(1, Model.CurrentPage - 2);
                        int endPage = Math.Min(Model.TotalPages, startPage + 4);
                        if (endPage - startPage < 4) {
                            startPage = Math.Max(1, endPage - 4);
                        }
                    }
                    @for (int p = startPage; p <= endPage; p++)
                    {
                        <a href="/Admin/Posts?page=@p&search=@Uri.EscapeDataString(search)&statusFilter=@currentStatusFilter&categoryFilter=@currentCategoryFilter" 
                           class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-bold transition-all shadow-sm active:scale-95 @(p == Model.CurrentPage ? "bg-gradient-to-br from-[#2D5A3D] to-[#3D7054] text-white border-transparent shadow-md" : "border border-gray-200 bg-white text-gray-600 hover:bg-gray-50 hover:text-[#2D5A3D]")">
                            @p
                        </a>
                    }
                </div>
                
                <a href="@(Model.CurrentPage < Model.TotalPages ? $"/Admin/Posts?page={Model.CurrentPage + 1}&search={Uri.EscapeDataString(search)}&statusFilter={currentStatusFilter}&categoryFilter={currentCategoryFilter}" : "javascript:void(0)")" 
                   class="px-4 py-2 border border-gray-200 bg-white rounded-xl text-sm font-bold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all shadow-sm active:scale-95 @(Model.CurrentPage == Model.TotalPages ? "opacity-50 cursor-not-allowed pointer-events-none" : "")">
                    Sau
                </a>
            </div>
        </div>
    }
</div>

<!-- Modal Xem Chi Tiết -->
<div id="postDetailModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4 hidden">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden flex flex-col transform transition-all">
        <!-- Header -->
        <div class="bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] p-5 text-white flex items-center justify-between flex-shrink-0">
            <div>
                <h3 class="font-bold text-lg">Chi tiết bài đăng</h3>
                <p class="text-white/70 text-xs mt-0.5" id="pdm-id">ID: </p>
            </div>
            <button onclick="closePostDetailModal()" class="w-8 h-8 bg-white/20 hover:bg-white/30 rounded-xl flex items-center justify-center transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto p-6 space-y-5">
            <!-- Product Image + Info -->
            <div class="flex space-x-4">
                <div class="w-28 h-28 rounded-2xl overflow-hidden flex-shrink-0 bg-gray-100">
                    <img id="pdm-image" src="" class="w-full h-full object-cover hidden" />
                    <div id="pdm-image-placeholder" class="w-full h-full flex items-center justify-center text-gray-400">
                        <i data-lucide="image" class="w-8 h-8"></i>
                    </div>
                </div>
                <div class="flex-1">
                    <h4 id="pdm-title" class="font-bold text-gray-900 text-base leading-snug"></h4>
                    <div id="pdm-price" class="text-lg font-bold text-[#C4603A] mt-1"></div>
                    <div class="flex flex-wrap gap-1.5 mt-2" id="pdm-tags">
                        <!-- tags dynamically injected here -->
                    </div>
                </div>
            </div>

            <!-- Stats grid -->
            <div class="grid grid-cols-2 gap-3 bg-gray-50/50 p-4 rounded-2xl border border-gray-100">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shadow-sm text-gray-500">
                        <i data-lucide="eye" class="w-5 h-5"></i>
                    </div>
                    <div>
                        <div class="text-[11px] text-gray-500 font-bold uppercase tracking-wide">Lượt xem</div>
                        <div class="font-bold text-gray-900 text-sm" id="pdm-views">0</div>
                    </div>
                </div>
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shadow-sm text-gray-500">
                        <i data-lucide="message-circle" class="w-5 h-5"></i>
                    </div>
                    <div>
                        <div class="text-[11px] text-gray-500 font-bold uppercase tracking-wide">Liên hệ</div>
                        <div class="font-bold text-gray-900 text-sm" id="pdm-contactCount">0</div>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div>
                <h5 class="font-bold text-sm text-gray-900 mb-2">Mô tả sản phẩm</h5>
                <p id="pdm-description" class="text-gray-600 text-sm leading-relaxed whitespace-pre-wrap bg-gray-50 p-4 rounded-2xl border border-gray-100"></p>
            </div>

            <!-- Owner Info -->
            <div>
                <h5 class="font-bold text-sm text-gray-900 mb-2">Thông tin người bán</h5>
                <div class="bg-gray-50 rounded-2xl p-4 border border-gray-100 flex items-center space-x-3">
                    <div class="w-10 h-10 rounded-full bg-[#2D5A3D] text-white flex items-center justify-center font-bold text-sm overflow-hidden">
                        <img id="pdm-owner-avatar" src="" class="w-full h-full object-cover hidden" />
                        <span id="pdm-owner-initial">U</span>
                    </div>
                    <div class="flex-1">
                        <div id="pdm-owner-username" class="font-bold text-gray-900 text-sm"></div>
                        <div id="pdm-owner-email" class="text-xs text-gray-500"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div class="p-5 border-t border-gray-100 bg-gray-50 flex items-center justify-end space-x-3 flex-shrink-0" id="pdm-actions">
            <!-- buttons dynamically injected here -->
        </div>
    </div>
</div>

<!-- Modal Hành động (Vi phạm/Xóa) -->
<div id="actionReasonModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[60] flex items-center justify-center p-4 hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-md overflow-hidden flex flex-col p-6 border border-gray-100">
        <form method="post" action="/Admin/UpdatePostStatus">
            <input type="hidden" name="productId" id="arm-productId" />
            <input type="hidden" name="status" id="arm-status" />
            
            <div id="arm-icon-wrapper" class="w-12 h-12 rounded-full flex items-center justify-center mb-4 bg-yellow-100 text-yellow-600">
                <i data-lucide="alert-triangle" class="w-6 h-6"></i>
            </div>
            
            <h3 id="arm-title" class="font-bold text-lg text-gray-900 mb-2">Xác nhận</h3>
            <p class="text-gray-600 text-sm mb-2">Vui lòng nhập lý do để thông báo đến người dùng:</p>
            
            <div id="arm-warning" class="text-xs font-medium mb-4 p-2.5 rounded-lg border">
                <!-- warning message -->
            </div>
            
            <textarea name="note" rows="3" placeholder="Nhập lý do..." required
                      class="w-full px-3 py-2 mb-6 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D] text-sm resize-none"></textarea>
            
            <div class="flex space-x-3">
                <button type="button" onclick="closeActionReasonModal()" class="flex-1 py-2.5 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Hủy</button>
                <button type="submit" id="arm-submit" class="flex-1 py-2.5 text-white rounded-xl text-sm font-medium transition-colors">Xác nhận</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Xác nhận Khôi phục -->
<div id="confirmRestoreModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[60] flex items-center justify-center p-4 hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm overflow-hidden flex flex-col p-6 border border-gray-100 text-center">
        <form method="post" action="/Admin/UpdatePostStatus">
            <input type="hidden" name="productId" id="crm-productId" />
            <input type="hidden" name="status" value="Public" />
            <input type="hidden" name="note" value="Khôi phục bởi Admin" />
            
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4 bg-green-100 text-green-600 mx-auto">
                <i data-lucide="refresh-ccw" class="w-8 h-8"></i>
            </div>
            
            <h3 class="font-bold text-xl text-gray-900 mb-2">Xác nhận khôi phục</h3>
            <p class="text-gray-600 text-sm mb-6">Bạn có chắc chắn muốn khôi phục bài đăng này? Người dùng sẽ xem lại được bài đăng này trên ứng dụng.</p>
            
            <div class="flex space-x-3">
                <button type="button" onclick="closeConfirmRestoreModal()" class="flex-1 py-2.5 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Hủy</button>
                <button type="submit" class="flex-1 py-2.5 text-white bg-green-600 hover:bg-green-700 rounded-xl text-sm font-medium transition-colors">Khôi phục</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Xác nhận Duyệt Kháng cáo -->
<div id="confirmApproveModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-[60] flex items-center justify-center p-4 hidden">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm overflow-hidden flex flex-col p-6 border border-gray-100 text-center">
        <form method="post" action="/Admin/UpdatePostStatus">
            <input type="hidden" name="productId" id="cam-productId" />
            <input type="hidden" name="status" value="Public" />
            <input type="hidden" name="note" value="Chấp nhận kháng cáo" />
            
            <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4 bg-green-100 text-green-600 mx-auto">
                <i data-lucide="check-circle" class="w-8 h-8"></i>
            </div>
            
            <h3 class="font-bold text-xl text-gray-900 mb-2">Duyệt kháng cáo</h3>
            <p class="text-gray-600 text-sm mb-6">Bạn có chắc chắn muốn chấp nhận kháng cáo cho bài đăng này? Bài đăng sẽ được hiển thị công khai trở lại.</p>
            
            <div class="flex space-x-3">
                <button type="button" onclick="closeConfirmApproveModal()" class="flex-1 py-2.5 border border-gray-300 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">Hủy</button>
                <button type="submit" class="flex-1 py-2.5 text-white bg-green-600 hover:bg-green-700 rounded-xl text-sm font-medium transition-colors">Duyệt</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openPostDetailModal(post) {
            document.getElementById('pdm-id').textContent = 'ID: ' + post.Id;
            document.getElementById('pdm-title').textContent = post.Title;
            document.getElementById('pdm-price').textContent = post.Price.toLocaleString('vi-VN') + 'đ';
            
            // Image
            const imgEl = document.getElementById('pdm-image');
            const placeholderEl = document.getElementById('pdm-image-placeholder');
            if (post.Images && post.Images.length > 0) {
                imgEl.src = post.Images[0];
                imgEl.classList.remove('hidden');
                placeholderEl.classList.add('hidden');
            } else {
                imgEl.classList.add('hidden');
                placeholderEl.classList.remove('hidden');
            }

            // Tags
            let tagsHtml = `
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-md">${post.Category || ''}</span>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-md">${post.Condition || ''}</span>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-md">Size ${post.Size || ''}</span>
            `;
            if (post.IsFeatured) {
                tagsHtml += `<span class="text-xs bg-orange-100 text-[#C4603A] px-2 py-0.5 rounded-md font-medium">Nổi bật</span>`;
            }
            document.getElementById('pdm-tags').innerHTML = tagsHtml;

            // Stats
            document.getElementById('pdm-views').textContent = post.Views;
            document.getElementById('pdm-contactCount').textContent = post.ContactCount;
            document.getElementById('pdm-description').textContent = post.Description || "Không có mô tả.";

            // Owner
            document.getElementById('pdm-owner-username').textContent = post.Owner ? post.Owner.Username : '';
            document.getElementById('pdm-owner-email').textContent = post.Owner ? post.Owner.Email : '';
            
            const avatarImg = document.getElementById('pdm-owner-avatar');
            const avatarInitial = document.getElementById('pdm-owner-initial');
            if (post.Owner && post.Owner.Avatar && post.Owner.Avatar.startsWith('http')) {
                avatarImg.src = post.Owner.Avatar;
                avatarImg.classList.remove('hidden');
                avatarInitial.classList.add('hidden');
            } else {
                avatarImg.classList.add('hidden');
                avatarInitial.classList.remove('hidden');
                avatarInitial.textContent = post.Owner && post.Owner.Username ? post.Owner.Username.substring(0, 1).toUpperCase() : 'U';
            }

            // Actions
            let actionsHtml = `<button onclick="closePostDetailModal()" class="px-5 py-2.5 rounded-xl border border-gray-300 text-sm font-bold text-gray-700 hover:bg-white transition-all shadow-sm">Đóng</button>`;
            
            if (post.Status === 'Public') {
                actionsHtml += `
                    <button onclick="closePostDetailModal(); openActionReasonModal('${post.Id}', 'Violated')" class="px-5 py-2.5 rounded-xl bg-yellow-500 hover:bg-yellow-600 text-white text-sm font-bold transition-all shadow-sm flex items-center gap-2">
                        <i data-lucide="alert-triangle" class="w-4 h-4"></i> Đánh dấu vi phạm
                    </button>
                    <button onclick="closePostDetailModal(); openActionReasonModal('${post.Id}', 'AdminDeleted')" class="px-5 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm font-bold transition-all shadow-sm flex items-center gap-2">
                        <i data-lucide="trash-2" class="w-4 h-4"></i> Xóa vĩnh viễn
                    </button>
                `;
            } else if (post.Status === 'Violated') {
                actionsHtml += `
                    <button onclick="closePostDetailModal(); openActionReasonModal('${post.Id}', 'AdminDeleted')" class="px-5 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm font-bold transition-all shadow-sm flex items-center gap-2">
                        <i data-lucide="trash-2" class="w-4 h-4"></i> Xóa vĩnh viễn
                    </button>
                `;
            } else if (post.Status === 'AppealPending') {
                actionsHtml += `
                    <button type="button" onclick="closePostDetailModal(); openConfirmApproveModal('${post.Id}')" class="px-5 py-2.5 rounded-xl bg-green-600 hover:bg-green-700 text-white text-sm font-bold transition-all shadow-sm flex items-center gap-2">
                        <i data-lucide="check-circle" class="w-4 h-4"></i> Duyệt
                    </button>
                    <button onclick="closePostDetailModal(); openActionReasonModal('${post.Id}', 'AdminDeleted')" class="px-5 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white text-sm font-bold transition-all shadow-sm flex items-center gap-2">
                        <i data-lucide="x-circle" class="w-4 h-4"></i> Từ chối
                    </button>
                `;
            } else if (post.Status === 'AdminDeleted' || post.Status === 'Deleted') {
                actionsHtml += `
                    <button type="button" onclick="closePostDetailModal(); openConfirmRestoreModal('${post.Id}')" class="px-5 py-2.5 rounded-xl bg-green-600 hover:bg-green-700 text-white text-sm font-bold transition-all shadow-sm flex items-center gap-2">
                        <i data-lucide="refresh-ccw" class="w-4 h-4"></i> Khôi phục
                    </button>
                `;
            }
            
            document.getElementById('pdm-actions').innerHTML = actionsHtml;
            lucide.createIcons(); // refresh icons in actions

            document.getElementById('postDetailModal').classList.remove('hidden');
        }

        function closePostDetailModal() {
            document.getElementById('postDetailModal').classList.add('hidden');
        }

        function openActionReasonModal(productId, actionType) {
            document.getElementById('arm-productId').value = productId;
            document.getElementById('arm-status').value = actionType;

            const iconWrapper = document.getElementById('arm-icon-wrapper');
            const title = document.getElementById('arm-title');
            const warning = document.getElementById('arm-warning');
            const submitBtn = document.getElementById('arm-submit');

            if (actionType === 'Violated') {
                iconWrapper.className = 'w-12 h-12 rounded-full flex items-center justify-center mb-4 bg-yellow-100 text-yellow-600';
                title.textContent = 'Đánh dấu Vi phạm';
                warning.className = 'text-yellow-700 text-xs font-medium mb-4 bg-yellow-50 p-2.5 rounded-lg border border-yellow-200';
                warning.innerHTML = 'Lưu ý: Thao tác này sẽ ẩn bài viết, nhưng người dùng <strong>CÓ THỂ</strong> chỉnh sửa và gửi duyệt lại.';
                submitBtn.className = 'flex-1 py-2.5 text-white rounded-xl text-sm font-medium transition-colors bg-yellow-600 hover:bg-yellow-700';
            } else {
                iconWrapper.className = 'w-12 h-12 rounded-full flex items-center justify-center mb-4 bg-red-100 text-red-600';
                title.textContent = 'Xóa Bài Đăng';
                warning.className = 'text-red-700 text-xs font-medium mb-4 bg-red-50 p-2.5 rounded-lg border border-red-200';
                warning.innerHTML = 'Cảnh báo: Hành động này tước quyền chỉnh sửa và kháng cáo của người dùng. Chỉ áp dụng cho các vi phạm nghiêm trọng.';
                submitBtn.className = 'flex-1 py-2.5 text-white rounded-xl text-sm font-medium transition-colors bg-red-600 hover:bg-red-700';
            }

            document.getElementById('actionReasonModal').classList.remove('hidden');
        }

        function closeActionReasonModal() {
            document.getElementById('actionReasonModal').classList.add('hidden');
        }

        function openConfirmRestoreModal(productId) {
            document.getElementById('crm-productId').value = productId;
            document.getElementById('confirmRestoreModal').classList.remove('hidden');
        }

        function closeConfirmRestoreModal() {
            document.getElementById('confirmRestoreModal').classList.add('hidden');
        }

        function openConfirmApproveModal(productId) {
            document.getElementById('cam-productId').value = productId;
            document.getElementById('confirmApproveModal').classList.remove('hidden');
        }

        function closeConfirmApproveModal() {
            document.getElementById('confirmApproveModal').classList.add('hidden');
        }
    </script>
}
