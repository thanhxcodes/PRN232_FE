@{
    ViewData["Title"] = "Quản Lý Bài Đăng";
    Layout = "_Layout";
}

<div class="mb-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-6">
        <div>
            <h2 class="text-3xl text-gray-900 mb-2">Quản Lý Bài Đăng</h2>
            <p class="text-gray-600">Theo dõi, kiểm duyệt và quản lý các bài viết trên hệ thống</p>
        </div>
    </div>
    
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center">
        <i data-lucide="file-text" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Tính năng đang được phát triển</h3>
        <p class="text-gray-500">Giao diện MVC cho tính năng quản lý Bài đăng đang trong quá trình chuyển đổi.</p>
    </div>
</div>
