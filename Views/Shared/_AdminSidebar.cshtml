@{
    var actionName = ViewContext.RouteData.Values["Action"]?.ToString() ?? "Index";
}

<!-- Admin Sidebar -->
<aside id="main-sidebar"
       class="fixed left-0 top-0 h-screen bg-white z-50 transition-all duration-300 shadow-lg overflow-y-auto w-64 border-r border-gray-100 flex flex-col">
    
    <!-- Logo -->
    <div class="p-6 flex items-center gap-3">
        <img src="/images/logo.png" alt="REVORA Logo" class="w-10 h-10 rounded-full object-cover shadow-sm" />
        <div>
            <h1 class="text-base font-black text-gray-900 tracking-tight leading-tight">REVORA</h1>
            <p class="text-[10px] text-gray-500 uppercase font-bold tracking-widest">Admin Panel</p>
        </div>
    </div>
    
    <!-- User Profile -->
    <div class="px-4 mb-4">
        <div class="bg-gray-50 rounded-2xl p-4 flex items-center gap-3 border border-gray-100">
            <div class="w-10 h-10 bg-[#2D5A3D] rounded-full flex items-center justify-center text-white font-bold text-sm shadow-sm">
                S
            </div>
            <div>
                <h3 class="text-sm font-bold text-gray-900 leading-tight mb-0.5">SẾP TỔNG</h3>
                <p class="text-[11px] text-gray-500 flex items-center gap-1 font-medium">
                    <i data-lucide="shield" class="w-3 h-3 text-[#2D5A3D]"></i> Quản trị viên
                </p>
            </div>
        </div>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-4 space-y-1.5 overflow-y-auto custom-scrollbar">
        <a href="/Admin"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Index" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="layout-dashboard" class="w-5 h-5 flex-shrink-0 @(actionName == "Index" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Tổng Quan</span>
        </a>

        <a href="/Admin/Revenue"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Revenue" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="dollar-sign" class="w-5 h-5 flex-shrink-0 @(actionName == "Revenue" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Doanh Thu</span>
        </a>

        <a href="/Admin/Packages"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Packages" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="package" class="w-5 h-5 flex-shrink-0 @(actionName == "Packages" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Quản Lý Gói</span>
        </a>

        <a href="/Admin/Users"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Users" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="users" class="w-5 h-5 flex-shrink-0 @(actionName == "Users" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Người Dùng</span>
        </a>

        <a href="/Admin/Posts"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Posts" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="file-text" class="w-5 h-5 flex-shrink-0 @(actionName == "Posts" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Bài Đăng</span>
        </a>

        <a href="/Admin/Notifications"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Notifications" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="bell" class="w-5 h-5 flex-shrink-0 @(actionName == "Notifications" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Thông Báo</span>
        </a>

        <a href="/Admin/Announcements"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Announcements" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="calendar" class="w-5 h-5 flex-shrink-0 @(actionName == "Announcements" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Sự Kiện</span>
        </a>

        <a href="/Admin/Feedbacks"
           class="flex items-center space-x-3 px-4 py-3 rounded-xl transition-all font-semibold text-sm @(actionName == "Feedbacks" ? "bg-[#2D5A3D] text-white shadow-md shadow-[#2D5A3D]/20" : "text-gray-600 hover:bg-gray-100 hover:text-gray-900")">
            <i data-lucide="message-square" class="w-5 h-5 flex-shrink-0 @(actionName == "Feedbacks" ? "text-white" : "text-gray-500")"></i>
            <span class="sidebar-text">Ý Kiến Đóng Góp</span>
        </a>
    </nav>
    
    <div class="p-4 border-t border-gray-100 mt-auto">
        <a href="/"
           class="flex items-center space-x-3 px-4 py-3 transition-colors rounded-xl font-semibold text-sm text-gray-600 hover:bg-gray-100 hover:text-gray-900">
            <i data-lucide="arrow-left" class="w-5 h-5 flex-shrink-0 text-gray-500"></i>
            <span class="sidebar-text">Về trang chủ</span>
        </a>
        <form action="/Auth/Logout" method="post" class="mt-1">
            <button type="submit" class="w-full flex items-center space-x-3 px-4 py-3 transition-colors rounded-xl font-semibold text-sm text-red-600 hover:bg-red-50">
                <i data-lucide="log-out" class="w-5 h-5 flex-shrink-0 text-red-500"></i>
                <span class="sidebar-text">Đăng Xuất</span>
            </button>
        </form>
    </div>
</aside>

<!-- Spacer for content -->
<div id="sidebar-spacer" class="transition-all duration-300 w-64 flex-shrink-0 hidden md:block"></div>
