<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - REVORA</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS (compiled) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- SweetAlert2 -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.all.min.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="font-sans antialiased text-gray-900 bg-gray-50">

    <div class="min-h-screen bg-gray-50">
        <!-- Top Navbar -->
        @await Html.PartialAsync("_TopNavbar")

        <div class="pt-16 flex">
            <!-- Sidebar -->
            @if (ViewData["HideSidebar"] as bool? != true)
            {
                @await Html.PartialAsync("_Sidebar")
            }

            <!-- Main Content -->
            <main class="flex-1 overflow-hidden">
                @RenderBody()

                <!-- Footer (conditionally rendered in real app, but placed here for now) -->
                @if (ViewData["HideFooter"] as bool? != true)
                {
                    @await Html.PartialAsync("_Footer")
                }
            </main>
        </div>
    </div>

    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        lucide.createIcons();
    </script>



    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            window.globalConfig = {
                accessToken: '@Html.Raw(Context.User.Claims.FirstOrDefault(c => c.Type == "AccessToken")?.Value ?? "")',
                currentUserId: parseInt('@Html.Raw(Context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0")'),
                apiBaseUrl: '/api-proxy',
                hubUrl: '/api-proxy/chathub'
            };
        </script>
    }

    <!-- Global SignalR -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <!-- Custom JS for Sidebar/Navbar Toggles -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
