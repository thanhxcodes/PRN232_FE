<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - REVORA</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Raleway:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-white font-sans antialiased text-gray-900">

<div class="min-h-screen w-full flex flex-col lg:flex-row bg-white overflow-hidden">
    <!-- Left Panel - Brand (Hidden on Mobile) -->
    <div class="relative hidden lg:flex flex-1 flex-col justify-between bg-[#001a11] p-12 lg:p-16 xl:p-20 text-white overflow-hidden">
        <!-- Abstract background elements -->
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute -top-[20%] -left-[10%] w-[100%] h-[100%] bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-[#2D5A3D]/30 via-[#001a11]/0 to-transparent blur-3xl opacity-70"></div>
            <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 400 400\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noiseFilter\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'3\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noiseFilter)\'/%3E%3C/svg%3E'); mix-blend-mode: overlay;"></div>
        </div>

        <div class="relative z-10 flex items-center gap-3">
            <a href="/" class="flex items-center gap-3 group">
                <img src="/images/logo.png" alt="REVORA Logo" class="w-10 h-10 rounded-full" />
                <span class="text-2xl font-black text-white" style="font-family: 'Raleway', sans-serif; letter-spacing: 0.15em;">
                    REVORA
                </span>
            </a>
        </div>

        <div class="relative z-10 max-w-lg mt-auto mb-auto">
            <h1 class="text-5xl lg:text-6xl font-bold tracking-tight text-white mb-6 leading-[1.1]">
                Revive <br class="hidden lg:block" />
                <span class="text-white/70">Your Aura.</span>
            </h1>
            <p class="text-lg text-white/60 leading-relaxed font-medium">
                Khám phá thế giới thời trang bền vững. Nơi phong cách của bạn được tái sinh.
            </p>
        </div>

        <div class="relative z-10 text-sm text-white/40 font-medium">
            © 2026 REVORA. All rights reserved.
        </div>
    </div>

    <!-- Right Panel - Form Container -->
    <div class="flex-[0.8] xl:flex-[0.7] flex flex-col justify-center items-center p-6 sm:p-12 relative bg-white">
        
        <!-- Mobile Header (Hidden on Desktop) -->
        <div class="lg:hidden flex flex-col items-center mb-8 mt-4">
            <a href="/" class="flex items-center gap-3">
                <img src="/images/logo.png" alt="REVORA Logo" class="w-12 h-12 rounded-full shadow-sm" />
                <span class="text-2xl font-black text-[#001a11] tracking-tight" style="font-family: 'Raleway', sans-serif; letter-spacing: 0.15em;">
                    REVORA
                </span>
            </a>
        </div>

        <div class="w-full max-w-[420px]">
            @RenderBody()
        </div>
        
        <!-- Mobile Footer -->
        <p class="lg:hidden text-center text-gray-400 text-xs mt-12 font-medium">
            © 2026 REVORA. All rights reserved.
        </p>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script>
    lucide.createIcons();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
