@model dynamic

@{
    var title = Model.Title;
    var subtitle = Model.Subtitle;
    var icon = Model.Icon;
    var iconGradient = Model.IconGradient;
    var btnClass = Model.BtnClass;
    var sortQuery = Model.SortQuery;
    var products = Model.Products as List<REVORA_MVC_FE.Models.ProductResponseDto>;
}

@if (products != null && products.Count > 0)
{
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
        <div class="flex items-center justify-between mb-8">
            <div class="flex items-center space-x-3">
                <div class="p-2 bg-gradient-to-br @iconGradient rounded-full">
                    <i data-lucide="@icon" class="w-6 h-6 text-white"></i>
                </div>
                <div>
                    <h2 class="text-3xl text-gray-900 font-bold">@title</h2>
                    <p class="text-sm text-gray-600">@subtitle</p>
                </div>
            </div>
            <a href="/Products?sortBy=@sortQuery" class="flex items-center space-x-2 px-6 py-3 @btnClass rounded-full hover:shadow-lg hover:scale-105 transition-all font-semibold">
                <span>Tất Cả Sản Phẩm</span>
                <i data-lucide="chevron-right" class="w-5 h-5"></i>
            </a>
        </div>
        
        @await Html.PartialAsync("_ProductCarousel", products)
    </section>
}
