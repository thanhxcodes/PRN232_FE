<!-- Views/Shared/_AnnouncementPopup.cshtml -->
<div id="user-announcement-popup" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[9999] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="relative w-full max-w-4xl aspect-[21/9] rounded-2xl overflow-hidden shadow-2xl flex bg-[#1A1A1A] transform scale-95 transition-transform duration-300" id="user-announcement-content">
        <!-- Close Button -->
        <button id="user-ann-close" class="absolute top-4 right-4 z-20 w-8 h-8 flex items-center justify-center rounded-full bg-black/40 text-white/70 hover:bg-black/60 hover:text-white transition-colors backdrop-blur-md">
            <i data-lucide="x" class="w-5 h-5"></i>
        </button>

        <!-- Image Side -->
        <div class="w-[45%] h-full bg-black flex items-center justify-center relative overflow-hidden border-r border-white/5 group">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10"></div>
            <img id="user-ann-image" src="" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
            <div class="absolute inset-0 border border-white/10 m-4 rounded-xl z-10 pointer-events-none"></div>
        </div>
        
        <!-- Content Side -->
        <div class="w-[55%] p-10 flex flex-col justify-center relative bg-gradient-to-br from-[#1A1A1A] to-[#0A0A0A]">
            <!-- Decorative Elements -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-green-900/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-yellow-900/10 rounded-full blur-3xl translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>
            
            <div class="relative z-10">
                <div id="user-ann-badge-container" class="mb-4 hidden">
                    <span id="user-ann-badge" class="px-3 py-1 bg-gradient-to-r from-yellow-600/20 to-yellow-500/20 border border-yellow-500/30 text-yellow-500 text-[10px] font-bold rounded-full inline-flex items-center gap-1.5 uppercase tracking-wider">
                        <i data-lucide="sparkles" class="w-3 h-3"></i> 
                        <span id="user-ann-badge-text"></span>
                    </span>
                </div>
                
                <p class="text-xs font-bold tracking-[0.2em] text-white/40 mb-3 uppercase flex items-center gap-2">
                    <span class="w-4 h-[1px] bg-white/40"></span>
                    Bản tin đặc biệt
                </p>
                <h3 id="user-ann-title" class="text-white font-bold text-3xl leading-tight mb-4">Tiêu đề</h3>
                <p id="user-ann-description" class="text-white/60 text-sm leading-relaxed mb-8 line-clamp-4 font-light">Mô tả</p>
                
                <div class="flex items-center gap-4">
                    <button id="user-ann-later" class="flex-1 py-3.5 text-sm font-medium text-white/50 text-center rounded-xl border border-white/10 hover:bg-white/5 hover:text-white transition-all">Để xem sau</button>
                    <button id="user-ann-button" class="flex-1 py-3.5 bg-white text-black text-sm font-bold text-center rounded-xl shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_30px_rgba(255,255,255,0.2)] hover:scale-[1.02] transition-all duration-300">Khám phá ngay</button>
                </div>

                <div class="mt-6 flex items-center gap-3">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <div class="relative w-8 h-4 bg-white/10 rounded-full transition-colors group-hover:bg-white/20">
                            <input type="checkbox" id="user-ann-hide-checkbox" class="sr-only peer">
                            <div class="absolute left-0.5 top-0.5 w-3 h-3 bg-white/50 rounded-full transition-transform peer-checked:translate-x-4 peer-checked:bg-white"></div>
                        </div>
                        <span class="text-[10px] text-white/30 font-medium group-hover:text-white/50 transition-colors">Tạm ẩn các sự kiện trong 4 giờ tới</span>
                    </label>
                </div>
            </div>

            <!-- Navigation Controls -->
            <div id="user-ann-nav" class="absolute bottom-6 right-8 flex items-center gap-4 z-10 hidden">
                <div class="flex gap-1.5" id="user-ann-dots">
                    <!-- Dots generated by JS -->
                </div>
                <div class="flex items-center gap-2 ml-4">
                    <button id="user-ann-prev" class="p-1.5 rounded-lg border border-white/10 text-white/30 hover:text-white hover:bg-white/10 transition-all">
                        <i data-lucide="chevron-left" class="w-4 h-4"></i>
                    </button>
                    <button id="user-ann-next" class="p-1.5 rounded-lg border border-white/10 text-white/30 hover:text-white hover:bg-white/10 transition-all">
                        <i data-lucide="chevron-right" class="w-4 h-4"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
