@inject REVORA_MVC_FE.Services.ApiService ApiService
<nav class="fixed top-0 left-0 right-0 z-50 bg-[#2D5A3D] shadow-lg" style="background-color: #2D5A3D;">
    <!-- Animated Background & Sparkles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.15) 2px, transparent 0); background-size: 24px 24px;">
        <i data-lucide="sparkles" class="absolute top-2 left-[20%] w-4 h-4 text-emerald-300 opacity-50 animate-pulse delay-150"></i>
        <i data-lucide="sparkles" class="absolute top-4 right-[25%] w-3 h-3 text-emerald-400 opacity-70 animate-bounce delay-700"></i>
        <i data-lucide="sparkles" class="absolute top-10 right-[15%] w-2 h-2 text-emerald-500 opacity-40 animate-pulse delay-500"></i>
    </div>

    <div class="flex items-center justify-between h-16 px-4 relative z-10">
        <!-- Left: Menu + Logo -->
        <div class="flex items-center space-x-4">
            <button id="menu-toggle-btn" class="text-white hover:bg-white/10 p-2 rounded-lg transition-colors">
                <i data-lucide="menu" class="w-6 h-6"></i>
            </button>
            <a href="/" class="flex items-center gap-2.5">
                <img src="/images/logo.png" alt="REVORA Logo" class="w-9 h-9 rounded-full object-cover" />
                <div class="flex flex-col leading-none">
                    <span class="text-white text-xl font-bold tracking-widest" style="font-family: 'Raleway', sans-serif; letter-spacing: 0.22em;">REVORA</span>
                    <span class="text-white/50 text-[8px] tracking-[0.18em] uppercase">Revive Your Aura</span>
                </div>
            </a>
        </div>

        <!-- Center: Search -->
        <div class="flex-1 max-w-2xl mx-8 hidden md:block">
            <form action="/Products" method="get" class="relative">
                <input type="text" name="search" placeholder="Tìm kiếm sản phẩm thời trang..."
                       class="w-full px-4 py-2 pl-10 rounded-full bg-white/10 backdrop-blur-sm text-white placeholder-white/70 border border-white/20 focus:outline-none focus:ring-2 focus:ring-white/30" />
                <button type="submit" class="absolute left-3 top-1/2 -translate-y-1/2 text-white/70 hover:text-white transition-colors">
                    <i data-lucide="search" class="w-5 h-5"></i>
                </button>
            </form>
        </div>

        <!-- Right: Actions -->
        <div class="flex items-center space-x-3">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                var postingCredits = 0;
                var featuredCredits = 0;
                List<REVORA_MVC_FE.Models.CreditBatchDto> postingBatches = new();
                List<REVORA_MVC_FE.Models.CreditBatchDto> featuredBatches = new();
                
                var creditsRes = await ApiService.GetMyCreditsAsync();
                if (creditsRes?.Data != null)
                {
                    postingCredits = creditsRes.Data.PostingCredits;
                    featuredCredits = creditsRes.Data.FeaturedCredits;
                }
                var postingSummary = await ApiService.GetPostingCreditSummaryAsync();
                if (postingSummary != null) postingBatches = postingSummary.Batches;
                var featuredSummary = await ApiService.GetFeaturedCreditSummaryAsync();
                if (featuredSummary != null) featuredBatches = featuredSummary.Batches;

                <!-- Credits badges -->
                <div class="hidden lg:flex items-center gap-1 bg-white/10 backdrop-blur-sm px-2 py-1 rounded-full border border-white/20">
                    <div class="relative group cursor-pointer">
                        <div class="flex items-center space-x-2 backdrop-blur-sm px-3 py-1.5 rounded-full border border-white/20" style="background-color: rgba(71, 85, 105, 0.8);">
                            <i data-lucide="image" class="w-4 h-4 text-white"></i>
                            <span class="font-semibold text-sm text-white">@postingCredits</span>
                        </div>
                        <div class="absolute right-0 top-10 w-72 bg-white rounded-2xl shadow-2xl border border-gray-100 p-4 z-50 hidden group-hover:block transition-all">
                            <div class="text-sm font-semibold text-gray-900 mb-3 flex items-center justify-between">
                                <div>
                                    <span>Đăng Tin</span>
                                    <span class="ml-2 text-blue-600">@postingCredits credits</span>
                                </div>
                            </div>
                            <div class="space-y-2 max-h-60 overflow-y-auto">
                                @foreach(var batch in postingBatches)
                                {
                                    <div class="flex justify-between items-start text-xs bg-gray-50 rounded-lg p-3 border-b border-gray-100 last:border-0">
                                        <div>
                                            <div class="font-bold text-sm text-blue-600">@batch.RemainingCredits credits</div>
                                            @if(!string.IsNullOrEmpty(batch.PackageName)) { <div class="text-gray-500 mt-0.5">@batch.PackageName</div> }
                                        </div>
                                        <div class="text-right">
                                            <div class="text-gray-600">HSD: @(string.IsNullOrEmpty(batch.ExpiresAt) ? "Vĩnh viễn" : DateTime.Parse(batch.ExpiresAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="relative group cursor-pointer ml-1">
                        <div class="flex items-center space-x-2 backdrop-blur-sm px-3 py-1.5 rounded-full border border-white/20" style="background-color: rgba(180, 83, 9, 0.6);">
                            <i data-lucide="sparkles" class="w-4 h-4 text-white"></i>
                            <span class="font-semibold text-sm text-white">@featuredCredits</span>
                        </div>
                        <div class="absolute right-0 top-10 w-72 bg-white rounded-2xl shadow-2xl border border-gray-100 p-4 z-50 hidden group-hover:block transition-all">
                            <div class="text-sm font-semibold text-gray-900 mb-3 flex items-center justify-between">
                                <div>
                                    <span>Nổi Bật</span>
                                    <span class="ml-2 text-orange-600">@featuredCredits credits</span>
                                </div>
                            </div>
                            <div class="space-y-2 max-h-60 overflow-y-auto">
                                @foreach(var batch in featuredBatches)
                                {
                                    <div class="flex justify-between items-start text-xs bg-gray-50 rounded-lg p-3 border-b border-gray-100 last:border-0">
                                        <div>
                                            <div class="font-bold text-sm text-orange-600">@batch.RemainingCredits credits</div>
                                            @if(!string.IsNullOrEmpty(batch.PackageName)) { <div class="text-gray-500 mt-0.5">@batch.PackageName</div> }
                                        </div>
                                        <div class="text-right">
                                            <div class="text-gray-600">HSD: @(string.IsNullOrEmpty(batch.ExpiresAt) ? "Vĩnh viễn" : DateTime.Parse(batch.ExpiresAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <a href="/Plans" class="w-7 h-7 ml-1 bg-white/15 hover:bg-white/25 rounded-full flex items-center justify-center transition-colors" title="Nạp thêm credits">
                        <i data-lucide="plus" class="w-4 h-4 text-white"></i>
                    </a>
                </div>

                <!-- Nút Đăng tin -->
                <div class="hidden md:flex items-center relative">
                    <style>
                        @@keyframes shimmer {
                            0% { transform: translateX(-150%) skewX(-20deg); }
                            100% { transform: translateX(150%) skewX(-20deg); }
                        }
                        .btn-sparkle::after {
                            content: '';
                            position: absolute;
                            top: 0;
                            left: 0;
                            width: 50%;
                            height: 100%;
                            background: linear-gradient(to right, transparent, rgba(255,255,255,0.6), transparent);
                            transform: translateX(-150%) skewX(-20deg);
                            animation: shimmer 2s infinite;
                        }
                    </style>
                    <a href="/Products/Create" class="btn-sparkle relative text-gray-900 px-6 py-2 rounded-full shadow-[0_0_15px_rgba(245,158,11,0.7)] hover:shadow-[0_0_25px_rgba(245,158,11,0.9)] hover:scale-105 transition-all duration-300 text-[15px] font-bold flex items-center gap-1.5 border border-amber-300/50 overflow-hidden" style="background: linear-gradient(to right, #fbbf24, #fb923c, #f59e0b); color: #fff;">
                        <i data-lucide="sparkles" class="w-4 h-4 text-white animate-pulse"></i>
                        Đăng tin
                    </a>
                </div>

                <!-- Nút Liên hệ -->
                <div class="hidden sm:flex items-center">
                    <a href="/Chat" class="relative bg-white text-gray-900 border border-gray-200 px-4 py-[7px] rounded-full hover:bg-gray-100 hover:shadow-md transition-all text-[15px] font-semibold flex items-center gap-2">
                        <i data-lucide="message-circle" class="w-5 h-5 text-gray-800" stroke-width="2.5"></i>
                        Liên hệ
                        <span id="global-unread-chat-count" class="absolute -top-1.5 -right-1.5 min-w-[20px] h-5 px-1.5 bg-[#C4603A] rounded-full text-[11px] flex items-center justify-center text-white font-bold border-2 border-white shadow-sm hidden">0</span>
                    </a>
                </div>

                <!-- Wishlist Icon -->
                <a href="/Profile?tab=wishlist" class="text-white/80 hover:text-white transition-colors relative p-1" id="nav-wishlist-btn">
                    <i data-lucide="heart" class="w-6 h-6"></i>
                    <span id="global-wishlist-count" class="absolute -top-1 -right-1 bg-[#C4603A] text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center hidden border border-[#2D5A3D]">0</span>
                </a>
                
                <!-- Bell / Notifications -->
                <div class="relative">
                    <button class="text-white/80 hover:text-white transition-colors relative p-1">
                        <i data-lucide="bell" class="w-6 h-6"></i>
                    </button>
                </div>

                <!-- User avatar menu -->
                <div class="relative group pt-2 pb-2">
                    <div class="w-9 h-9 rounded-full flex items-center justify-center text-[#2D5A3D] transition-colors font-bold text-sm overflow-hidden border border-white/20 bg-white hover:bg-gray-100 cursor-pointer">
                        @{
                            var avatarUrl = User.Claims.FirstOrDefault(c => c.Type == "AvatarUrl")?.Value;
                            var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? "User";
                            var username = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Name)?.Value ?? "user1";
                        }
                        @if (!string.IsNullOrEmpty(avatarUrl)) {
                            <img src="@avatarUrl" alt="Avatar" class="w-full h-full object-cover" />
                        } else {
                            @fullName.FirstOrDefault()
                        }
                    </div>

                    <!-- Dropdown Menu -->
                    <div class="absolute right-0 top-full mt-0 w-56 bg-white rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] py-2 invisible opacity-0 translate-y-2 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 border border-gray-100 z-50">
                        <div class="px-4 py-3 border-b border-gray-100">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-100 flex items-center justify-center shrink-0">
                                    @if (!string.IsNullOrEmpty(avatarUrl)) {
                                        <img src="@avatarUrl" alt="Avatar" class="w-full h-full object-cover" />
                                    } else {
                                        <span class="text-[#2D5A3D] font-bold text-lg">@fullName.FirstOrDefault()</span>
                                    }
                                </div>
                                <div class="flex flex-col min-w-0">
                                    <span class="text-sm font-bold text-gray-900 leading-tight truncate">@fullName</span>
                                    <span class="text-xs text-gray-500 truncate">@@@username</span>
                                </div>
                            </div>
                        </div>

                        <div class="py-2">
                            <a href="/Plans" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#2D5A3D] transition-colors">
                                <i data-lucide="sparkles" class="w-4 h-4 text-[#2D5A3D]"></i>
                                Nạp Credits
                            </a>
                            <a href="/Profile" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#2D5A3D] transition-colors">
                                <i data-lucide="user" class="w-4 h-4 text-gray-500"></i>
                                Trang Cá Nhân
                            </a>
                            <a href="/Products/Manage" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 hover:text-[#2D5A3D] transition-colors">
                                <i data-lucide="list" class="w-4 h-4 text-gray-500"></i>
                                Quản Lí Tin
                            </a>
                        </div>
                        
                        <div class="border-t border-gray-100 py-1">
                            <form action="/Auth/Logout" method="post" class="block w-full m-0">
                                <button type="submit" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 transition-colors cursor-pointer text-left">
                                    <i data-lucide="log-out" class="w-4 h-4"></i>
                                    Đăng Xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="flex items-center gap-3">
                    <a href="/Auth/Login" class="text-white px-5 py-2 rounded-full hover:bg-white/10 transition-all text-sm">
                        Đăng Nhập
                    </a>
                    <a href="/Auth/Register" class="bg-white text-[#2D5A3D] px-5 py-2 rounded-full hover:shadow-lg transition-all text-sm font-semibold">
                        Đăng Ký
                    </a>
                </div>
            }
        </div>
    </div>
</nav>
