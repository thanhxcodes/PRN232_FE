                                                                        li.querySelector('span').innerHTML = '<svg viewBox="0 0 12 12" fill="none" class="w-3 h-3"><circle cx="6" cy="6" r="6" class="fill-green-500" /><path d="M3.5 6l2 2 3-3" stroke="white" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" /></svg>';
