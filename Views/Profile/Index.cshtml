                                            @section Scripts {
                                                <script>
                                                    const initialProfile = @Html.Raw(Json.Serialize(profile));
                                                    let currentTab = '@activeTab';
                                                    let isEditing = false;
                                                    let isOwnProfile = @(isOwnProfile.ToString().ToLower());
                                                    let targetUserId = '@currentUserId';
                                                    let publicViewMode = false;
                                                    
                                                    // Image upload state
                                                    let uploadedAvatarUrl = null;
                                                    let uploadedBannerUrl = null;
                                                    let isUploadingAvatar = false;
                                                    let _barCancelCallback = null;

                                                    function showImageChangeBar(previewUrl, onCancel, type = 'avatar') {
                                                        const bar = document.getElementById('image-change-bar');
                                                        const preview = document.getElementById('bar-avatar-preview');
                                                        const label = bar.querySelector('span.text-sm');
                                                        const sub = bar.querySelector('span.text-xs');

                                                        // Set preview thumbnail
                                                        if (previewUrl) {
                                                            preview.style.backgroundImage = `url('${previewUrl}')`;
                                                            preview.classList.remove('hidden');
                                                        } else {
                                                            preview.classList.add('hidden');
                                                        }

                                                        // Update label based on type
                                                        if (type === 'banner') {
                                                            label.textContent = 'Ảnh bìa đã thay đổi';
                                                            sub.textContent = 'Nhấn Lưu để áp dụng thay đổi';
                                                        } else {
                                                            label.textContent = 'Ảnh đại diện đã thay đổi';
                                                            sub.textContent = 'Nhấn Lưu để áp dụng thay đổi';
                                                        }

                                                        // Re-animate (force reflow)
                                                        const inner = bar.querySelector('.animate-slide-up-bar');
                                                        inner.classList.remove('animate-slide-up-bar');
                                                        void inner.offsetWidth; // reflow
                                                        inner.classList.add('animate-slide-up-bar');

                                                        _barCancelCallback = onCancel;
                                                        bar.classList.remove('hidden');
                                                        lucide.createIcons();
                                                    }

                                                    function hideImageChangeBar() {
                                                        document.getElementById('image-change-bar').classList.add('hidden');
                                                        _barCancelCallback = null;
                                                    }

                                                    // Avatar Dropdown logic
                                                    const AVATAR_COLORS = [
                                                        '#2D5A3D', '#1a1a2e', '#0f3460', '#533483', '#2d6a4f', '#b5451b', '#774936', '#374151'
                                                    ];
                                                    const dropdown = document.getElementById('avatar-dropdown');
                                                    const colorGrid = document.getElementById('avatar-color-grid');
                                                    
                                                    function renderAvatarColors() {
                                                        colorGrid.innerHTML = '';
                                                        AVATAR_COLORS.forEach(color => {
                                                            const btn = document.createElement('button');
                                                            btn.className = 'w-10 h-10 rounded-full transition-transform hover:scale-110';
                                                            btn.style.backgroundColor = color;
                                                            // Just visual selection, backend doesn't save AvatarColor, but we apply it
                                                            btn.addEventListener('click', () => {
                                                                document.getElementById('profile-avatar').style.backgroundImage = '';
                                                                document.getElementById('profile-avatar').style.backgroundColor = color;
                                                                document.getElementById('profile-initials').innerText = (initialProfile.fullName || 'U').substring(0, 1).toUpperCase();
                                                                uploadedAvatarUrl = null; 
                                                                dropdown.classList.add('hidden');
                                                            });
                                                            colorGrid.appendChild(btn);
                                                        });
                                                    }

                                                    // Initialize UI
                                                    document.addEventListener('DOMContentLoaded', () => {
                                                        lucide.createIcons();
                                                        switchTab(currentTab);
                                                        renderAvatarColors();

                                                        // Eagerly load data for badges/stats
                                                        loadProducts();
                                                        if (isOwnProfile) loadWishlist();

                                                        // Avatar trigger toggle
                                                        document.getElementById('avatar-picker-overlay')?.addEventListener('click', (e) => {
                                                            e.stopPropagation();
                                                            dropdown.classList.toggle('hidden');
                                                        });
                                                        document.addEventListener('click', (e) => {
                                                            const trigger = document.getElementById('avatar-picker-overlay');
                                                            if (dropdown && trigger && !dropdown.contains(e.target) && !trigger.contains(e.target)) {
                                                                dropdown.classList.add('hidden');
                                                            }
                                                        });

                                                        // Image change bar — Save & Cancel
                                                        document.getElementById('bar-save-btn')?.addEventListener('click', async () => {
                                                            const btn = document.getElementById('bar-save-btn');
                                                            btn.disabled = true;
                                                            btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Đang lưu...';
                                                            lucide.createIcons();
                                                            try {
                                                                await saveAvatarOnly();
                                                                hideImageChangeBar();
                                                            } finally {
                                                                btn.disabled = false;
                                                                btn.innerHTML = '<i data-lucide="save" class="w-4 h-4"></i> Lưu ngay';
                                                                lucide.createIcons();
                                                            }
                                                        });

                                                        document.getElementById('bar-cancel-btn')?.addEventListener('click', () => {
                                                            if (typeof _barCancelCallback === 'function') _barCancelCallback();
                                                            hideImageChangeBar();
                                                        });

                                                        // Tab click events
                                                        document.querySelectorAll('.profile-tab-btn').forEach(btn => {
                                                            btn.addEventListener('click', (e) => {
                                                                switchTab(e.currentTarget.dataset.tab);
                                                            });
                                                        });

                                                        // Render initial profile
                                                        renderProfileView(initialProfile);

                                                        // Edit button toggle
                                                        const btnEdit = document.getElementById('btn-edit-profile');
                                                        if (btnEdit) {
                                                            btnEdit.addEventListener('click', () => {
                                                                isEditing = true;
                                                                switchTab('profile');
                                                                document.getElementById('profile-view-mode').classList.add('hidden');
                                                                document.getElementById('profile-edit-mode').classList.remove('hidden');
                                                                document.getElementById('avatar-picker-overlay').classList.remove('hidden');
                                                                document.getElementById('banner-picker-container').classList.remove('hidden');
                                                                populateEditForm(initialProfile);
                                                                btnEdit.classList.add('hidden');
                                                            });
                                                        }

                                                        document.getElementById('btn-cancel-edit')?.addEventListener('click', () => {
                                                            isEditing = false;
                                                            document.getElementById('profile-edit-mode').classList.add('hidden');
                                                            document.getElementById('profile-view-mode').classList.remove('hidden');
                                                            document.getElementById('avatar-picker-overlay').classList.add('hidden');
                                                            document.getElementById('banner-picker-container').classList.add('hidden');
                                                            btnEdit.classList.remove('hidden');
                                                            
                                                            // Restore Avatar and Banner
                                                            uploadedAvatarUrl = null;
                                                            uploadedBannerUrl = null;
                                                            if (initialProfile.avatarUrl) {
                                                                document.getElementById('profile-avatar').style.backgroundImage = `url('${initialProfile.avatarUrl}')`;
                                                                document.getElementById('profile-initials').innerText = '';
                                                            } else {
                                                                document.getElementById('profile-avatar').style.backgroundImage = '';
                                                                document.getElementById('profile-initials').innerText = (initialProfile.fullName || 'U').substring(0, 1).toUpperCase();
                                                            }
