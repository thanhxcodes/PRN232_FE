                                                    function showToast(message, type = 'success') {
                                                        const container = document.getElementById('toast-container');
                                                        const toast = document.createElement('div');

                                                        // Animation and styling classes
                                                        toast.className = `transform transition-all duration-300 translate-y-10 opacity-0 pointer-events-auto flex items-center gap-3 px-6 py-4 rounded-2xl shadow-xl font-medium text-sm ${type === 'success' ? 'bg-[#2D5A3D] text-white' : 'bg-red-500 text-white'}`;

                                                        const icon = type === 'success' ? 'check-circle' : 'alert-circle';
                                                        toast.innerHTML = `<i data-lucide="${icon}" class="w-5 h-5"></i> <span>${message}</span>`;

                                                        container.appendChild(toast);
                                                        lucide.createIcons();

                                                        // Trigger animation in
                                                        requestAnimationFrame(() => {
                                                            toast.classList.remove('translate-y-10', 'opacity-0');
                                                        });

                                                        // Remove after 3 seconds
                                                        setTimeout(() => {
                                                            toast.classList.add('opacity-0', 'translate-y-2');
                                                            setTimeout(() => toast.remove(), 300);
                                                        }, 3000);
                                                    }

                                                    function formatCount(count) {
                                                        return count >= 1000 ? (count / 1000.0).toFixed(1).replace('.0', '') + "k" : count.toString();
                                                    }

                                                    function switchTab(tabId) {
                                                        currentTab = tabId;
                                                        // Update URL
                                                        const url = new URL(window.location);
                                                        url.searchParams.set('tab', tabId);
                                                        window.history.pushState({}, '', url);

                                                        // Update buttons
                                                        document.querySelectorAll('.profile-tab-btn').forEach(btn => {
                                                            if (btn.dataset.tab === tabId) {
                                                                btn.classList.add('active');
                                                            } else {
                                                                btn.classList.remove('active');
                                                            }
                                                        });

                                                        // Update content
                                                        document.querySelectorAll('.tab-content').forEach(content => {
                                                            if (content.id === `tab-content-${tabId}`) {
                                                                content.classList.remove('opacity-0', 'pointer-events-none');
                                                                content.classList.add('opacity-100');
                                                                content.style.position = 'relative'; // to let it take height
                                                            } else {
                                                                content.classList.remove('opacity-100');
                                                                content.classList.add('opacity-0', 'pointer-events-none');
                                                                content.style.position = 'absolute';
                                                            }
                                                        });

                                                        // Load data if needed
                                                        if (tabId === 'products') loadProducts();
                                                        if (tabId === 'wishlist') loadWishlist();
                                                    }

                                                    function renderProfileView(profile) {
                                                        if (!profile) return;
                                                        const container = document.getElementById('profile-view-mode');

                                                        const fields = [
                                                            { label: 'Họ và Tên', value: profile.fullName, icon: 'user' },
                                                            { label: 'Email', value: profile.email, icon: 'mail' },
                                                            { label: 'Số Điện Thoại', value: profile.phone, icon: 'phone' },
                                                            { label: 'Ngày Sinh', value: profile.birthday ? new Date(profile.birthday).toLocaleDateString('vi-VN') : '', icon: 'calendar' },
                                                            { label: 'Giới Tính', value: profile.gender === 'female' ? 'Nữ' : profile.gender === 'male' ? 'Nam' : 'Khác', icon: 'user' },
                                                            { label: 'Thành Phố', value: profile.city, icon: 'map-pin' },
                                                            { label: 'Địa Chỉ', value: profile.address, icon: 'map-pin', fullWidth: true }
                                                        ];

                                                        let html = '';
                                                        fields.forEach(f => {
                                                            const isGuestView = !isOwnProfile || publicViewMode;
                                                            if (isGuestView && !['Họ và Tên', 'Thành Phố'].includes(f.label)) return;

                                                            html += `
                                                                <div class="flex items-start gap-4 p-5 bg-gray-50/50 hover:bg-gray-50 rounded-2xl border border-gray-100/50 transition-colors ${f.fullWidth ? 'md:col-span-2' : ''}">
                                                                    <div class="w-10 h-10 bg-white shadow-sm border border-gray-100 rounded-xl flex items-center justify-center text-[#2D5A3D] flex-shrink-0">
                                                                        <i data-lucide="${f.icon}" class="w-[18px] h-[18px]"></i>
                                                                    </div>
                                                                    <div>
                                                                        <div class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-1">${f.label}</div>
                                                                        <div class="text-gray-900 font-medium text-[15px]">${f.value || '—'}</div>
                                                                    </div>
                                                                </div>
                                                                `;
                                                        });

                                                        html += `
                                                            <div class="md:col-span-2 p-5 bg-gray-50/50 hover:bg-gray-50 rounded-2xl border border-gray-100/50 transition-colors mt-2">
                                                                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wider mb-3">Tiểu Sử</div>
                                                                <p class="text-gray-700 leading-relaxed text-[15px]">${profile.bio || 'Chưa có thông tin tiểu sử.'}</p>
                                                            </div>
                                                            `;

                                                        container.innerHTML = html;
                                                        lucide.createIcons();
                                                    }

                                                    // Save image-only (avatar and/or banner) — called from the floating bar
                                                    async function saveAvatarOnly() {
                                                        try {
                                                            const payload = {
                                                                fullName: initialProfile.fullName,
                                                                bio: initialProfile.bio,
                                                                birthday: initialProfile.birthday || null,
                                                                gender: initialProfile.gender,
                                                                phone: initialProfile.phone,
                                                                city: initialProfile.city,
                                                                address: initialProfile.address,
                                                                // Use the newly uploaded URL, or keep existing
                                                                avatarUrl: uploadedAvatarUrl || initialProfile.avatarUrl,
                                                                bannerUrl: uploadedBannerUrl || initialProfile.bannerUrl
                                                            };
                                                            const response = await fetch('/Profile/UpdateProfile', {
                                                                method: 'PUT',
                                                                headers: { 'Content-Type': 'application/json' },
                                                                body: JSON.stringify(payload)
                                                            });
                                                            const result = await response.json();
                                                            if (result.success) {
                                                                // Sync memory
                                                                let changedMsg = 'Ảnh đã được cập nhật! 🎉';
                                                                if (uploadedAvatarUrl && uploadedBannerUrl) {
                                                                    changedMsg = 'Ảnh đại diện và Ảnh bìa đã được cập nhật! 🎉';
                                                                } else if (uploadedAvatarUrl) {
                                                                    changedMsg = 'Ảnh đại diện đã được cập nhật! 🎉';
                                                                } else if (uploadedBannerUrl) {
                                                                    changedMsg = 'Ảnh bìa đã được cập nhật! 🎉';
                                                                }

                                                                if (uploadedAvatarUrl) initialProfile.avatarUrl = uploadedAvatarUrl;
                                                                if (uploadedBannerUrl) initialProfile.bannerUrl = uploadedBannerUrl;
                                                                uploadedAvatarUrl = null;
                                                                uploadedBannerUrl = null;
                                                                
                                                                showToast(changedMsg);
                                                            } else {
                                                                showToast(result.message || 'Lưu ảnh thất bại', 'error');
                                                            }
                                                        } catch (err) {
                                                            showToast('Lỗi kết nối khi lưu ảnh', 'error');
                                                        }
                                                    }

                                                    function populateEditForm(profile) {
                                                        document.getElementById('edit-name').value = profile.fullName || '';
                                                        document.getElementById('edit-bio').value = profile.bio || '';

                                                        if (profile.birthday) {
                                                            const d = new Date(profile.birthday);
                                                            const year = d.getFullYear();
                                                            const month = String(d.getMonth() + 1).padStart(2, '0');
                                                            const day = String(d.getDate()).padStart(2, '0');
                                                            document.getElementById('edit-birthday').value = `${year}-${month}-${day}`;
                                                        } else {
                                                            document.getElementById('edit-birthday').value = '';
                                                        }

                                                        document.getElementById('edit-gender').value = profile.gender?.toLowerCase() || '';
                                                        document.getElementById('edit-phone').value = profile.phone || '';
                                                        document.getElementById('edit-city').value = profile.city || '';
                                                        document.getElementById('edit-address').value = profile.address || '';
                                                    }

                                                    async function saveProfile() {
                                                        const btnSave = document.getElementById('btn-save-edit');
                                                        if (btnSave) {
                                                            btnSave.disabled = true;
                                                            btnSave.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Đang lưu...';
                                                            lucide.createIcons();
                                                        }

                                                        // If called from avatar save bar but not in edit mode, make sure we have the form values
                                                        const getVal = (id, fallback = '') => {
                                                            const el = document.getElementById(id);
                                                            return el ? el.value : fallback;
                                                        };

                                                        const data = {
                                                            fullName: getVal('edit-name') || initialProfile.fullName,
                                                            bio: getVal('edit-bio') || initialProfile.bio,
                                                            birthday: getVal('edit-birthday') || initialProfile.birthday || null,
                                                            gender: getVal('edit-gender') || initialProfile.gender,
                                                            phone: getVal('edit-phone') || initialProfile.phone,
                                                            city: getVal('edit-city') || initialProfile.city,
                                                            address: getVal('edit-address') || initialProfile.address,
                                                            avatarUrl: uploadedAvatarUrl !== null ? uploadedAvatarUrl : initialProfile.avatarUrl,
                                                            bannerUrl: uploadedBannerUrl !== null ? uploadedBannerUrl : initialProfile.bannerUrl
                                                        };

                                                        try {
                                                            const response = await fetch('/Profile/UpdateProfile', {
                                                                method: 'PUT',
                                                                headers: { 'Content-Type': 'application/json' },
                                                                body: JSON.stringify(data)
                                                            });
                                                            const result = await response.json();

                                                            if (result.success) {
                                                                // Update initialProfile memory
                                                                Object.assign(initialProfile, result.data);
                                                                // Also sync avatar/banner into initialProfile if we uploaded new ones
                                                                if (uploadedAvatarUrl) initialProfile.avatarUrl = uploadedAvatarUrl;
                                                                if (uploadedBannerUrl) initialProfile.bannerUrl = uploadedBannerUrl;

                                                                // Update DOM elements outside tab
                                                                document.getElementById('profile-name').innerText = initialProfile.fullName;
                                                                document.getElementById('profile-bio').innerText = initialProfile.bio || 'Chưa có thông tin tiểu sử.';
                                                                document.getElementById('profile-city').innerText = initialProfile.city || 'Chưa có thông tin';

                                                                // Reset upload state
                                                                uploadedAvatarUrl = null;
                                                                uploadedBannerUrl = null;
                                                                hideImageChangeBar();

                                                                // Switch back to view mode
                                                                document.getElementById('btn-cancel-edit').click();
                                                                renderProfileView(initialProfile);
                                                                showToast("Cập nhật hồ sơ thành công!");
                                                            } else {
                                                                showToast(result.message || "Lỗi cập nhật hồ sơ", "error");
                                                            }
                                                        } catch (err) {
                                                            showToast("Lỗi hệ thống khi cập nhật hồ sơ", "error");
                                                        } finally {
                                                            if (btnSave) {
                                                                btnSave.disabled = false;
                                                                btnSave.innerHTML = '<i data-lucide="save" class="w-4 h-4"></i> Lưu thay đổi';
                                                                lucide.createIcons();
                                                            }
                                                        }
                                                    }

                                                    let currentPage = 1;
                                                    let isLoadingMore = false;
                                                    let hasMoreProducts = true;

                                                    async function loadProducts(page = 1) {
                                                        const container = document.getElementById('products-list');
                                                        const spinner = document.getElementById('load-more-spinner');

                                                        if (page === 1 && container.dataset.loaded) return; // Prevent double load on init
                                                        if (isLoadingMore || (!hasMoreProducts && page > 1)) return;

                                                        isLoadingMore = true;

                                                        if (page === 1) {
                                                            container.innerHTML = '<div class="flex justify-center p-8 w-full"><i data-lucide="loader-2" class="w-8 h-8 animate-spin text-[#2D5A3D]"></i></div>';
                                                            lucide.createIcons();
                                                        } else {
                                                            if (spinner) spinner.classList.remove('hidden');
                                                        }

                                                        try {
                                                            const url = `/Profile/GetProducts?sellerId=${targetUserId}&pageIndex=${page}`;
                                                            const response = await fetch(url);
                                                            const result = await response.json();

                                                            // TẠM THỜI: Giữ một chút delay (400ms) để UI có cảm giác mượt mà và thấy được loading spinner
                                                            await new Promise(resolve => setTimeout(resolve, 400));

                                                            if (result.success && result.data && result.data.items) {
                                                                const items = result.data.items;
                                                                if (page === 1) container.innerHTML = ''; // clear loading

                                                                if (items.length === 0 && page === 1) {
                                                                    const emptyMessage = isOwnProfile ? 'Bạn chưa đăng bán sản phẩm nào.' : 'Người này chưa đăng bán sản phẩm nào.';
                                                                    container.innerHTML = `<div class="bg-white/80 backdrop-blur-xl border border-white/60 rounded-[32px] shadow-sm p-12 text-center">
                                                                            <i data-lucide="package" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
                                                                            <h3 class="text-lg font-semibold text-gray-700 mb-2">Chưa có sản phẩm nào đang bán</h3>
                                                                            <p class="text-gray-500 text-sm">${emptyMessage}</p>
                                                                        </div>`;
                                                                    hasMoreProducts = false;
                                                                } else {
                                                                    renderProductList(container, items, page > 1);
                                                                    hasMoreProducts = page < result.data.totalPages;
                                                                }

                                                                if (page === 1) container.dataset.loaded = "true";

                                                                // Update badges
                                                                const totalCount = result.data.totalCount || items.length;
                                                                document.getElementById('stat-selling').innerText = totalCount;
                                                                const badge = document.getElementById('badge-products');
                                                                badge.innerText = totalCount;
                                                                badge.classList.remove('hidden');

                                                                currentPage = page;
                                                            } else {
                                                                if (page === 1) container.innerHTML = `<div class="w-full text-center text-gray-500 py-8">${result.message || 'Lỗi tải sản phẩm'}</div>`;
                                                            }
                                                        } catch (err) {
                                                            if (page === 1) container.innerHTML = `<div class="w-full text-center text-red-500 py-8">Lỗi kết nối khi tải sản phẩm</div>`;
                                                        } finally {
                                                            isLoadingMore = false;
                                                            if (spinner) spinner.classList.add('hidden');
                                                            lucide.createIcons();
                                                            setupInfiniteScroll(); // Ensure observer is attached
                                                        }
                                                    }

                                                    function setupInfiniteScroll() {
                                                        const trigger = document.getElementById('load-more-trigger');
                                                        if (!trigger || window.infiniteScrollObserver) return;

                                                        window.infiniteScrollObserver = new IntersectionObserver((entries) => {
                                                            if (entries[0].isIntersecting && hasMoreProducts && !isLoadingMore && currentTab === 'products') {
                                                                loadProducts(currentPage + 1);
                                                            }
                                                        }, { rootMargin: '100px' });

                                                        window.infiniteScrollObserver.observe(trigger);
                                                    }

                                                    let currentWishlistPage = 1;
                                                    let isLoadingMoreWishlist = false;
                                                    let hasMoreWishlist = true;

                                                    async function loadWishlist(page = 1) {
                                                        const container = document.getElementById('wishlist-list');
                                                        const spinner = document.getElementById('load-more-wishlist-spinner');

                                                        if (page === 1 && container.dataset.loaded) return;
                                                        if (isLoadingMoreWishlist || (!hasMoreWishlist && page > 1)) return;

                                                        isLoadingMoreWishlist = true;

                                                        if (page === 1) {
                                                            container.innerHTML = '<div class="w-full flex justify-center p-8"><i data-lucide="loader-2" class="w-8 h-8 animate-spin text-[#2D5A3D]"></i></div>';
                                                            lucide.createIcons();
                                                        } else {
                                                            if (spinner) spinner.classList.remove('hidden');
                                                        }

                                                        try {
                                                            const response = await fetch(`/Profile/GetWishlist?pageIndex=${page}`);
                                                            const result = await response.json();

                                                            await new Promise(resolve => setTimeout(resolve, 400));

                                                            if (result.success && result.data && result.data.items) {
                                                                const items = result.data.items;
                                                                if (page === 1) container.innerHTML = '';

                                                                if (items.length === 0 && page === 1) {
                                                                    container.innerHTML = `<div class="bg-white/80 backdrop-blur-xl border border-white/60 rounded-[32px] shadow-sm p-12 text-center">
                                                                            <i data-lucide="heart" class="w-16 h-16 text-gray-300 mx-auto mb-4"></i>
                                                                            <h3 class="text-lg font-semibold text-gray-700 mb-2">Chưa có sản phẩm yêu thích</h3>
                                                                            <p class="text-gray-500 text-sm">Khám phá và thêm sản phẩm vào danh sách yêu thích của bạn</p>
                                                                        </div>`;
                                                                    hasMoreWishlist = false;
                                                                } else {
                                                                    renderProductList(container, items, page > 1, 'wishlist');
                                                                    hasMoreWishlist = page < result.data.totalPages;
                                                                }

                                                                if (page === 1) container.dataset.loaded = "true";

                                                                const totalCount = result.data.totalCount || items.length;
                                                                const badge = document.getElementById('badge-wishlist');
                                                                if (badge) {
                                                                    badge.innerText = totalCount;
                                                                    badge.classList.remove('hidden');
                                                                }

                                                                currentWishlistPage = page;
                                                            } else {
                                                                if (page === 1) container.innerHTML = `<div class="w-full text-center text-gray-500 py-8">${result.message || 'Lỗi tải mục yêu thích'}</div>`;
                                                            }
                                                        } catch (err) {
                                                            if (page === 1) container.innerHTML = `<div class="w-full text-center text-red-500 py-8">Lỗi kết nối khi tải mục yêu thích</div>`;
                                                        } finally {
                                                            isLoadingMoreWishlist = false;
                                                            if (spinner) spinner.classList.add('hidden');
                                                            lucide.createIcons();
                                                            setupInfiniteScrollWishlist();
                                                        }
                                                    }

                                                    function setupInfiniteScrollWishlist() {
                                                        const trigger = document.getElementById('load-more-trigger-wishlist');
                                                        if (!trigger || window.infiniteScrollWishlistObserver) return;

                                                        window.infiniteScrollWishlistObserver = new IntersectionObserver((entries) => {
                                                            if (entries[0].isIntersecting && hasMoreWishlist && !isLoadingMoreWishlist && currentTab === 'wishlist') {
                                                                loadWishlist(currentWishlistPage + 1);
                                                            }
                                                        }, { rootMargin: '100px' });

                                                        window.infiniteScrollWishlistObserver.observe(trigger);
                                                    }

