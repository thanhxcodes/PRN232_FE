                                                                    }
                                                                }
                                                                if (fieldId === 'birthday' && val) {
                                                                    if (new Date(val) > new Date()) {
                                                                        hasError = true;
                                                                        customMsg = 'Ngày sinh không được ở tương lai.';
                                                                    }
                                                                }

                                                                if (hasError) {
