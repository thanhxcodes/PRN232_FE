@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
    var activeTab = ViewBag.ActiveTab as string ?? "profile";
    bool isOwnProfile = ViewBag.IsOwnProfile ?? true;
    var profile = ViewBag.Profile as REVORA_MVC_FE.Models.UserProfileDto;
    long currentUserId = profile?.Id ?? 0;

    // Format follower/following counts
    string FormatCount(int count) => count >= 1000 ? (count / 1000.0).ToString("0.#") + "k" : count.ToString();
    string followersCountStr = FormatCount(profile?.FollowerCount ?? 0);
    string followingCountStr = FormatCount(profile?.FollowingCount ?? 0);
    string joinedStr = profile?.CreatedAt != null ? $"Tham gia {profile.CreatedAt.Month}/{profile.CreatedAt.Year}" : "Tham gia —";
}

@section Styles {
    <style>
        .profile-tab-btn {
            transition: all 0.2s ease-in-out;
        }

        .profile-tab-btn.active {
            color: white;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .profile-tab-btn.active .tab-bg {
            opacity: 1;
        }

        .profile-tab-btn .tab-bg {
            opacity: 0;
            transition: opacity 0.2s ease-in-out;
        }

        @@keyframes bounceIn {
            0% {
                opacity: 0;
                transform: translateX(-50%) scale(0.7) translateY(-8px);
            }

            60% {
                opacity: 1;
                transform: translateX(-50%) scale(1.06) translateY(2px);
            }

            100% {
                opacity: 1;
                transform: translateX(-50%) scale(1) translateY(0);
            }
        }

        .animate-bounce-in {
            animation: bounceIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        }

        @@keyframes slideUpBar {
            from {
                opacity: 0;
                transform: translateY(100%);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-slide-up-bar {
            animation: slideUpBar 0.3s cubic-bezier(0.34, 1.2, 0.64, 1) both;
        }
    </style>
    <style>
        /* Hide the native eye icon in Edge/IE */
        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear,
        input[type="password"]::-webkit-reveal,
        input[type="password"]::-webkit-clear-button {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
        }
    </style>
}

<div class="min-h-screen bg-gray-50" id="profile-app">
    <!-- Public View Banner (Facebook "View As" Style) -->
    @await Html.PartialAsync("Partials/_ProfileHeader")
    <!-- Tab Content Containers -->
    @await Html.PartialAsync("Partials/_TabProfileInfo")
    @await Html.PartialAsync("Partials/_TabSelling")
    @await Html.PartialAsync("Partials/_TabWishlist")
    @await Html.PartialAsync("Partials/_TabSecurity")
</div>
</div>
</div>
@await Html.PartialAsync("Partials/_Modals")

@section Scripts {
    <script>
        // Inject server variables into window for ProfileManager
        window.ProfileData = {
            initialProfile: @Html.Raw(Json.Serialize(profile)),
            currentTab: '@activeTab',
            isOwnProfile: @(isOwnProfile.ToString().ToLower()),
            targetUserId: '@currentUserId'
        };
    </script>
    <script src="~/js/pages/profile.js"></script>
}
