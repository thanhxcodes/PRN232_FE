@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
    var activeTab = ViewBag.ActiveTab as string ?? "profile";
    bool isOwnProfile = ViewBag.IsOwnProfile ?? true;
    var profile = ViewBag.Profile as REVORA_MVC_FE.Models.UserProfileDto;
    long currentUserId = profile?.Id ?? 0;

    // Format follower/following counts
    string FormatCount(int count) => count >= 1000 ? (count / 1000.0).ToString("0.#") + "k" : count.ToString();
    string followersCountStr = FormatCount(profile?.FollowerCount ?? 0);
    string followingCountStr = FormatCount(profile?.FollowingCount ?? 0);
    string joinedStr = profile?.CreatedAt != null ? $"Tham gia {profile.CreatedAt.Month}/{profile.CreatedAt.Year}" : "Tham gia —";
}

@section Styles {
    <style>
        .profile-tab-btn {
            transition: all 0.2s ease-in-out;
        }

        .profile-tab-btn.active {
            color: white;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .profile-tab-btn.active .tab-bg {
            opacity: 1;
        }

        .profile-tab-btn .tab-bg {
            opacity: 0;
            transition: opacity 0.2s ease-in-out;
        }

        @@keyframes bounceIn {
            0% { opacity: 0; transform: translateX(-50%) scale(0.7) translateY(-8px); }
            60% { opacity: 1; transform: translateX(-50%) scale(1.06) translateY(2px); }
            100% { opacity: 1; transform: translateX(-50%) scale(1) translateY(0); }
        }
        .animate-bounce-in {
            animation: bounceIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        }

        @@keyframes slideUpBar {
            from { opacity: 0; transform: translateY(100%); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .animate-slide-up-bar {
            animation: slideUpBar 0.3s cubic-bezier(0.34, 1.2, 0.64, 1) both;
        }
    </style>
    <style>
        /* Hide the native eye icon in Edge/IE */
        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear,
        input[type="password"]::-webkit-reveal,
        input[type="password"]::-webkit-clear-button {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
        }
    </style>
}

<div class="min-h-screen bg-gray-50" id="profile-app">
    <!-- Public View Banner (Facebook "View As" Style) -->
    <div id="public-view-banner"
         class="hidden fixed top-16 left-0 right-0 z-40 transition-all duration-300 transform -translate-y-full"
         style="background-color: #0f172a; color: white; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
        <div
            style="max-width: 80rem; margin: 0 auto; padding: 12px 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px;">
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="background-color: rgba(255,255,255,0.2); padding: 6px; border-radius: 50%;">
                    <i data-lucide="eye" style="width: 20px; height: 20px;"></i>
                </div>
                <div>
                    <div style="font-weight: 700; font-size: 14px;">CHẾ ĐỘ KHÁCH</div>
                    <div style="font-size: 13px; opacity: 0.9;">Bạn đang xem trang cá nhân dưới góc nhìn của một khách
                        hàng.</div>
                    </div>
                </div>

                <button id="btn-exit-public"
                        style="background-color: white; color: #0f172a; border: none; padding: 8px 20px; border-radius: 9999px; font-weight: 700; font-size: 13px; cursor: pointer; display: flex; align-items: center; gap: 6px; box-shadow: 0 1px 2px rgba(0,0,0,0.1); transition: all 0.2s;">
                    <i data-lucide="x" style="width: 16px; height: 16px;"></i> Thoát chế độ
                </button>
            </div>
        </div>

    <!-- Banner - Abstract Mesh Gradient -->
    <div class="h-72 relative overflow-hidden bg-[#2D5A3D]" id="profile-banner-container">
        <!-- Animated Mesh Gradients -->
        <div class="absolute top-0 left-0 w-full h-full opacity-60 mix-blend-screen" id="profile-banner-content">
            <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[150%] bg-gradient-to-br from-[#3D7054] to-[#C4603A]/30 rounded-full blur-[100px] animate-pulse" style="animation-duration: 8s;"></div>
            <div class="absolute top-[-10%] right-[-10%] w-[60%] h-[120%] bg-gradient-to-bl from-[#C4603A]/20 to-[#2D5A3D] rounded-full blur-[120px] animate-pulse" style="animation-duration: 10s; animation-delay: 1s;"></div>
        </div>
        <div class="absolute inset-0 bg-black/10"></div>
        <div class="absolute bottom-4 right-4 z-20 hidden" id="banner-picker-container">
            <input type="file" id="banner-upload" accept="image/jpeg,image/png,image/gif" class="hidden" />
            <label for="banner-upload" class="bg-white/80 backdrop-blur-md px-4 py-2 text-gray-700 rounded-lg flex items-center gap-2 shadow-lg border border-white/40 cursor-pointer hover:bg-white hover:text-[#2D5A3D] transition-colors font-medium text-sm">
                <i data-lucide="camera" class="w-4 h-4"></i> Thay ảnh bìa
            </label>
        </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Profile card - Glassmorphism -->
        <div class="relative -mt-40 mb-8">
            <div
                class="bg-white/80 backdrop-blur-2xl border border-white/60 rounded-[32px] shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] p-8 md:p-10">
                <div class="flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-8">
                    <!-- Avatar -->
                    <div class="relative flex-shrink-0 z-10">
                        <div class="w-32 h-32 rounded-full flex items-center justify-center text-white text-3xl font-bold shadow-lg select-none bg-cover bg-center overflow-hidden bg-[#2D5A3D] relative group/avatar"
                             id="profile-avatar"
                             style="@(!string.IsNullOrEmpty(profile?.AvatarUrl) ? $"background-image: url('{profile.AvatarUrl}')" : "")">
                            <span id="profile-initials">@(string.IsNullOrEmpty(profile?.AvatarUrl) ? (profile?.FullName
                                                                ?? "U").Substring(0, 1).ToUpper() : "")</span>
                            
                            <div class="absolute inset-0 bg-black/35 rounded-full flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity hidden cursor-pointer" id="avatar-picker-overlay">
                                <i data-lucide="camera" class="w-8 h-8 text-white"></i>
                            </div>
                        </div>

                        <!-- Dropdown Menu for Avatar -->
                        <div class="absolute top-[105%] left-0 bg-white rounded-2xl shadow-xl border border-gray-100 p-4 z-50 min-w-[200px] hidden" id="avatar-dropdown">
                            <p class="text-xs text-gray-500 mb-3 font-semibold uppercase tracking-wide">Ảnh đại diện</p>
                            <div class="mb-4 flex flex-col gap-2">
                                <label for="avatar-upload" class="flex items-center gap-2 px-3 py-2 bg-gray-50 hover:bg-gray-100 text-sm font-medium text-gray-700 rounded-lg transition-colors border border-gray-200 justify-center cursor-pointer w-full">
                                    <i data-lucide="camera" class="w-4 h-4"></i> Tải ảnh lên
                                </label>
                                <input type="file" id="avatar-upload" accept="image/jpeg,image/png,image/gif" class="hidden" />
                            </div>
                            <p class="text-xs text-gray-500 mb-3 font-semibold uppercase tracking-wide">Hoặc chọn màu</p>
                            <div class="grid grid-cols-4 gap-2" id="avatar-color-grid">
                                <!-- Colors injected here via JS -->
                            </div>
                        </div>
                        

                        <!-- Online indicator -->
                        <div class="absolute -bottom-1 -right-1">
                            <div
                                class="w-8 h-8 rounded-full border-4 border-white flex items-center justify-center bg-green-500">
                                <div class="w-3 h-3 rounded-full bg-green-400"></div>
                            </div>
                        </div>
                    </div>

                            <!-- Info -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center flex-wrap gap-3 mb-1">
                                    <h1 class="text-2xl font-bold text-gray-900" id="profile-name">@(profile?.FullName ?? "")
                                    </h1>
                                    <button
                                        class="w-8 h-8 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] rounded-full flex items-center justify-center text-white text-lg hover:scale-110 transition-transform @(isOwnProfile ? "cursor-pointer" : "cursor-default")"
                                        title="Premium Gold" id="btn-badge">
                                        ⭐
                                    </button>
                                </div>
                                <p class="text-gray-400 text-sm mb-3">@@<span id="profile-username">@(profile?.Username ??
                                     "")</span></p>
                                    <div class="flex flex-wrap gap-4 mb-4 text-sm text-gray-600">
                                        <span class="flex items-center gap-1.5">
                                            <i data-lucide="map-pin" class="w-4 h-4 text-[#2D5A3D]"></i> <span
                                            id="profile-city">@(profile?.City ?? "Chưa có thông tin")</span>
                                        </span>
                                        <span class="flex items-center gap-1.5">
                                            <i data-lucide="calendar" class="w-4 h-4 text-[#2D5A3D]"></i> @joinedStr
                                        </span>
                                    </div>
                                    <p class="text-gray-600 text-sm leading-relaxed max-w-2xl line-clamp-2 mb-3" id="profile-bio">
                                        @(profile?.Bio ?? "Chưa có thông tin tiểu sử.")</p>
                                    </div>

                                    <!-- Actions -->
                                    <div class="flex flex-col gap-3 flex-shrink-0 w-full md:w-auto" id="profile-actions">
                                        @if (isOwnProfile)
                                        {
                                            <button id="btn-edit-profile"
                                                    class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white px-6 py-2.5 rounded-full hover:shadow-lg transition-all text-sm font-semibold">
                                                <i data-lucide="edit-3" class="w-4 h-4"></i> Sửa Hồ Sơ
                                            </button>
                                            <button id="btn-toggle-public"
                                                    class="flex items-center justify-center gap-2 border-2 border-gray-200 text-gray-600 px-6 py-2.5 rounded-full hover:bg-gray-50 transition-colors text-sm font-medium">
                                                <i data-lucide="eye" class="w-4 h-4"></i> <span id="text-toggle-public">Góc nhìn khách
                                                hàng</span>
                                            </button>
                                        }
                                        else
                                        {
                                            if (profile != null && profile.IsFollowing)
                                            {
                                                <button id="btn-follow" data-target="@profile.Id"
                                                        class="flex items-center justify-center gap-2 border-2 border-gray-200 text-gray-600 px-6 py-2.5 rounded-full hover:bg-gray-50 hover:border-red-200 hover:text-red-500 transition-colors text-sm font-medium">
                                                    <i data-lucide="user-check" class="w-4 h-4"></i> Đang theo dõi
                                                </button>
                                            }
                                            else
                                            {
                                                <button id="btn-follow" data-target="@(profile?.Id)"
                                                        class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white px-6 py-2.5 rounded-full hover:shadow-lg transition-all text-sm font-semibold">
                                                    <i data-lucide="user-plus" class="w-4 h-4"></i> Theo dõi
                                                </button>
                                            }
                                        }
                                    </div>
                                </div>

                                <!-- Stats -->
                                <div class="grid grid-cols-3 gap-4 md:gap-6 mt-8 pt-8 border-t border-gray-200/50">
                                    <div class="flex flex-col items-center p-4 rounded-2xl hover:bg-white/50 transition-colors">
                                        <div class="text-3xl font-black text-[#2D5A3D] drop-shadow-sm" id="stat-selling">0</div>
                                        <div class="text-sm font-medium text-gray-500 mt-1 uppercase tracking-wider">Đang Bán</div>
                                    </div>
                                    <div class="flex flex-col items-center p-4 rounded-2xl hover:bg-[#2D5A3D]/5 hover:scale-105 transition-all cursor-pointer group"
                                         id="btn-followers">
                                        <div class="text-3xl font-black text-[#2D5A3D] drop-shadow-sm group-hover:text-[#3D7054] transition-colors"
                                             id="stat-followers">@followersCountStr</div>
                                        <div
                                            class="text-sm font-medium text-gray-500 mt-1 uppercase tracking-wider group-hover:text-[#2D5A3D] transition-colors">
                                            Follower</div>
                                        </div>
                                        <div class="flex flex-col items-center p-4 rounded-2xl hover:bg-[#2D5A3D]/5 hover:scale-105 transition-all cursor-pointer group"
                                             id="btn-following">
                                            <div class="text-3xl font-black text-[#2D5A3D] drop-shadow-sm group-hover:text-[#3D7054] transition-colors"
                                                 id="stat-following">@followingCountStr</div>
                                            <div
                                                class="text-sm font-medium text-gray-500 mt-1 uppercase tracking-wider group-hover:text-[#2D5A3D] transition-colors">
                                                Đã Follow</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Tabs - Pill format -->
                                <div class="mb-8 flex justify-center overflow-x-auto pb-2" style="scrollbar-width: none;">
                                    <div
                                        class="bg-white/60 backdrop-blur-md rounded-full shadow-sm p-1.5 inline-flex gap-2 border border-white/40">
                                        <button data-tab="profile"
                                                class="profile-tab-btn flex items-center gap-2.5 px-6 py-2.5 rounded-full text-[15px] font-semibold relative text-gray-600 hover:text-gray-900 hover:bg-white/50">
                                            <div
                                                class="tab-bg absolute inset-0 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] rounded-full -z-10">
                                            </div>
                                            <i data-lucide="user" class="w-4 h-4"></i> <span>Hồ Sơ</span>
                                        </button>
                                        <button data-tab="products"
                                                class="profile-tab-btn flex items-center gap-2.5 px-6 py-2.5 rounded-full text-[15px] font-semibold relative text-gray-600 hover:text-gray-900 hover:bg-white/50">
                                            <div
                                                class="tab-bg absolute inset-0 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] rounded-full -z-10">
                                            </div>
                                            <i data-lucide="package" class="w-4 h-4"></i> <span>Đang Bán</span>
                                            <span id="badge-products"
                                                  class="hidden ml-1 px-2 py-0.5 rounded-full bg-gray-200 text-gray-700 text-xs font-bold">0</span>
                                        </button>
                                        @if (isOwnProfile)
                                        {
                                            <button data-tab="wishlist"
                                                    class="profile-tab-btn flex items-center gap-2.5 px-6 py-2.5 rounded-full text-[15px] font-semibold relative text-gray-600 hover:text-gray-900 hover:bg-white/50">
                                                <div
                                                    class="tab-bg absolute inset-0 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] rounded-full -z-10">
                                                </div>
                                                <i data-lucide="heart" class="w-4 h-4"></i> <span>Yêu Thích</span>
                                                <span id="badge-wishlist"
                                                      class="hidden ml-1 px-2 py-0.5 rounded-full bg-gray-200 text-gray-700 text-xs font-bold">0</span>
                                            </button>
                                            <button data-tab="security"
                                                    class="profile-tab-btn flex items-center gap-2.5 px-6 py-2.5 rounded-full text-[15px] font-semibold relative text-gray-600 hover:text-gray-900 hover:bg-white/50">
                                                <div
                                                    class="tab-bg absolute inset-0 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] rounded-full -z-10">
                                                </div>
                                                <i data-lucide="lock" class="w-4 h-4"></i> <span>Bảo Mật</span>
                                            </button>
                                        }
                                    </div>
                                </div>

                                <!-- Tab Content Containers -->
                                <div class="pb-16 relative min-h-[400px]">
                                    <!-- PROFILE TAB -->
                                    <div id="tab-content-profile"
                                         class="tab-content absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300">
                                        <div class="bg-white/80 backdrop-blur-xl border border-white/60 rounded-[32px] shadow-sm p-8 md:p-10">
                                            <h2 class="text-lg font-bold text-gray-900 mb-7">Thông Tin Cá Nhân</h2>

                                            <!-- View Mode Grid -->
                                            <div id="profile-view-mode" class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                <!-- Rendered via JS -->
                                            </div>

                                            <!-- Edit Mode Form -->
                                            <div id="profile-edit-mode" class="hidden">
                                                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                                    <div class="md:col-span-2">
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Họ và Tên</label>
                                                        <input type="text" id="edit-name"
                                                               class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors" />
                                                        <span id="error-name" class="hidden text-xs text-red-500 mt-1.5 font-medium flex items-center gap-1">
                                                            <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i> <span class="error-text"></span>
                                                        </span>
                                                    </div>
                                                    <div class="md:col-span-2">
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Tiểu Sử</label>
                                                        <textarea id="edit-bio" rows="3"
                                                                  class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors resize-none"></textarea>
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Ngày Sinh</label>
                                                        <input type="date" id="edit-birthday"
                                                               class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors" />
                                                        <span id="error-birthday" class="hidden text-xs text-red-500 mt-1.5 font-medium flex items-center gap-1">
                                                            <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i> <span class="error-text"></span>
                                                        </span>
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Giới Tính</label>
                                                        <select id="edit-gender"
                                                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors">
                                                            <option value="" disabled>Chọn giới tính</option>
                                                            <option value="female">Nữ</option>
                                                            <option value="male">Nam</option>
                                                            <option value="other">Khác</option>
                                                        </select>
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Số Điện Thoại</label>
                                                        <input type="tel" id="edit-phone"
                                                               class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors" />
                                                        <span id="error-phone" class="hidden text-xs text-red-500 mt-1.5 font-medium flex items-center gap-1">
                                                            <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i> <span class="error-text"></span>
                                                        </span>
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Tỉnh / Thành Phố</label>
                                                        <select id="edit-city"
                                                                class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors">
                                                            <option>Hà Nội</option>
                                                            <option>TP. Hồ Chí Minh</option>
                                                            <option>Đà Nẵng</option>
                                                            <option>Hải Phòng</option>
                                                            <option>Cần Thơ</option>
                                                        </select>
                                                    </div>
                                                    <div class="md:col-span-2">
                                                        <label class="block text-sm font-medium text-gray-700 mb-2">Địa Chỉ</label>
                                                        <input type="text" id="edit-address"
                                                               class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-gray-50 focus:bg-white transition-colors" />
                                                    </div>
                                                    <div class="md:col-span-2 flex justify-end gap-3 mt-4">
                                                        <button id="btn-cancel-edit"
                                                                class="flex items-center justify-center gap-2 px-6 py-2.5 rounded-full border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 transition-colors">Hủy</button>
                                                        <button id="btn-save-edit"
                                                                class="flex items-center justify-center gap-2 px-6 py-2.5 rounded-full bg-[#2D5A3D] text-white font-medium hover:bg-[#1a3825] transition-colors whitespace-nowrap min-w-[140px]">Lưu
                                                            Thay Đổi</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- PRODUCTS TAB -->
                                        <div id="tab-content-products"
                                             class="tab-content absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300">
                                            @if (isOwnProfile)
                                            {
                                                <div id="owner-store-banner"
                                                     class="bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-[24px] p-6 mb-6 flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
                                                    <div class="w-12 h-12 rounded-full bg-blue-200/50 flex items-center justify-center flex-shrink-0">
                                                        <i data-lucide="store" class="w-6 h-6 text-blue-600"></i>
                                                    </div>
                                                    <div class="flex-1">
                                                        <h3 class="text-sm font-bold text-blue-900 mb-1">Tin đăng của bạn</h3>
                                                        <p class="text-xs text-blue-700/80 leading-relaxed">Các sản phẩm đang hiển thị công khai trên
                                                            gian hàng. Để chỉnh sửa thông tin, ẩn/hiện hoặc xóa sản phẩm, vui lòng truy cập trang Quản
                                                            lý.</p>
                                                        </div>
                                                        <a href="/Products/Manage"
                                                               class="flex-shrink-0 px-5 py-2.5 bg-blue-600 text-white rounded-xl text-sm font-semibold hover:bg-blue-700 transition-colors shadow-sm flex items-center gap-2">
                                                            <span>Quản lý tin đăng</span>
                                                            <i data-lucide="arrow-right" class="w-4 h-4"></i>
                                                        </a>
                                                    </div>
                                                }

                                                <div class="flex items-center justify-end mb-4">
                                                    <select id="sort-products"
                                                            class="px-4 py-2 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-[#2D5A3D]/30 bg-white cursor-pointer">
                                                        <option value="newest">Mới Nhất</option>
                                                        <option value="priceAsc">Giá: Thấp đến Cao</option>
                                                        <option value="priceDesc">Giá: Cao đến Thấp</option>
                                                        <option value="popular">Phổ Biến Nhất</option>
                                                    </select>
                                                </div>
                                                <div id="products-list" class="flex flex-col gap-4">
                                                    <!-- Rendered via JS -->
                                                </div>
