                                                                            <h3 class="text-lg font-semibold text-gray-900 truncate group-hover/link:text-[#2D5A3D] transition-colors mb-1.5">${p.title}</h3>
                                                                        </a>
                                                                        <div class="text-xl font-bold text-[#2D5A3D] tracking-tight mb-3">${price}</div>
                        
                                                                        <div class="flex flex-wrap items-center gap-3 text-xs text-gray-600 font-medium mt-auto pt-2">
                                                                            <div class="flex items-center gap-1.5 bg-gray-100/80 px-2.5 py-1 rounded-lg">
                                                                                <i data-lucide="user" class="w-3.5 h-3.5"></i> <span class="truncate max-w-[100px]">${p.sellerName || 'Người bán'}</span>
                                                                            </div>
                                                                            <div class="flex items-center gap-1.5 bg-gray-100/80 px-2.5 py-1 rounded-lg">
                                                                                <i data-lucide="tag" class="w-3.5 h-3.5"></i> <span class="truncate max-w-[120px]">${p.condition || 'New'}</span>
                                                                            </div>
                                                                            <div class="flex items-center gap-1.5 bg-gray-100/80 px-2.5 py-1 rounded-lg">
                                                                                <i data-lucide="map-pin" class="w-3.5 h-3.5"></i> <span class="truncate max-w-[150px]">${p.location || 'Hà Nội'}</span>
                                                                            </div>
                                                                        </div>
                        
                                                                        ${contextType === 'products' ? `
                                                                        <div class="mt-3 flex flex-col gap-1 text-[12px] text-gray-400">
                                                                            ${p.createdAt ? `
                                                                            <div class="flex items-center gap-1.5">
                                                                                <i data-lucide="calendar" class="w-3.5 h-3.5 text-gray-900"></i> <span class="text-gray-900 font-medium">Ngày đăng tin: ${postedDate}</span>
                                                                            </div>
                                                                            <div class="flex items-center gap-1.5">
                                                                                <i data-lucide="clock" class="w-3.5 h-3.5 text-gray-900"></i> <span class="text-gray-900 font-medium">Ngày hết hạn: ${expiryStr}</span>
                                                                            </div>` : ''}
                                                                        </div>
                                                                        ` : ''}
                                                                    </div>
                                                                    ${actionButtons}
                                                                </div>`;
                                                        });

                                                        if (append) {
                                                            container.insertAdjacentHTML('beforeend', html);
                                                        } else {
                                                            container.innerHTML = html;
                                                        }
                                                        if (typeof window.updateAllWishlistButtons === 'function') {
                                                            window.updateAllWishlistButtons();
                                                        }
                                                    }

                                                    async function toggleWishlistAction(productId, btn) {
                                                        const isWishlisted = btn.classList.contains('text-red-500');
                                                        const originalHtml = btn.innerHTML;
                                                        btn.innerHTML = '<i data-lucide="loader-2" class="w-5 h-5 animate-spin"></i>';
                                                        lucide.createIcons();

                                                        try {
                                                            const response = await fetch(`/Profile/ToggleWishlist?productId=${productId}`, { method: 'POST' });
                                                            const result = await response.json();

                                                            if (result.success) {
                                                                const badges = [document.getElementById('badge-wishlist'), document.getElementById('global-wishlist-count')];

                                                                if (isWishlisted) {
                                                                    showToast('Đã bỏ yêu thích', 'success');
                                                                    btn.classList.remove('text-red-500', 'hover:text-red-600');
                                                                    btn.classList.add('text-gray-400', 'hover:text-gray-600');
                                                                    btn.title = 'Thêm vào yêu thích';
                                                                    btn.innerHTML = '<i data-lucide="heart" class="w-6 h-6 transition-colors"></i>';

                                                                    badges.forEach(b => {
                                                                        if (b) {
                                                                            let current = parseInt(b.innerText || '0');
                                                                            if (current > 0) {
                                                                                b.innerText = current - 1;
                                                                                if (b.id === 'global-wishlist-count' && current - 1 === 0) b.classList.add('hidden');
                                                                            }
                                                                        }
                                                                    });
                                                                } else {
                                                                    showToast('Đã thêm vào yêu thích', 'success');
                                                                    btn.classList.remove('text-gray-400', 'hover:text-gray-600');
                                                                    btn.classList.add('text-red-500', 'hover:text-red-600');
                                                                    btn.title = 'Bỏ yêu thích';
                                                                    btn.innerHTML = '<i data-lucide="heart" class="w-6 h-6 transition-colors fill-current"></i>';

                                                                    badges.forEach(b => {
                                                                        if (b) {
                                                                            let current = parseInt(b.innerText || '0');
                                                                            b.innerText = current + 1;
                                                                            if (b.id === 'global-wishlist-count') b.classList.remove('hidden');
                                                                        }
                                                                    });
                                                                }
                                                                lucide.createIcons();
                                                            } else {
                                                                showToast(result.message || 'Lỗi hệ thống', 'error');
                                                                btn.innerHTML = originalHtml;
                                                                lucide.createIcons();
                                                            }
                                                        } catch (err) {
                                                            showToast('Lỗi kết nối', 'error');
                                                            btn.innerHTML = originalHtml;
                                                            lucide.createIcons();
                                                        }
                                                    }
                                                    
                                                    // ================= FOLLOW LOGIC =================
                                                        const followModal = document.getElementById('follow-modal');
                                                        const followModalBackdrop = document.getElementById('follow-modal-backdrop');
                                                        const followModalContent = document.getElementById('follow-modal-content');
                                                        const btnCloseFollowModal = document.getElementById('btn-close-follow-modal');
                                                        const followListContainer = document.getElementById('follow-list-container');
                                                        const tabFollowers = document.getElementById('tab-followers');
                                                        const tabFollowing = document.getElementById('tab-following');
                                                        
                                                        let followActiveTab = 'followers';
                                                        let isFollowDataLoading = false;

                                                        function openFollowModal(tab) {
                                                            followActiveTab = tab;
                                                            updateFollowTabsUI();
                                                            
                                                            followModal.classList.remove('hidden');
                                                            // Trigger reflow
                                                            void followModal.offsetWidth;
                                                            followModalBackdrop.classList.remove('opacity-0');
                                                            followModalBackdrop.classList.add('opacity-100');
                                                            followModalContent.classList.remove('scale-95', 'opacity-0');
                                                            followModalContent.classList.add('scale-100', 'opacity-100');
                                                            
                                                            loadFollowData(tab);
                                                        }

                                                        function closeFollowModal() {
                                                            followModalBackdrop.classList.remove('opacity-100');
                                                            followModalBackdrop.classList.add('opacity-0');
                                                            followModalContent.classList.remove('scale-100', 'opacity-100');
                                                            followModalContent.classList.add('scale-95', 'opacity-0');
                                                            setTimeout(() => {
                                                                followModal.classList.add('hidden');
                                                            }, 300);
                                                        }

                                                        function updateFollowTabsUI() {
                                                            if (followActiveTab === 'followers') {
                                                                tabFollowers.className = 'flex-1 py-4 text-sm font-bold text-center border-b-2 border-[#2D5A3D] text-[#2D5A3D]';
                                                                tabFollowing.className = 'flex-1 py-4 text-sm font-bold text-center border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50 transition-colors';
                                                            } else {
                                                                tabFollowing.className = 'flex-1 py-4 text-sm font-bold text-center border-b-2 border-[#2D5A3D] text-[#2D5A3D]';
                                                                tabFollowers.className = 'flex-1 py-4 text-sm font-bold text-center border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50 transition-colors';
                                                            }
                                                        }

                                                        async function loadFollowData(tab) {
                                                            followListContainer.innerHTML = '<div class="p-8 text-center text-gray-400"><i data-lucide="loader-2" class="w-8 h-8 animate-spin mx-auto text-[#2D5A3D]"></i></div>';
                                                            lucide.createIcons();
                                                            
                                                            try {
                                                                const endpoint = tab === 'followers' 
                                                                    ? `/Profile/GetFollowers?userId=${targetUserId || profile.userId}`
                                                                    : `/Profile/GetFollowing?userId=${targetUserId || profile.userId}`;
                                                                    
                                                                const res = await fetch(endpoint);
                                                                const result = await res.json();
                                                                
                                                                if (result.success && result.data && result.data.items) {
                                                                    renderFollowList(result.data.items);
                                                                } else {
                                                                    followListContainer.innerHTML = '<div class="p-8 text-center text-gray-500">Không thể tải dữ liệu.</div>';
                                                                }
                                                            } catch (err) {
                                                                followListContainer.innerHTML = '<div class="p-8 text-center text-red-500">Lỗi kết nối.</div>';
                                                            }
                                                        }

                                                        function renderFollowList(items) {
                                                            if (items.length === 0) {
                                                                followListContainer.innerHTML = `
                                                                    <div class="flex flex-col items-center justify-center p-8 text-center">
                                                                        <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-4">
                                                                            <i data-lucide="users" class="w-8 h-8 text-gray-300"></i>
                                                                        </div>
                                                                        <p class="text-gray-500 text-sm">Chưa có ai ở đây cả.</p>
                                                                    </div>`;
                                                                lucide.createIcons();
                                                                return;
                                                            }
                                                            
                                                            followListContainer.innerHTML = '';
                                                            items.forEach(u => {
                                                                const itemDiv = document.createElement('div');
                                                                itemDiv.className = 'flex items-center justify-between p-3 hover:bg-gray-50 rounded-2xl transition-colors mb-1 group';
                                                                
                                                                const avatarSrc = u.avatarUrl ? `url('${u.avatarUrl}')` : '';
                                                                const avatarInitial = !u.avatarUrl ? (u.fullName || 'U')[0].toUpperCase() : '';
                                                                const isMe = u.userId.toString() === '@currentUserId';
                                                                
                                                                // Nút follow trong danh sách (ẩn nếu là chính mình)
                                                                let actionHtml = '';
                                                                if (!isMe) {
                                                                    if (u.isFollowing) {
                                                                        actionHtml = `<button class="btn-toggle-follow w-28 py-1.5 px-3 bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 rounded-full text-xs font-semibold transition-colors flex items-center justify-center gap-1.5" data-target="${u.userId}" data-state="following">
                                                                            <i data-lucide="user-check" class="w-3.5 h-3.5"></i> <span>Đang theo dõi</span>
                                                                        </button>`;
                                                                    } else {
                                                                        actionHtml = `<button class="btn-toggle-follow w-28 py-1.5 px-3 bg-[#2D5A3D] hover:bg-[#3D7054] text-white rounded-full text-xs font-semibold transition-colors flex items-center justify-center gap-1.5" data-target="${u.userId}" data-state="none">
                                                                            <i data-lucide="user-plus" class="w-3.5 h-3.5"></i> <span>Theo dõi</span>
                                                                        </button>`;
                                                                    }
                                                                }
                                                                
                                                                itemDiv.innerHTML = `
                                                                    <a href="/Profile?id=${u.userId}" class="flex items-center gap-3 flex-1 min-w-0">
                                                                        <div class="w-12 h-12 rounded-full bg-[#2D5A3D] flex items-center justify-center text-white font-bold flex-shrink-0 bg-cover bg-center" style="background-image: ${avatarSrc}">
                                                                            ${avatarInitial}
                                                                        </div>
                                                                        <div class="flex-1 min-w-0 pr-4">
                                                                            <h4 class="text-sm font-bold text-gray-900 truncate group-hover:text-[#2D5A3D] transition-colors">${u.fullName}</h4>
                                                                            <p class="text-xs text-gray-500 truncate">@@${u.username}</p>
                                                                        </div>
                                                                    </a>
                                                                    <div class="flex-shrink-0">
                                                                        ${actionHtml}
                                                                    </div>
                                                                `;
                                                                followListContainer.appendChild(itemDiv);
                                                            });
                                                            lucide.createIcons();
                                                            
                                                            // Gắn sự kiện cho các nút trong danh sách
                                                            document.querySelectorAll('.btn-toggle-follow').forEach(btn => {
                                                                btn.addEventListener('click', async (e) => {
                                                                    e.preventDefault();
                                                                    e.stopPropagation();
                                                                    const targetId = btn.getAttribute('data-target');
                                                                    const state = btn.getAttribute('data-state');
                                                                    
                                                                    // Loading state UI
                                                                    const originalHtml = btn.innerHTML;
                                                                    btn.innerHTML = '<i data-lucide="loader-2" class="w-3.5 h-3.5 animate-spin"></i>';
                                                                    btn.disabled = true;
                                                                    lucide.createIcons();
                                                                    
                                                                    try {
                                                                        const res = await fetch(`/Profile/ToggleFollow?targetUserId=${targetId}`, { method: 'POST' });
                                                                        const data = await res.json();
                                                                        if (data.success) {
                                                                            const isFollowingNow = data.data.isFollowing;
                                                                            if (isFollowingNow) {
                                                                                btn.setAttribute('data-state', 'following');
                                                                                btn.className = 'btn-toggle-follow w-28 py-1.5 px-3 bg-gray-100 hover:bg-red-50 text-gray-600 hover:text-red-600 rounded-full text-xs font-semibold transition-colors flex items-center justify-center gap-1.5';
                                                                                btn.innerHTML = '<i data-lucide="user-check" class="w-3.5 h-3.5"></i> <span>Đang theo dõi</span>';
                                                                            } else {
                                                                                btn.setAttribute('data-state', 'none');
                                                                                btn.className = 'btn-toggle-follow w-28 py-1.5 px-3 bg-[#2D5A3D] hover:bg-[#3D7054] text-white rounded-full text-xs font-semibold transition-colors flex items-center justify-center gap-1.5';
                                                                                btn.innerHTML = '<i data-lucide="user-plus" class="w-3.5 h-3.5"></i> <span>Theo dõi</span>';
                                                                            }
                                                                            updateLocalFollowStats(isFollowingNow, targetId);
                                                                            window.dispatchEvent(new CustomEvent('followStatusChanged', { detail: { targetId, isFollowing: isFollowingNow } }));
                                                                        } else {
                                                                            showToast(data.message || 'Lỗi hệ thống', 'error');
                                                                            btn.innerHTML = originalHtml;
                                                                        }
                                                                    } catch {
                                                                        showToast('Lỗi kết nối', 'error');
                                                                        btn.innerHTML = originalHtml;
                                                                    } finally {
                                                                        btn.disabled = false;
                                                                        lucide.createIcons();
                                                                    }
                                                                });
                                                            });
                                                        }

                                                        function updateLocalFollowStats(isFollowingAdded, targetId) {
                                                            if (isOwnProfile) {
                                                                // Nếu đang ở profile chính mình, theo dõi ai đó thì "Đã follow" (stat-following) tăng
                                                                const countEl = document.getElementById('stat-following');
                                                                if (countEl) {
                                                                    let currentCount = parseInt(countEl.innerText.replace('k', '000')) || 0;
                                                                    countEl.innerText = formatCount(isFollowingAdded ? currentCount + 1 : Math.max(0, currentCount - 1));
                                                                }
                                                            } else {
                                                                // Nếu đang ở profile người khác, và targetId đúng là chủ profile đó -> "Follower" (stat-followers) tăng
                                                                if (targetId && targetId.toString() === '@currentUserId') {
                                                                    const countEl = document.getElementById('stat-followers');
                                                                    if (countEl) {
                                                                        let currentCount = parseInt(countEl.innerText.replace('k', '000')) || 0;
                                                                        countEl.innerText = formatCount(isFollowingAdded ? currentCount + 1 : Math.max(0, currentCount - 1));
                                                                    }
                                                                }
                                                            }
                                                        }

                                                        // Event Listeners cho Modal Follow
                                                        document.getElementById('btn-followers')?.addEventListener('click', () => openFollowModal('followers'));
                                                        document.getElementById('btn-following')?.addEventListener('click', () => openFollowModal('following'));
                                                        btnCloseFollowModal?.addEventListener('click', closeFollowModal);
                                                        followModalBackdrop?.addEventListener('click', closeFollowModal);
                                                        
                                                        tabFollowers?.addEventListener('click', () => {
                                                            if (followActiveTab !== 'followers') {
                                                                openFollowModal('followers');
                                                            }
                                                        });
                                                        tabFollowing?.addEventListener('click', () => {
                                                            if (followActiveTab !== 'following') {
                                                                openFollowModal('following');
                                                            }
                                                        });

                                                        // Main Follow Button (ngoài profile)
                                                        document.getElementById('btn-follow')?.addEventListener('click', async (e) => {
                                                            const btn = e.currentTarget;
                                                            const targetId = btn.getAttribute('data-target');
                                                            if (!targetId) return;

                                                            const originalHtml = btn.innerHTML;
                                                            btn.innerHTML = '<i data-lucide="loader-2" class="w-4 h-4 animate-spin"></i> Đang xử lý...';
                                                            btn.disabled = true;
                                                            lucide.createIcons();

                                                            try {
                                                                const res = await fetch(`/Profile/ToggleFollow?targetUserId=${targetId}`, { method: 'POST' });
                                                                const data = await res.json();
                                                                if (data.success) {
                                                                    const isFollowingNow = data.data.isFollowing;
                                                                    const countEl = document.getElementById('stat-followers');
                                                                    let currentCount = parseInt(countEl.innerText) || 0;
                                                                    
                                                                    if (isFollowingNow) {
                                                                        btn.className = 'flex items-center justify-center gap-2 border-2 border-gray-200 text-gray-600 px-6 py-2.5 rounded-full hover:bg-gray-50 hover:border-red-200 hover:text-red-500 transition-colors text-sm font-medium';
                                                                        btn.innerHTML = '<i data-lucide="user-check" class="w-4 h-4"></i> Đang theo dõi';
                                                                        countEl.innerText = currentCount + 1;
                                                                        showToast('Đã theo dõi người dùng', 'success');
                                                                    } else {
                                                                        btn.className = 'flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white px-6 py-2.5 rounded-full hover:shadow-lg transition-all text-sm font-semibold';
                                                                        btn.innerHTML = '<i data-lucide="user-plus" class="w-4 h-4"></i> Theo dõi';
                                                                        countEl.innerText = Math.max(0, currentCount - 1);
                                                                        showToast('Đã bỏ theo dõi người dùng', 'success');
                                                                    }
                                                                    window.dispatchEvent(new CustomEvent('followStatusChanged', { detail: { targetId, isFollowing: isFollowingNow } }));
                                                                } else {
                                                                    showToast(data.message || 'Lỗi thao tác', 'error');
                                                                    btn.innerHTML = originalHtml;
                                                                }
                                                            } catch {
                                                                showToast('Lỗi kết nối máy chủ', 'error');
                                                                btn.innerHTML = originalHtml;
                                                            } finally {
                                                                btn.disabled = false;
                                                                lucide.createIcons();
                                                            }
                                                        });
                                                    </script>
                                                }
