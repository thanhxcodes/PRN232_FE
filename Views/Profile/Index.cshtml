                                                                            <div class="flex flex-row items-center gap-3">
                                                                                ${isMyProduct ? `
                                                                                <button disabled title="Bạn không thể tự chat với chính mình" class="flex-1 sm:flex-none py-2.5 px-5 rounded-xl text-sm font-semibold bg-gray-200 text-gray-500 shadow-sm cursor-not-allowed flex items-center justify-center space-x-1.5">
                                                                                    <i data-lucide="message-square" class="w-4 h-4"></i><span class="sm:hidden lg:inline">Sản phẩm của bạn</span>
