                                                                    if (eyeOff) eyeOff.classList.add('hidden');
                                                                    if (eye) eye.classList.remove('hidden');
                                                                }
                                                            });
                                                        });

                                                        function calcPasswordStrength(password) {
                                                            const rules = [
                                                                { id: 'length', passed: password.length >= 8 },
                                                                { id: 'uppercase', passed: /[A-Z]/.test(password) },
                                                                { id: 'lowercase', passed: /[a-z]/.test(password) },
                                                                { id: 'number', passed: /[0-9]/.test(password) },
                                                                { id: 'special', passed: /[@@#$!%*?&]/.test(password) }
                                                            ];
                                                            const score = Math.min(5, rules.filter(r => r.passed).length);
                                                            const levels = [
                                                                { label: 'Rất yếu', color: 'bg-red-500', textColor: 'text-red-600' },
                                                                { label: 'Yếu', color: 'bg-orange-400', textColor: 'text-orange-500' },
                                                                { label: 'Trung bình', color: 'bg-yellow-400', textColor: 'text-yellow-600' },
                                                                { label: 'Khá mạnh', color: 'bg-lime-500', textColor: 'text-lime-600' },
                                                                { label: 'Mạnh', color: 'bg-green-500', textColor: 'text-green-600' },
                                                                { label: 'Rất mạnh', color: 'bg-emerald-600', textColor: 'text-emerald-700' }
                                                            ];
                                                            return { score, rules, ...levels[score] };
                                                        }

                                                        // Real-time error clearing and confirm password validation
                                                        const validateConfirmPassword = () => {
                                                            const newPw = document.getElementById('pw-next').value;
                                                            const confirmPw = document.getElementById('pw-confirm').value;
                                                            const errConfirm = document.getElementById('pw-confirm-error');
                                                            const confirmInput = document.getElementById('pw-confirm');

                                                            if (confirmPw && confirmPw !== newPw) {
                                                                errConfirm.querySelector('span').innerText = 'Xác nhận mật khẩu mới không khớp';
                                                                errConfirm.classList.remove('hidden');
                                                                confirmInput.classList.add('border-rose-400', 'focus:ring-rose-200/50');
                                                            } else if (confirmPw && confirmPw === newPw) {
                                                                errConfirm.classList.add('hidden');
                                                                confirmInput.classList.remove('border-rose-400', 'focus:ring-rose-200/50');
                                                            }
                                                        };

                                                        const clearErrorOnInput = (inputId, errorId) => {
