@{
    var profile = ViewBag.Profile as REVORA_MVC_FE.Models.UserProfileDto;
    bool isOwnProfile = ViewBag.IsOwnProfile ?? true;
}
<div id="tab-content-security"
     class="tab-content absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="bg-white/80 backdrop-blur-xl border border-white/60 rounded-[32px] shadow-sm p-8 md:p-10">
        <h3 class="font-bold text-gray-900 text-lg mb-6">Thay Đổi Mật Khẩu</h3>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <!-- Left Column: Form -->
            <div class="lg:col-span-7 space-y-6">
                <div id="pw-success"
                     class="hidden bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-3.5 flex items-center gap-2.5 animate-slide-down">
                    <i data-lucide="check-circle" class="w-5 h-5 flex-shrink-0"></i> Đổi mật khẩu thành
                    công!
                </div>

                <div class="space-y-5">
                    <!-- Current Password -->
                    <div class="flex flex-col">
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Mật Khẩu Hiện
                            Tại</label>
                            <div class="relative">
                                <i data-lucide="lock"
                                   class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
                                <input type="password" id="pw-current" placeholder="••••••••" autocomplete="new-password"
                                       class="w-full pl-10 pr-12 py-3 rounded-xl border border-gray-200 focus:ring-[#2D5A3D]/30 focus:outline-none focus:ring-2 bg-gray-50 focus:bg-white transition-all duration-200 text-gray-900" />
                                <button type="button"
                                        class="btn-toggle-pw absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                                        data-target="pw-current">
                                    <i data-lucide="eye" class="w-5 h-5 icon-eye"></i>
                                    <i data-lucide="eye-off" class="w-5 h-5 icon-eye-off hidden"></i>
                                </button>
                            </div>
                            <p id="pw-current-error"
                                   class="hidden mt-1.5 text-xs text-rose-500 flex items-center gap-1.5 animate-slide-down">
                                <i data-lucide="alert-circle" class="w-3.5 h-3.5 flex-shrink-0"></i>
                                <span></span>
                            </p>
                        </div>

                        <!-- New Password -->
                        <div class="flex flex-col">
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Mật Khẩu Mới</label>
                            <div class="relative">
                                <i data-lucide="lock"
                                   class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
                                <input type="password" id="pw-next" placeholder="••••••••" autocomplete="new-password"
                                       class="w-full pl-10 pr-12 py-3 rounded-xl border border-gray-200 focus:ring-[#2D5A3D]/30 focus:outline-none focus:ring-2 bg-gray-50 focus:bg-white transition-all duration-200 text-gray-900" />
                                <button type="button"
                                        class="btn-toggle-pw absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                                        data-target="pw-next">
                                    <i data-lucide="eye" class="w-5 h-5 icon-eye"></i>
                                    <i data-lucide="eye-off" class="w-5 h-5 icon-eye-off hidden"></i>
                                </button>
                            </div>
                            <p id="pw-next-error"
                                   class="hidden mt-1.5 text-xs text-rose-500 flex items-center gap-1.5 animate-slide-down">
                                <i data-lucide="alert-circle" class="w-3.5 h-3.5 flex-shrink-0"></i>
                                <span></span>
                            </p>

                            <!-- Strength Meter -->
                            <div id="pw-strength-meter" class="hidden mt-2.5 space-y-2">
                                <div class="flex gap-1" id="pw-strength-bars">
                                    <div class="h-1.5 flex-1 rounded-full bg-gray-200 transition-all duration-300">
                                    </div>
                                    <div class="h-1.5 flex-1 rounded-full bg-gray-200 transition-all duration-300">
                                    </div>
                                    <div class="h-1.5 flex-1 rounded-full bg-gray-200 transition-all duration-300">
                                    </div>
                                    <div class="h-1.5 flex-1 rounded-full bg-gray-200 transition-all duration-300">
                                    </div>
                                    <div class="h-1.5 flex-1 rounded-full bg-gray-200 transition-all duration-300">
                                    </div>
                                </div>
                                <div class="flex items-center gap-1.5 text-xs font-semibold" id="pw-strength-label">
                                    <i data-lucide="shield-check" class="w-3.5 h-3.5"></i>
                                    <span>Độ mạnh: Chưa nhập</span>
                                </div>
                                <ul class="space-y-1" id="pw-strength-rules">
                                    <li class="flex items-center gap-1.5 text-xs text-gray-400 transition-colors"
                                        data-rule="length">
                                        <span class="w-3 h-3 flex-shrink-0"><svg viewBox="0 0 12 12" fill="none"
                                                                                 class="w-3 h-3">
                                            <circle cx="6" cy="6" r="5.5" stroke="#d1d5db" />
                                        </svg></span> Ít nhất 8 ký tự
                                    </li>
                                    <li class="flex items-center gap-1.5 text-xs text-gray-400 transition-colors"
                                        data-rule="uppercase">
                                        <span class="w-3 h-3 flex-shrink-0"><svg viewBox="0 0 12 12" fill="none"
                                                                                 class="w-3 h-3">
                                            <circle cx="6" cy="6" r="5.5" stroke="#d1d5db" />
                                        </svg></span> Chứa chữ hoa (A-Z)
                                    </li>
                                    <li class="flex items-center gap-1.5 text-xs text-gray-400 transition-colors"
                                        data-rule="lowercase">
                                        <span class="w-3 h-3 flex-shrink-0"><svg viewBox="0 0 12 12" fill="none"
                                                                                 class="w-3 h-3">
                                            <circle cx="6" cy="6" r="5.5" stroke="#d1d5db" />
                                        </svg></span> Chứa chữ thường (a-z)
                                    </li>
                                    <li class="flex items-center gap-1.5 text-xs text-gray-400 transition-colors"
                                        data-rule="number">
                                        <span class="w-3 h-3 flex-shrink-0"><svg viewBox="0 0 12 12" fill="none"
                                                                                 class="w-3 h-3">
                                            <circle cx="6" cy="6" r="5.5" stroke="#d1d5db" />
                                        </svg></span> Chứa chữ số (0-9)
                                    </li>
                                    <li class="flex items-center gap-1.5 text-xs text-gray-400 transition-colors"
                                        data-rule="special">
                                        <span class="w-3 h-3 flex-shrink-0"><svg viewBox="0 0 12 12" fill="none"
                                                                                 class="w-3 h-3">
                                            <circle cx="6" cy="6" r="5.5" stroke="#d1d5db" />
                                        </svg></span> Chứa ký tự đặc biệt (@@#$!%*?&)
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Confirm Password -->
                        <div class="flex flex-col">
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Xác Nhận Mật Khẩu
                                Mới</label>
                                <div class="relative">
                                    <i data-lucide="lock"
                                       class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"></i>
                                    <input type="password" id="pw-confirm" placeholder="••••••••" autocomplete="new-password"
                                           class="w-full pl-10 pr-12 py-3 rounded-xl border border-gray-200 focus:ring-[#2D5A3D]/30 focus:outline-none focus:ring-2 bg-gray-50 focus:bg-white transition-all duration-200 text-gray-900" />
                                    <button type="button"
                                            class="btn-toggle-pw absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600"
                                            data-target="pw-confirm">
                                        <i data-lucide="eye" class="w-5 h-5 icon-eye"></i>
                                        <i data-lucide="eye-off" class="w-5 h-5 icon-eye-off hidden"></i>
                                    </button>
                                </div>
                                <p id="pw-confirm-error"
                                       class="hidden mt-1.5 text-xs text-rose-500 flex items-center gap-1.5 animate-slide-down">
                                    <i data-lucide="alert-circle" class="w-3.5 h-3.5 flex-shrink-0"></i>
                                    <span></span>
                                </p>
                            </div>
                        </div>

                        <div id="pw-error"
                             class="hidden bg-rose-50 border border-rose-200 text-rose-700 text-sm px-4 py-3 rounded-xl flex items-center gap-2 animate-slide-down">
                            <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i> <span></span>
                        </div>

                        <button id="btn-save-pw"
                                class="flex items-center justify-center gap-2 bg-gradient-to-r from-[#2D5A3D] to-[#3D7054] text-white px-8 py-3 rounded-full shadow-md hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 active:shadow-md transition-all duration-200 font-semibold cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none w-full sm:w-auto">
                            Đổi Mật Khẩu
                        </button>
                    </div>

                    <!-- Right Column: Guidance -->
                    <div class="lg:col-span-5 space-y-5 animate-slide-down lg:border-l lg:border-gray-200/50 lg:pl-8">
                        <div class="bg-gray-50/80 backdrop-blur-sm border border-gray-100 rounded-2xl p-5 space-y-3">
                            <div class="flex items-center gap-2 text-[#2D5A3D]">
                                <i data-lucide="info" class="w-5 h-5 flex-shrink-0"></i>
                                <span class="font-bold text-gray-800 text-sm">Quy tắc đặt mật khẩu</span>
                            </div>
                            <p class="text-xs text-gray-500 leading-relaxed">
                                Mật khẩu phải có ít nhất 8 ký tự, bao gồm chữ hoa, chữ thường, số, ký tự đặc biệt
                                (@@, #, $, !, %, *, ?, &) và không chứa thông tin tài khoản (tên đăng nhập, email).
                            </p>
                        </div>

                        <div class="bg-[#2D5A3D]/5 backdrop-blur-sm border border-[#2D5A3D]/10 rounded-2xl p-5 space-y-3">
                            <div class="flex items-center gap-2 text-[#2D5A3D]">
                                <svg viewBox="0 0 24 24" fill="none" class="w-5 h-5 text-[#2D5A3D] flex-shrink-0"
                                     stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                </svg>
                                <span class="font-bold text-gray-800 text-sm">Khuyến nghị bảo mật</span>
                            </div>
                            <ul class="space-y-2 text-xs text-gray-500 list-disc pl-4 leading-relaxed">
                                <li>Sử dụng mật khẩu mạnh và không trùng lặp với các dịch vụ khác.</li>
                                <li>Thay đổi mật khẩu định kỳ 6 tháng một lần để bảo vệ tài khoản.</li>
                                <li>Không bao giờ chia sẻ mật khẩu của bạn với bất kỳ ai, kể cả quản trị viên hệ
                                    thống.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
